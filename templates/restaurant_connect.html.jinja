<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurants Connect - FridgeNet</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">

{% include "components/navbar.html.jinja" %}

<!-- Hero -->
<section class="bg-green-200 py-16 text-center">
    <h1 class="text-4xl font-bold mb-4 text-gray-900">Restaurants Connect</h1>
    <p class="text-lg text-gray-700 mb-8">
        Partner with us to reduce food waste and support your community
    </p>
    <a href="/signup" 
       class="bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-3 rounded-lg shadow-md transition">
        Login / Sign Up
    </a>
</section>

<!-- Benefits -->
<section class="max-w-6xl mx-auto py-12 px-6 grid md:grid-cols-3 gap-6">
    <div class="bg-white p-6 rounded-xl shadow">
        <h2 class="font-bold text-xl mb-2">Reduce Waste</h2>
        <p>Turn surplus food into meaningful impact instead of throwing it away.</p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow">
        <h2 class="font-bold text-xl mb-2">Help Community</h2>
        <p>Support local families through community fridges.</p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow">
        <h2 class="font-bold text-xl mb-2">Get Recognized</h2>
        <p>Your restaurant will be featured on our platform.</p>
    </div>
</section>

<!-- How It Works -->
<section class="bg-gray-100 py-12 text-center">
    <h2 class="text-3xl font-bold mb-8">How It Works</h2>
    <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto px-6">
        <div>1️⃣ Login / Sign Up</div>
        <div>2️⃣ Submit Food</div>
        <div>3️⃣ Pickup / Drop-off</div>
        <div>4️⃣ Feed the Community</div>
    </div>
</section>

</body>
</html>