<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurants Connect - FridgeNet</title>
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { 
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            orange: '#f97316',
                            dark: '#1b1730',
                            card: '#2a2545'
                        }
                    }
                }
            }
        }
    </script>

    <script>
        (function () {
            const saved = localStorage.getItem("theme");
            if (saved === "dark" || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
                document.documentElement.classList.add("dark");
            }
        })();
    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        
        body { 
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }

        .glass-effect {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.03);
        }

        .hero-gradient {
            background: radial-gradient(circle at top right, rgba(249, 115, 22, 0.1), transparent),
                        radial-gradient(circle at bottom left, rgba(34, 197, 94, 0.05), transparent);
        }
    </style>
</head>

<body class="bg-[#fcfcfd] dark:bg-brand-dark min-h-screen flex flex-col text-gray-900 dark:text-gray-100 transition-colors duration-500">

{% include "components/navbar.html.jinja" %}

<section class="relative overflow-hidden hero-gradient py-24 px-6 text-center border-b border-gray-100 dark:border-gray-800">
<div class="max-w-4xl mx-auto relative z-10 text-center">
    
    <h1 class="text-5xl md:text-6xl font-extrabold mb-6 tracking-tight
               text-gray-900 dark:text-white">
        RESTAURANTS 
        <span class="text-transparent bg-clip-text bg-gradient-to-r 
                     from-orange-500 to-amber-500
                     dark:from-orange-400 dark:to-amber-300">
            CONNECT
        </span>
    </h1>

    <p class="text-xl mb-10 max-w-2xl mx-auto leading-relaxed
              text-gray-600 dark:text-gray-400">
        Bridge the gap between surplus food and community need. 
        Join our network of responsible local eateries.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        
        {% if current_user.is_authenticated %}
        <a href="/restaurant-dashboard"
           class="w-full sm:w-auto 
                  bg-orange-500 hover:bg-orange-600 
                  dark:bg-orange-600 dark:hover:bg-orange-500
                  text-white font-bold px-10 py-4 rounded-xl 
                  shadow-lg shadow-orange-500/20 dark:shadow-orange-900/40
                  transition-all hover:-translate-y-1">
            Access Dashboard
        </a>
        {% else %}
        <a href="/signup" 
           class="w-full sm:w-auto 
                  bg-orange-500 hover:bg-orange-600 
                  dark:bg-orange-600 dark:hover:bg-orange-500
                  text-white font-bold px-10 py-4 rounded-xl 
                  shadow-lg shadow-orange-500/20 dark:shadow-orange-900/40
                  transition-all hover:-translate-y-1">
            Join the Network
        </a>

        <a href="#how-it-works"
           class="font-medium transition-colors
                  text-gray-500 hover:text-orange-500
                  dark:text-gray-400 dark:hover:text-orange-400">
            Learn how it works &rarr;
        </a>
        {% endif %}

    </div>
</div>
</section>

<section class="max-w-7xl mx-auto py-20 px-6">
    <div class="grid md:grid-cols-3 gap-10">
        <div class="group relative p-8 rounded-3xl bg-white dark:bg-brand-card border border-gray-100 dark:border-white/5 shadow-xl shadow-gray-200/50 dark:shadow-none transition-all hover:border-orange-500/50">
            <div class="mb-6 inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-orange-50 dark:bg-orange-500/10 text-orange-500 text-3xl group-hover:scale-110 transition-transform">
                ♻️
            </div>
            <h3 class="text-2xl font-bold mb-4">Reduce Waste</h3>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
                Transform high-quality surplus into meals. Reduce your environmental footprint while optimizing your kitchen's output.
            </p>
        </div>

        <div class="group relative p-8 rounded-3xl bg-white dark:bg-brand-card border border-gray-100 dark:border-white/5 shadow-xl shadow-gray-200/50 dark:shadow-none transition-all hover:border-green-500/50">
            <div class="mb-6 inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-green-50 dark:bg-green-500/10 text-green-500 text-3xl group-hover:scale-110 transition-transform">
                🤝
            </div>
            <h3 class="text-2xl font-bold mb-4">Support Local</h3>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
                Connect directly with community fridges. Your donation stays local, feeding neighbors who need it most.
            </p>
        </div>

        <div class="group relative p-8 rounded-3xl bg-white dark:bg-brand-card border border-gray-100 dark:border-white/5 shadow-xl shadow-gray-200/50 dark:shadow-none transition-all hover:border-blue-500/50">
            <div class="mb-6 inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-50 dark:bg-blue-500/10 text-blue-500 text-3xl group-hover:scale-110 transition-transform">
                ⭐
            </div>
            <h3 class="text-2xl font-bold mb-4">Brand Impact</h3>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
                Gain visibility as a socially conscious business. Earn badges and recognition that resonate with modern diners.
            </p>
        </div>
    </div>
</section>

<section id="how-it-works" class="relative py-24 px-6 overflow-hidden 
                bg-gradient-to-r from-green-100 via-green-100 to-emerald-200
                dark:from-[#1b1730] dark:via-[#2a2545] dark:to-[#1b1730] 
                transition-colors duration-700">
    
    <div class="max-w-6xl mx-auto relative z-10 text-center">
        <h2 class="text-3xl font-black mb-16 tracking-tight text-gray-900 dark:text-white uppercase italic">
            Simple 4-Step Process
        </h2>
        
        <div class="grid md:grid-cols-4 gap-6 relative">
            <div class="p-8 rounded-[2.5rem] bg-white/60 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-xl transition-all hover:-translate-y-2">
                <span class="block text-4xl mb-4">📱</span>
                <span class="block text-xs font-bold text-orange-600 dark:text-orange-400 mb-2 uppercase tracking-widest">Step 01</span>
                <h4 class="font-bold text-gray-900 dark:text-white">Register Profile</h4>
            </div>

            <div class="p-8 rounded-[2.5rem] bg-white/60 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-xl transition-all hover:-translate-y-2">
                <span class="block text-4xl mb-4">🍱</span>
                <span class="block text-xs font-bold text-orange-600 dark:text-orange-400 mb-2 uppercase tracking-widest">Step 02</span>
                <h4 class="font-bold text-gray-900 dark:text-white">Log Surplus</h4>
            </div>

            <div class="p-8 rounded-[2.5rem] bg-white/60 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-xl transition-all hover:-translate-y-2">
                <span class="block text-4xl mb-4">🚗</span>
                <span class="block text-xs font-bold text-orange-600 dark:text-orange-400 mb-2 uppercase tracking-widest">Step 03</span>
                <h4 class="font-bold text-gray-900 dark:text-white">Route Surplus</h4>
            </div>

            <div class="p-8 rounded-[2.5rem] bg-white/60 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-xl transition-all hover:-translate-y-2">
                <span class="block text-4xl mb-4">❤️</span>
                <span class="block text-xs font-bold text-orange-600 dark:text-orange-400 mb-2 uppercase tracking-widest">Step 04</span>
                <h4 class="font-bold text-gray-900 dark:text-white">Direct Impact</h4>
            </div>
        </div>
    </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-12">
<h2 class="text-3xl font-bold flex items-center gap-3">
<span class="relative flex h-3 w-3">
<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
<span class="relative inline-flex italic rounded-full h-3 w-3 bg-red-500"></span>
</span>
Live Fridge Needs
</h2>
<br>
    <div id="fridge-container" class="flex overflow-x-auto gap-4 pb-8 hide-scrollbar scroll-smooth">
        {% for fridge in fridges %}
        <div class="min-w-[300px] md:min-w-[350px] p-6 rounded-3xl bg-white dark:bg-brand-card border border-gray-100 dark:border-white/5 shadow-sm hover:shadow-xl transition-all group">
            <div class="flex justify-between items-start mb-6">
                <div class="bg-orange-500/10 p-3 rounded-2xl text-orange-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                
                {% if fridge.Status == 'empty' %}
                    <span class="px-3 py-1 bg-red-500 text-white text-[10px] font-black rounded-full uppercase tracking-tighter">Urgent Need</span>
                {% elif fridge.Status == 'few' %}
                    <span class="px-3 py-1 bg-orange-500 text-white text-[10px] font-black rounded-full uppercase tracking-tighter">Low Stock</span>
                {% else %}
                    <span class="px-3 py-1 bg-green-500 text-white text-[10px] font-black rounded-full uppercase tracking-tighter">Healthy</span>
                {% endif %}
            </div>
            
            <a href="{{ url_for('personal_fridges', fridge_id=fridge['ID']) }}" class="block group/link">
    <h4 class="font-bold text-xl mb-1 truncate text-gray-900 dark:text-white group-hover/link:text-orange-500 transition-colors">
        {{ fridge.name }}
    </h4>
</a>
            
            <p class="text-xs text-gray-400 mb-6 italic">
    Last update: 
    {% if fridge.Last_updated is string %}  
        {{ fridge.Last_updated }}
    {% else %}
        {{ fridge.Last_updated.strftime('%I:%M %p') }}
    {% endif %}
</p>
        </div>
        {% endfor %}
    </div>
</section>
    

<style>
    /* Custom CSS to hide scrollbar but keep functionality */
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    // Logic for the scroll buttons
    const container = document.getElementById('fridge-container');
    document.getElementById('scroll-right').onclick = () => {
        container.scrollLeft += 350;
    };
    document.getElementById('scroll-left').onclick = () => {
        container.scrollLeft -= 350;
    };
</script>




    {% include "components/footer.html.jinja" %}

</body>
</html>