<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurants Connect - FridgeNet</title>
    <link rel="icon" type="image/png" href="/static/images/logo.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>

    <!-- DARK MODE INIT (IMPORTANT for navbar too) -->
    <script>
        (function () {
            const saved = localStorage.getItem("theme");

            if (saved === "dark") {
                document.documentElement.classList.add("dark");
            } else if (saved === "light") {
                document.documentElement.classList.remove("dark");
            } else {
                const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                document.documentElement.classList.toggle("dark", prefersDark);
            }
        })();
    </script>

    <style>
        html { 
            scroll-behavior: smooth;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .float {
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>

<body class="bg-gray-50 dark:bg-[#1b1730] min-h-screen flex flex-col text-gray-900 dark:text-gray-100 transition-colors">

{% include "components/navbar.html.jinja" %}

<!-- HERO -->
<section class="bg-green-200 dark:bg-gradient-to-r dark:from-[#2a2545] dark:to-[#1e1b2e] py-16 text-center px-6 transition-colors">
    <h1 class="text-4xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        Restaurants Connect
    </h1>
    <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
        Partner with us to reduce food waste and support your community
    </p>
      {% if current_user.is_authenticated %}
    <a href="/restaurant-dashboard" 
       class="bg-green-600 hover:bg-green-700 dark:bg-purple-600 dark:hover:bg-purple-700 text-white font-semibold px-8 py-3 rounded-lg shadow-md transition">
        Dashboard
    </a>
      {% else %}

    <a href="/signup" 
       class="bg-green-600 hover:bg-green-700 dark:bg-purple-600 dark:hover:bg-purple-700 text-white font-semibold px-8 py-3 rounded-lg shadow-md transition">
      Sign Up
    </a>
        {% endif %}
</section>

<!-- BENEFITS -->
<section class="max-w-6xl mx-auto py-12 px-6 grid md:grid-cols-3 gap-8">

    <div class="group bg-white dark:bg-[#2a2545] p-8 rounded-2xl shadow-sm border-t-4 border-t-orange-500 border border-gray-200 dark:border-[#40376E] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">♻️</span>
        </div>
        <h2 class="font-bold text-2xl mb-3 group-hover:text-orange-500 transition-colors">Reduce Waste</h2>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Turn surplus food into meaningful impact instead of throwing it away. Save the planet while helping others.
        </p>
    </div>

    <div class="group bg-white dark:bg-[#2a2545] p-8 rounded-2xl shadow-sm border-t-4 border-t-orange-500 border border-gray-200 dark:border-[#40376E] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">🤝</span>
        </div>
        <h2 class="font-bold text-2xl mb-3 group-hover:text-orange-500 transition-colors">Help Community</h2>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Support local families through community fridges and direct donations. Building a stronger neighborhood together.
        </p>
    </div>

    <div class="group bg-white dark:bg-[#2a2545] p-8 rounded-2xl shadow-sm border-t-4 border-t-orange-500 border border-gray-200 dark:border-[#40376E] hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <span class="text-2xl">⭐</span>
        </div>
        <h2 class="font-bold text-2xl mb-3 group-hover:text-orange-500 transition-colors">Get Recognized</h2>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Showcase your restaurant's social responsibility. Get featured on our platform and attract conscious diners.
        </p>
    </div>

</section>

<!-- HOW IT WORKS -->
<section class="bg-gray-100 dark:bg-[#1e1b2e] py-12 text-center transition-colors">
    <h2 class="text-3xl font-bold mb-8 text-gray-900 dark:text-white">
        How It Works
    </h2>

    <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto px-6 text-gray-700 dark:text-gray-300">

    <a href="/signup" class="group p-4 rounded-lg bg-white dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] hover:bg-gray-50 dark:hover:bg-[#352f54] hover:text-orange-500 transition-colors">
        1️⃣ Login / Sign Up
    </a>

    <div class="group p-4 rounded-lg bg-white dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] transition-colors">
        2️⃣ Submit Food
    </div>

    <a href="/donate" class="group p-4 rounded-lg bg-white dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] hover:bg-gray-50 dark:hover:bg-[#352f54] hover:text-orange-500 transition-colors">
        3️⃣ Pickup / Drop-off
    </a>

    <div class="group p-4 rounded-lg bg-white dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E]  transition-colors">
        4️⃣ Feed the Community
    </div>

</div>
</section>

</body>
</html>