<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="/static/images/logo.png">

    <title>FridgeNet Forgot Password</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            darkMode: 'class'
        }
    </script>

    <!-- Theme Loader -->
    <script>
        (function () {
            const saved = localStorage.getItem("theme");

            if (saved === "dark") {
                document.documentElement.classList.add("dark");
            } else {
                document.documentElement.classList.remove("dark");
            }
        })();
    </script>

    <style>
        html {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body,
        div,
        section,
        nav,
        button,
        input,
        a,
        h1,
        h2,
        h3,
        p {
            transition:
                background-color 0.3s ease,
                color 0.3s ease,
                border-color 0.3s ease,
                box-shadow 0.3s ease;
        }

        .flash-message {
            opacity: 1;
            transform: translateY(0);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .flash-hide {
            opacity: 0;
            transform: translateY(-10px);
        }
    </style>

</head>

<body class="bg-gradient-to-r from-green-100 to-orange-100
             dark:from-[#141225] dark:to-[#1b1730]
             min-h-screen flex flex-col
             text-gray-900 dark:text-gray-100
             transition-colors duration-300">

    {% include "components/navbar.html.jinja" %}

    <!-- Forgot Password Section -->
    <section class="flex-grow flex items-center justify-center px-4 py-16
                    bg-gradient-to-r from-green-50 to-orange-100
                    dark:from-[#1b1730] dark:to-[#7C5EDB]
                    transition-colors duration-300">

        <div class="w-full max-w-md
                    bg-white dark:bg-[#1e1b2e]
                    rounded-2xl shadow-xl p-10
                    border border-green-100 dark:border-[#40376E]">

            <!-- Title -->
            <h1 class="text-4xl font-extrabold text-center
                       text-green-800 dark:text-[#b9a6ff]">

                Forgot Your
                <span class="text-orange-500 dark:text-[#d8b4fe]">
                    Password?
                </span>

            </h1>

            <!-- Subtitle -->
            <p class="text-center text-gray-600 dark:text-gray-300 mt-3">
                Enter your email and we'll send you a secure password reset link.
            </p>

            <!-- FLASHES -->
            {% with messages = get_flashed_messages(with_categories=true) %}
                {% if messages %}
                    <div class="mt-6 space-y-3">

                        {% for category, message in messages %}

                            <div class="flash-message px-4 py-3 rounded-xl text-white text-sm shadow-md
                                {% if 'error' in category %}
                                    bg-red-500 dark:bg-red-700
                                {% else %}
                                    bg-green-600 dark:bg-[#6f52c9]
                                {% endif %}
                            ">
                                {{ message }}
                            </div>

                        {% endfor %}

                    </div>
                {% endif %}
            {% endwith %}

            <!-- FORM -->
            <form method="POST" class="mt-8 space-y-5">

                <input type="hidden"
                       name="csrf_token"
                       value="{{ csrf_token() }}">

                <!-- Email -->
                <div>
                    <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
                        Email Address *
                    </label>

                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="Enter your email"
                        class="w-full border border-gray-300 dark:border-[#40376E]
                               bg-white dark:bg-[#2a2545]
                               text-gray-900 dark:text-white
                               rounded-xl px-4 py-2
                               focus:outline-none focus:ring-2
                               focus:ring-green-500 dark:focus:ring-purple-400"
                    />
                </div>

                <!-- Button -->
                <button
                    type="submit"
                    class="w-full bg-green-600 hover:bg-green-700
                           dark:bg-purple-600 dark:hover:bg-purple-700
                           text-white font-semibold py-2 rounded-xl
                           shadow-md transition">

                    Send Reset Link

                </button>

                <!-- Login Link -->
                <p class="text-center text-sm text-gray-600 dark:text-gray-300 pt-2">

                    Remember your password?

                    <a href="/login"
                       class="text-green-700 dark:text-purple-300
                              font-semibold hover:underline">

                        Back to Login

                    </a>

                </p>

            </form>

        </div>

    </section>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const messages = document.querySelectorAll(".flash-message");

            messages.forEach((msg) => {
                setTimeout(() => {
                    msg.classList.add("flash-hide");

                    setTimeout(() => {
                        msg.remove();
                    }, 600);

                }, 3000);
            });
        });
    </script>

    {% include "components/footer.html.jinja" %}

</body>

</html>