<!DOCTYPE html>
<html>
<head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0" />
 <link rel="icon" type="image/png" href="/static/images/logo.png">
 <script src="https://cdn.tailwindcss.com"></script>
 <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>

  <script>
      (function () {
        const saved = localStorage.getItem("theme");

        if (saved === "dark") {
          document.documentElement.classList.add("dark");
        } else if (saved === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", prefersDark);
        }
      })();


    document.addEventListener("DOMContentLoaded", function () {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    });
  </script>
  
   <style>
    html { scroll-behavior: smooth; transition: background-color 0.3s ease; }
    .star-rating label { color: #d1d5db; transition: color 0.2s ease; font-size: 2.5rem; }
    /* Peer-checked logic for the stars */
    .star-rating input:checked ~ label, 
    .star-rating label:hover, 
    .star-rating label:hover ~ label { color: #fbbf24 !important; }
    .flash-msg { animation: slideIn 0.5s ease-out; pointer-events: auto; }
    @keyframes slideIn { from { transform: translate(-50%, -20px); opacity: 0; } to { transform: translate(-50%, 0); opacity: 1; } }
    .edit-mode-active {
    animation: expandDown 0.3s ease-out forwards;
    border-left: 4px solid #16a34a; /* A green accent to show it's being edited */
}

@keyframes expandDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}
 </style>

</head>

<body class="bg-yellow-50 dark:bg-[#1b1730] text-gray-900 dark:text-gray-100 flex flex-col min-h-screen">
  
  <div id="flash-container" class="fixed top-24 left-1/2 -translate-x-1/2 z-[10000] w-full max-w-md px-4 pointer-events-none">
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        {% for category, message in messages %}
          <div class="flash-msg {{ category }} {% if category == 'review-exists' or 'error' in category %}bg-orange-500{% else %}bg-green-600{% endif %} text-white px-4 py-3 rounded-2xl shadow-xl mb-4 flex items-center gap-3 text-sm md:text-base">
            <span>{{ '⚠️' if category == 'review-exists' or 'error' in category else '✅' }}</span>
            <p class="font-bold">{{ message }}</p>
          </div>
        {% endfor %}
      {% endif %}
    {% endwith %}
  </div>

  {% include "components/navbar.html.jinja" %}
<div id="fav-toast"
     class="fixed top-24 left-1/2 -translate-x-1/2 z-[99999]
     px-4 py-2 rounded-xl text-white font-bold text-sm
     shadow-lg opacity-0 pointer-events-none
     transition-all duration-300">
</div>
  <div class="flex-grow">
    <section class="bg-gradient-to-r from-green-100 to-emerald-50 dark:from-[#2a2545] dark:to-[#1b1730] py-10 md:py-16 px-4 md:px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      
      <div class="text-center md:text-left">
        <h1 class="text-3xl md:text-5xl font-extrabold text-green-800 dark:text-purple-300 mb-2 md:mb-3 leading-tight">
          {{ fridge["Name"] }}
        </h1>
        <p class="text-gray-700 dark:text-purple-100/80 text-base md:text-lg">
          📍 {{ fridge["Address"] }}
        </p>
        <div class="text-yellow-400 text-2xl mt-2">
    {% set full_stars = avg_rating|int %}
    {% set empty_stars = 5 - full_stars %}

    {% for i in range(full_stars) %}
        ★
    {% endfor %}

    {% for i in range(empty_stars) %}
        ☆
    {% endfor %}
</div>

<div class="text-sm text-gray-600 dark:text-gray-300 mt-1">
    {{ avg_rating }} / 5 ({{ total_reviews }} reviews)
</div>
      </div>

<div class="flex flex-col w-full md:w-72 lg:w-96 gap-3">
          
{% set status = (fridge_status['Status'] | default('Unknown')) | lower | trim %}
{% set is_locked = status in ['needs attention', 'out of service'] %}

<!-- Status Badge -->
<div class="w-full">
  {% if status in ["full", "many", "half"] %}
    <div class="w-full bg-green-600 text-white px-6 py-3 rounded-xl font-bold shadow-md text-center">
        🟢 Open & Stocked
    </div>
{% elif status in ["low", "few", "empty"] %}
    <div class="w-full bg-yellow-500 text-white px-6 py-3 rounded-xl font-bold shadow-md text-center">
        🟡 Low Stock
    </div>
{% elif status == "needs attention" %}
    <div class="w-full bg-red-600 text-white px-6 py-3 rounded-xl font-bold shadow-md text-center">
        🔴 Needs Attention — Inventory Locked
    </div>
{% elif status == "out of service" %}
    <div class="w-full bg-gray-600 text-white px-6 py-3 rounded-xl font-bold shadow-md text-center">
        ⚫ Out of Service — Inventory Locked
    </div>
{% else %}
    <div class="w-full bg-slate-500 text-white px-6 py-3 rounded-xl font-bold shadow-md text-center">
        ❓ Unknown Status
    </div>
{% endif %}
</div>

<!-- Action Buttons -->
<div class="flex flex-row items-stretch gap-3 w-full">
  {% if is_locked %}
    <!-- Locked: show disabled Update button with tooltip -->
    <div class="flex-1 relative group">
      <button disabled
        class="w-full bg-gray-400 text-white px-4 py-3 rounded-xl font-bold shadow-md text-center text-sm md:text-base cursor-not-allowed opacity-60">
        🔒 Update
      </button>
      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-gray-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
        Fridge is {{ fridge_status['Status'] }} — changes not allowed
      </div>
    </div>
  {% else %}
    <a href="/update_fridge/{{ fridge['ID'] }}"
       class="flex-1 bg-green-600 hover:bg-green-700 text-white px-4 py-3 rounded-xl font-bold transition shadow-md active:scale-95 text-center text-sm md:text-base flex items-center justify-center whitespace-nowrap">
      Update
    </a>
  {% endif %}

  <a href="/report/{{ fridge['ID'] }}"
     class="flex-1 bg-orange-500 hover:bg-orange-600 text-white px-4 py-3 rounded-xl font-bold transition shadow-md active:scale-95 text-center text-sm md:text-base flex items-center justify-center whitespace-nowrap">
    Report
  </a>

  {% if current_user.is_authenticated %}
 <button id="fav-btn" data-fridge-id="{{ fridge['ID'] }}"
        class="aspect-square p-3 rounded-xl bg-white dark:bg-gray-800 shadow-md border border-gray-200 dark:border-gray-700 active:scale-90 transition-all flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 overflow-visible">
    <svg id="star-icon" class="h-6 w-6 md:h-5 md:w-5 transition-all duration-300 {% if is_favorited %}fill-yellow-400 stroke-yellow-500 scale-110{% else %}fill-none stroke-gray-400{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="-1 -1 26 26">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l2.1 6.465a1 1 0 00.95.69h6.805c.969 0 1.371 1.24.588 1.81l-5.506 4a1 1 0 00-.364 1.118l2.1 6.465c.3.921-.755 1.688-1.54 1.118l-5.506-4a1 1 0 00-1.176 0l-5.506 4c-.784.57-1.838-.197-1.539-1.118l2.1-6.465a1 1 0 00-.364-1.118l-5.506-4c-.783-.57-.38-1.81.588-1.81h6.805a1 1 0 00.95-.69l2.1-6.465z" />
    </svg>
  </button>
  {% endif %}
    </section>

    <section class="py-12 px-6 max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <img src="{{ fridge['Image'] }}" class="w-full aspect-square rounded-3xl shadow-lg object-cover max-h-[400px]">
        <div class="space-y-3">
          <h2 class="text-2xl font-bold text-green-800 dark:text-purple-300 mb-4">Available Items</h2>
          {% if is_locked %}
  <div class="flex flex-col items-center justify-center p-8 bg-white/50 dark:bg-[#2a2545]/50 border-2 border-dashed border-red-200 dark:border-red-900/40 rounded-2xl text-center">
    <span class="text-4xl mb-2">🔒</span>
    <p class="text-red-600 dark:text-red-400 font-bold">Inventory Hidden</p>
    <p class="text-xs text-gray-400 dark:text-purple-300/40 mt-1">This fridge is {{ fridge_status['Status'] }} — inventory is not available.</p>
  </div>
{% else %}
  <ul class="grid gap-2">
    {% for item in items %}
      <li class="flex items-center justify-between bg-white dark:bg-[#2a2545] p-2 pr-4 rounded-xl shadow-sm border dark:border-[#40376E]">
        <div class="flex items-center space-x-3">
          <img src="{{ item['Image'] | default('/static/images/default-food.png') }}" class="w-10 h-10 rounded-lg object-cover">
          <p class="font-medium">{{ item['Name'] }}</p>
        </div>
        <span class="text-xs font-bold px-2 py-1 bg-green-100 dark:bg-purple-900/40 rounded-md">{{ item['Quantity'] }} left</span>
      </li>
    {% else %}
      <li class="flex flex-col items-center justify-center p-8 bg-white/50 dark:bg-[#2a2545]/50 border-2 border-dashed border-gray-200 dark:border-[#40376E] rounded-2xl text-center">
        <span class="text-4xl mb-2 grayscale opacity-60">🥘</span>
        <p class="text-gray-500 dark:text-purple-200/60 font-medium">No items currently available.</p>
        <p class="text-xs text-gray-400 dark:text-purple-300/40">Check back later or help by donating!</p>
      </li>
    {% endfor %}
  </ul>
{% endif %}
        </div>
      </div>

      <div class="mt-12 md:mt-20 border-t border-gray-200 dark:border-[#40376E] pt-8 md:pt-12">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 md:mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-green-800 dark:text-purple-300">Community Reviews</h2>
        
        <div class="flex gap-2 w-full sm:w-auto"> 
            {% if reviews|length > 3 %}
                <button id="see-more-btn" class="flex-1 sm:flex-none bg-white dark:bg-[#2a2545] text-green-700 dark:text-purple-300 border border-green-600 dark:border-purple-500 px-4 py-2 rounded-xl font-bold hover:bg-green-50 transition text-xs md:text-sm">
                    See All ({{ reviews|length }})
                </button>
            {% endif %}

            {% if current_user.is_authenticated %}
                <button id="open-review-btn" class="flex-1 sm:flex-none bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-xl font-bold transition shadow-lg text-xs md:text-sm">
                    + Add Review
                </button>
            {% else %}
                <a href="/login" class="flex-1 sm:flex-none bg-gray-200 hover:bg-gray-300 dark:bg-[#2a2545] dark:hover:bg-[#40376E] text-gray-700 dark:text-purple-300 px-4 py-2 rounded-xl font-bold transition shadow-md text-xs md:text-sm text-center flex items-center justify-center">
                    Login to Add Review
                </a>
            {% endif %}
        </div>
    </div>

    <div id="reviews-container" class="grid gap-6">
        {% for review in reviews %}
            <div id="review-card-{{ review['ReviewID'] }}" 
                 data-user-id="{{ review['UserID'] }}" 
                 class="review-card {% if loop.index > 3 %}hidden{% endif %} bg-white dark:bg-[#2a2545] rounded-xl md:rounded-2xl shadow-md p-4 md:p-6 border dark:border-[#40376E] space-y-4">
                
                <div class="flex justify-between items-start">
                    <div>
                        <p class="font-bold text-base md:text-lg text-green-700 dark:text-purple-300 mb-0.5">{{ review["user_name"] }}</p>
                        
                        {% if review["Formatted_Timestamp"] %}
                        <p class="text-[11px] md:text-xs text-gray-400 dark:text-purple-300/60 font-medium mb-1">
                            🕒 {{ review["Formatted_Timestamp"] }}
                        </p>
                        {% endif %}

                        <div class="flex text-yellow-400 text-sm mt-1">
                            {% for _ in range(review["Rating"] | int) %}★{% endfor %}
                            <span class="ml-2 text-xs text-gray-400">({{ review["Rating"] }}/5)</span>
                        </div>
                    </div>

                    {% if current_user.is_authenticated and current_user.id == review['UserID'] %}
                        <div class="flex items-center gap-3">
                            <button onclick="openEditPopup('{{ review['ReviewID'] }}', '{{ review['Rating'] }}', `{{ review['Comment'] | escape }}`)" 
                                    class="text-xs font-bold text-blue-600 dark:text-blue-400 hover:underline">
                                Edit
                            </button>
                            <span class="text-gray-300 dark:text-gray-600 text-xs">|</span>
                            <form method="POST" action="/review/{{ review['ReviewID'] }}/delete" onsubmit="return confirm('Are you sure you want to delete this review and all its replies? This action cannot be undone.');" class="inline">
                                <button type="submit" class="text-xs font-bold text-red-600 dark:text-red-400 hover:underline">
                                    Delete
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>

                <p id="comment-text-{{ review['ReviewID'] }}" class="text-sm md:text-base text-gray-700 dark:text-gray-200 leading-relaxed">{{ review["Comment"] }}</p>

                <div class="flex items-center gap-4 pt-2 border-t border-gray-100 dark:border-white/5">
    {% if current_user.is_authenticated %}
        {% if current_user.id != review['UserID'] or review['replies']|length > 0 %}
            <button type="button" 
                    onclick="toggleReplyForm('reply-form-{{ review['ReviewID'] }}')"
                    class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-wider text-green-600 dark:text-purple-400 hover:text-green-700 dark:hover:text-white transition-colors group">
                <svg class="w-4 h-4 transform group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                </svg>
                Reply
            </button>
        {% endif %}
    {% endif %}
</div>

                <div id="reply-form-{{ review['ReviewID'] }}" class="hidden mt-4 pl-4 border-l-2 border-gray-200 dark:border-gray-700/80">
                    <form method="POST" action="{{ url_for('reply_to_review', fridge_id=fridge['ID'], review_id=review['ReviewID']) }}" class="space-y-3">
                        <div class="space-y-1">
                            <label class="ml-1 block text-xs font-black uppercase tracking-widest text-gray-400 dark:text-gray-500">Your Reply</label>
                            <textarea name="reply_content" rows="3" required
                                placeholder="Write a public reply..." 
                                class="w-full text-sm p-3.5 rounded-2xl border border-gray-200 dark:border-gray-700/80
                                       bg-white/50 dark:bg-[#2a2545]/50 text-gray-950 dark:text-white font-medium
                                       focus:outline-none focus:ring-2 focus:ring-green-400 dark:focus:ring-[#8C65DB] focus:border-transparent transition-all"></textarea>
                        </div>
                        
                        <div class="flex justify-end gap-2 text-xs">
                            <button type="button" onclick="toggleReplyForm('reply-form-{{ review['ReviewID'] }}')"
                                    class="px-4 py-2 rounded-xl font-black text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors uppercase tracking-wider">
                                Cancel
                            </button>
                            <button type="submit" 
                                    class="px-5 py-2 rounded-xl font-black text-white bg-gradient-to-r from-green-600 to-emerald-500 dark:from-purple-600 dark:to-indigo-600 hover:scale-[1.03] active:scale-95 shadow-md transition-all uppercase tracking-wider">
                                Submit
                            </button>
                        </div>
                    </form>
                </div>

                {% if review['replies'] %}
                    <div class="pl-6 space-y-4 pt-2 border-l-2 border-gray-100 dark:border-white/5">
                        {% for reply in review['replies'] %}
                            <div class="flex gap-3 items-start text-xs">
                                <div class="w-7 h-7 rounded-lg bg-green-100 dark:bg-green-900/20 flex items-center justify-center text-green-700 dark:text-green-400 font-black shrink-0">
                                    {{ reply['user_name'][0] | upper }}
                                </div>
                                <div class="space-y-1">
                                    <div class="flex items-center gap-2">
                                        <span class="font-black text-gray-900 dark:text-white">{{ reply['user_name'] }}</span>
                                        <span class="text-[10px] text-gray-400 dark:text-gray-500 font-medium">{{ reply['Formatted_Timestamp'] or 'Just now' }}</span>
                                    </div>
                                    <p class="text-gray-600 dark:text-gray-300 font-medium leading-relaxed">
                                        {{ reply['ReplyContent'] }}
                                    </p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        {% else %}
            <div class="text-center py-10 bg-white/30 dark:bg-[#2a2545]/30 rounded-2xl border-2 border-dotted border-gray-200 dark:border-[#40376E]">
                <span class="text-4xl mb-3 block">💬</span>
                <p class="text-gray-600 dark:text-purple-200 font-semibold">No reviews yet.</p>
                <p class="text-sm text-gray-400 dark:text-purple-300/40">Be the first to share your experience!</p>
            </div>
        {% endfor %}
    </div>
</div>

<div id="review-popup" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-end sm:items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-[9999]">
  <div class="bg-white dark:bg-[#1b1730] p-6 md:p-8 rounded-t-3xl sm:rounded-3xl shadow-2xl border dark:border-[#403760] w-full max-w-md relative">
    <button id="close-popup" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl md:text-2xl">✕</button>
    <h2 class="text-xl md:text-2xl font-bold text-green-800 dark:text-purple-100 mb-2">Share Your Feedback</h2>
    
    <form method="POST" action="{{ url_for('add_review', fridge_id=fridge['ID']) }}">
      <div class="star-rating flex flex-row-reverse justify-center gap-1 md:gap-2 mb-6 mt-4">
        {% for i in range(5, 0, -1) %}
        <input type="radio" id="star{{i}}" name="Rating" value="{{i}}" class="hidden peer" required />
        <label for="star{{i}}" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition-colors text-2xl">★</label>
        {% endfor %}
      </div>
      
      <textarea name="Comment" rows="4" required placeholder="Tell others about the stock..." class="w-full rounded-xl border border-green-200 dark:border-[#40376E] bg-white dark:bg-[#2a2545] text-gray-900 dark:text-gray-100 px-4 py-3 mb-6 focus:ring-2 ring-green-500 outline-none text-sm"></textarea>
      
      <button type="submit" class="w-full py-3 md:py-4 bg-green-600 hover:bg-green-700 text-white rounded-2xl font-bold shadow-lg transform transition active:scale-95 text-sm md:text-base">Submit Review</button>
    </form>
  </div>
</div>

<div id="edit-popup" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-end sm:items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-[9999]">
  <div class="bg-white dark:bg-[#1b1730] p-6 md:p-8 rounded-t-3xl sm:rounded-3xl shadow-2xl border dark:border-[#403760] w-full max-w-md relative">
    <button id="close-edit-popup" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl md:text-2xl">✕</button>
    <h2 class="text-xl md:text-2xl font-bold text-blue-800 dark:text-blue-300 mb-2">Edit Your Feedback</h2>
    
    <form id="edit-form" method="POST" action="">       
      <div class="star-rating flex flex-row-reverse justify-center gap-1 md:gap-2 mb-6 mt-4">
        {% for i in range(5, 0, -1) %}
        <input type="radio" id="edit-star{{i}}" name="Rating" value="{{i}}" class="hidden peer" required />
        <label for="edit-star{{i}}" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition-colors text-2xl">★</label>
        {% endfor %}
      </div>
      
      <textarea id="edit-comment" name="Comment" rows="4" required class="w-full rounded-xl border border-blue-200 dark:border-[#40376E] bg-white dark:bg-[#2a2545] text-gray-900 dark:text-gray-100 px-4 py-3 mb-6 focus:ring-2 ring-blue-500 outline-none text-sm"></textarea>
      
      <button type="submit" class="w-full py-3 md:py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-bold shadow-lg transform transition active:scale-95 text-sm md:text-base">Save Changes</button>
    </form>
  </div>

</div>
<script>
function fireConfetti() {
  if (typeof confetti === 'function') {
    confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, colors: ['#16a34a', '#fbbf24', '#f97316'] });
  }
}

function hideMessage(element, delay) {
  setTimeout(() => {
    element.style.opacity = '0';
    element.style.transform = 'translateY(-20px)';
    setTimeout(() => element.remove(), 500);
  }, delay);
}

function showManualFlash(message, category) {
  const container = document.getElementById('flash-container') || document.body;
  const msgDiv = document.createElement('div');
  msgDiv.className = `flash-msg ${category} bg-orange-500 text-white px-6 py-4 rounded-2xl shadow-xl mb-4 flex items-center gap-3 transition-all duration-500`;
  msgDiv.innerHTML = `<span>⚠️</span><p class="font-bold">${message}</p>`;
  container.appendChild(msgDiv);
  hideMessage(msgDiv, 4000);
}

function openEditPopup(reviewId, currentRating, currentComment) {
  const editPopup = document.getElementById('edit-popup');
  const editForm = document.getElementById('edit-form');
  const editComment = document.getElementById('edit-comment');
  if (!editPopup || !editForm) return;
  editForm.action = `/review/${reviewId}/edit`;
  if (editComment) editComment.value = currentComment;
  for (let i = 1; i <= 5; i++) {
    const star = document.getElementById(`edit-star${i}`);
    if (star) star.checked = false;
  }
  const targetStar = document.getElementById(`edit-star${currentRating}`);
  if (targetStar) targetStar.checked = true;
  editPopup.classList.remove('pointer-events-none', 'opacity-0');
}

function toggleReplyForm(formId) {
  const targetForm = document.getElementById(formId);
  if (targetForm) targetForm.classList.toggle('hidden');
}

const Toast = (() => {
  return {
    show({ message, type = "success", duration = 2000 }) {
      let toast = document.getElementById("fav-toast");
      if (!toast) {
        toast = document.createElement("div");
        toast.id = "fav-toast";
        document.body.appendChild(toast);
      }
      toast.textContent = message;
      toast.className = `fixed top-24 left-1/2 -translate-x-1/2 z-[99999] px-4 py-2 rounded-xl text-white font-bold text-sm shadow-lg transition-all duration-300 ${type === "success" ? "bg-green-600" : "bg-red-600"}`;
      toast.style.opacity = "1";
      setTimeout(() => { toast.style.opacity = "0"; }, duration);
    }
  };
})();

document.addEventListener("DOMContentLoaded", () => {
  const openReviewBtn = document.getElementById('open-review-btn');
  const closeReviewBtn = document.getElementById('close-popup');
  const reviewPopup = document.getElementById('review-popup');
  const closeEditBtn = document.getElementById('close-edit-popup');
  const editPopup = document.getElementById('edit-popup');
  const seeMoreBtn = document.getElementById('see-more-btn');
  const allReviewCards = document.querySelectorAll('.review-card');
  const favBtn = document.getElementById("fav-btn");
  const favIcon = document.getElementById("star-icon");
  const currentUserId = "{{ current_user.id if current_user.is_authenticated else 'null' }}";

  /* --- REVIEW MODAL --- */
  if (openReviewBtn && reviewPopup) {
    openReviewBtn.addEventListener('click', () => {
      if (currentUserId !== 'null') {
        const existingReview = document.querySelector(`[data-user-id="${currentUserId}"]`);
        if (existingReview) {
          showManualFlash("You've already reviewed this fridge!", "review-exists");
          existingReview.scrollIntoView({ behavior: 'smooth', block: 'center' });
          existingReview.classList.add('ring-4', 'ring-orange-500');
          setTimeout(() => existingReview.classList.remove('ring-4', 'ring-orange-500'), 2000);
          return;
        }
      }
      reviewPopup.classList.remove('opacity-0', 'pointer-events-none');
    });
  }

  if (closeReviewBtn && reviewPopup) {
    closeReviewBtn.addEventListener('click', () => reviewPopup.classList.add('opacity-0', 'pointer-events-none'));
  }

  if (reviewPopup) {
    reviewPopup.addEventListener('click', (e) => {
      if (e.target === reviewPopup) reviewPopup.classList.add('opacity-0', 'pointer-events-none');
    });
  }

  /* --- EDIT MODAL --- */
  if (closeEditBtn && editPopup) {
    closeEditBtn.addEventListener('click', () => editPopup.classList.add('opacity-0', 'pointer-events-none'));
  }

  /* --- SEE MORE --- */
  if (seeMoreBtn) {
    seeMoreBtn.addEventListener('click', () => {
      const isShowingAll = seeMoreBtn.getAttribute('data-state') === 'open';
      allReviewCards.forEach((card, index) => {
        if (index >= 3) {
          if (isShowingAll) {
            card.classList.add('hidden');
          } else {
            card.classList.remove('hidden');
            card.animate([{ opacity: 0, transform: 'translateY(10px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 300 });
          }
        }
      });
      if (isShowingAll) {
        seeMoreBtn.innerText = `See All (${allReviewCards.length})`;
        seeMoreBtn.setAttribute('data-state', 'closed');
        document.querySelector('h2.text-3xl')?.scrollIntoView({ behavior: 'smooth' });
      } else {
        seeMoreBtn.innerText = 'Show Less';
        seeMoreBtn.setAttribute('data-state', 'open');
      }
    });
  }

  /* --- FAVORITES --- */
  if (favBtn && favIcon) {
    favBtn.addEventListener("click", async () => {
      favBtn.disabled = true;
      const currentFridgeId = favBtn.dataset.fridgeId;
      try {
        const res = await fetch("/toggle-favorite", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ fridge_id: currentFridgeId })
        });
        const data = await res.json();
        if (data.success) {
          if (data.action === "added") {
            favIcon.classList.add("fill-yellow-400", "stroke-yellow-500", "scale-110");
            favIcon.classList.remove("fill-none", "stroke-gray-400");
            fireConfetti();
            Toast.show({ message: "Saved to favorites ⭐" });
          } else {
            favIcon.classList.remove("fill-yellow-400", "stroke-yellow-500", "scale-110");
            favIcon.classList.add("fill-none", "stroke-gray-400");
            Toast.show({ message: "Removed from favorites", type: "error" });
          }
          if (window.BroadcastChannel) {
            new BroadcastChannel('favorites_sync').postMessage({ action: data.action, fridge_id: parseInt(currentFridgeId) });
          }
        }
      } catch (err) {
        console.error("Toggle favorite failed:", err);
        Toast.show({ message: "Something went wrong", type: "error" });
      } finally {
        favBtn.disabled = false;
      }
    });
  }

  if (window.BroadcastChannel) {
    const syncChannel = new BroadcastChannel('favorites_sync');
    syncChannel.onmessage = (event) => {
      const data = event.data;
      if (favBtn && parseInt(favBtn.dataset.fridgeId) === parseInt(data.fridge_id) && favIcon) {
        if (data.action === "added") {
          favIcon.classList.add("fill-yellow-400", "stroke-yellow-500", "scale-110");
          favIcon.classList.remove("fill-none", "stroke-gray-400");
        } else {
          favIcon.classList.remove("fill-yellow-400", "stroke-yellow-500", "scale-110");
          favIcon.classList.add("fill-none", "stroke-gray-400");
        }
      }
    };
  }

  /* --- FLASH MESSAGES --- */
  document.querySelectorAll('.flash-message, .flash-msg').forEach(msg => {
    const text = msg.textContent.toLowerCase();
    const delay = (text.includes('exists') || text.includes('not found') || text.includes('unauthorized')) ? 4000 : 6000;
    hideMessage(msg, delay);
    if (text.includes('successfully') || text.includes('updated') || msg.classList.contains('success')) fireConfetti();
  });
});
</script>
</body>
</html>