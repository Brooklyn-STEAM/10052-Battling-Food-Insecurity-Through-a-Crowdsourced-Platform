<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/static/images/logo.png">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = { darkMode: 'class' }
  </script>

  <script>
      (function () {
        const saved = localStorage.getItem("theme");

        if (saved === "dark") {
          document.documentElement.classList.add("dark");
        } elif(saved === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", prefersDark);
        }
      })();
  </script>

  <style>
    html {
      scroll-behavior: smooth;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    body,
    div,
    p,
    h1,
    h2,
    span {
      transition: background-color 0.3s ease, color 0.3s ease;
    }
  </style>
</head>

<body class="bg-yellow-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
  {% include "components/navbar.html.jinja" %}

  <div class="min-h-screen bg-yellow-50 dark:bg-gray-900">

    <!-- HEADER -->
    <section class="bg-gradient-to-r from-green-100 to-emerald-50 
                  dark:from-gray-800 dark:to-gray-900 py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-green-800 dark:text-green-400 mb-3">
              {{ fridge["Name"] }}
            </h1>
            <p class="text-gray-700 dark:text-gray-300 text-lg">
              📍 {{ fridge["Address"] }}
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            {% set status = fridge_status['Status'] | lower | trim %}

            {% if status in ["full", "many", "half"] %}
            <span class="bg-green-600 text-white px-5 py-3 rounded-xl font-semibold text-center shadow-md">
              🟢 Open & Stocked
            </span>

            {% elif status in ["low", "few"] %}
            <span class="bg-yellow-500 text-white px-5 py-3 rounded-xl font-semibold text-center shadow-md">
              🟡 Low Stock
            </span>

            {% else %}
            <span class="bg-red-600 text-white px-5 py-3 rounded-xl font-semibold text-center shadow-md">
              🔴 Closed / Needs Attention
            </span>
            {% endif %}



            <a href="/update_fridge/{{ fridge['ID'] }}"
              class="bg-green-600 hover:bg-green-700 text-white px-5 py-3 rounded-xl text-center shadow-md font-semibold transition">
              Update Inventory
            </a>


            <a href="/report/{{ fridge['ID'] }}"
              class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-5 py-3 rounded-xl shadow-md transition text-center">
              Report Issue
            </a>
            {% if current_user.is_authenticated %}
              <button id="fav-btn" data-fridge-id="{{ fridge['ID'] }}"
                class="bg-white dark:bg-gray-800 p-3 rounded-xl shadow-md border border-gray-200 dark:border-gray-700 transition transform active:scale-95">

                <svg id="star-icon" class="h-6 w-6 p-transition-all duration-200 fill-none stroke-gray-400 stroke-1.5"
                  xmlns="http://www.w3.org/2000/svg" viewBox="-1 -1 26 26">
                  <path stroke-linecap="round" stroke-linejoin="round" 
                    d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l2.1 6.465a1 1 0 00.95.69h6.805c.969 0 1.371 1.24.588 1.81l-5.506 4a1 1 0 00-.364 1.118l2.1 6.465c.3.921-.755 1.688-1.54 1.118l-5.506-4a1 1 0 00-1.176 0l-5.506 4c-.784.57-1.838-.197-1.539-1.118l2.1-6.465a1 1 0 00-.364-1.118l-5.506-4c-.783-.57-.38-1.81.588-1.81h6.805a1 1 0 00.95-.69l2.1-6.465z" />
                </svg>

              </button>
              {% endif %}
          </div>
        </div>
      </div>
    </section>

    <!-- ITEMS -->
    <section class="py-12 px-6 max-w-6xl mx-auto">

<div class="grid md:grid-cols-2 gap-8 items-start">



<div class="md:sticky md:top-6">

<img src="{{ fridge['Image'] }}" alt="{{ fridge['Name'] }}"

class="w-full max-h-[400px] aspect-square rounded-3xl shadow-lg object-cover max-h-[400px]">

</div>



<div class="space-y-3">

<h2 class="text-2xl font-bold text-green-800 dark:text-green-400 mb-4">Available Items</h2>



<ul id="list" class="grid gap-2">

{% for item in items %}

{% if item['Quantity'] > 0 %}

<li

class="flex items-center justify-between bg-white dark:bg-gray-800 p-2 pr-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">

<div class="flex items-center space-x-3">

<img src="{{ item['Image'] }}" class="w-10 h-10 rounded-lg object-cover flex-shrink-0">

<p class="font-medium text-gray-800 dark:text-gray-200">{{ item['Name'] }}</p>

</div>



<div class="flex items-center">

<span

class="text-xs font-bold px-2 py-1 bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 rounded-md">

{{ item['Quantity'] }} left

</span>

</div>

</li>

{% endif %}

{% else %}

<li

class="p-6 text-center bg-gray-50 dark:bg-gray-800/50 rounded-xl border-2 border-dashed border-gray-200 dark:border-gray-700">

<p class="text-gray-500 italic text-sm">No items currently listed.</p>

</li>

{% endfor %}

</ul>

</div>



</div>  

      <!-- REVIEWS NOW BELOW ITEMS -->
      <div class="space-y-6 mt-12 max-h-[600px] overflow-y-auto">
        <!-- REVIEWS -->
        <div class="space-y-6 mt-12 max-h-[600px] overflow-y-auto">

          <div class="flex justify-between items-center mb-6">
            <h2 class="text-3xl font-bold text-green-800 dark:text-green-400">Community Reviews</h2>

            {% if current_user.is_authenticated %}
            <button id="open-review-btn"
              class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-xl shadow-md text-sm font-semibold transition">
              Add Review
            </button>
            {% endif %}
          </div>

          <div class="space-y-6">
            {% if reviews %}
            {% for review in reviews %}
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-md p-6">
              <div class="flex justify-between items-center mb-2">
                <p class="font-semibold text-green-700 dark:text-green-400">{{ review["user_name"] }}</p>
                <span class="text-sm text-gray-500 dark:text-gray-400">⭐ {{ review["Rating"] }}/5</span>
              </div>
              <p class="text-gray-700 dark:text-gray-300">{{ review["Comment"] }}</p>
              <p class="text-xs text-gray-400">Posted {{ review["Timestamp"].strftime('%b %d, %Y at %I:%M %p') }}</p>
            </div>
            {% endfor %}
            {% else %}
            <div class="bg-green-50 dark:bg-green-900/20 rounded-2xl p-6">
              <p class="text-gray-600 dark:text-gray-400 italic">No reviews yet.</p>
            </div>
            {% endif %}
          </div>

        </div>
    </section>
  </div>

  <!-- POPUP -->
  <div id="review-popup"
    class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-[9999]">
    <div class="bg-white dark:bg-gray-900 p-8 rounded-xl shadow-lg border dark:border-gray-700 w-[420px]">
      <h2 class="text-2xl font-bold text-green-800 dark:text-green-400 mb-6">Add Review</h2>

      <form method="POST" action="/individfridge/{{ fridge['ID'] }}">
        <label class="block text-sm text-green-800 dark:text-green-400 mb-1">Rating</label>
        <select name="Rating"
          class="w-full rounded-lg border border-green-400 dark:border-green-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 mb-4">
          <option value="5">5 - Excellent</option>
          <option value="4">4 - Good</option>
          <option value="3">3 - Average</option>
          <option value="2">2 - Poor</option>
          <option value="1">1 - Very Bad</option>
        </select>

        <label class="block text-sm text-green-800 dark:text-green-400 mb-1">Comment</label>
        <textarea name="Comment" required
          class="w-full rounded-lg border border-green-400 dark:border-green-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 mb-4"></textarea>

        <button type="submit" class="w-full py-3 bg-green-600 hover:bg-green-700 text-white rounded-xl">
          Submit Review
        </button>
      </form>
    </div>
  </div>
  <script>
document.addEventListener("DOMContentLoaded", async () => {

  // ---------- REVIEW POPUP ----------
  const openBtn = document.getElementById('open-review-btn');
  const popup = document.getElementById('review-popup');

  if (openBtn && popup) {
    openBtn.addEventListener('click', () => {
      popup.classList.remove('opacity-0', 'pointer-events-none');
    });

    popup.addEventListener('click', (e) => {
      if (e.target === popup) {
        popup.classList.add('opacity-0', 'pointer-events-none');
      }
    });
  }

  // ---------- FAVORITE BUTTON ----------
  const favBtn = document.getElementById('fav-btn');
  const starIcon = document.getElementById('star-icon'); // ✅ FIXED

  if (!favBtn || !starIcon) return;

  const fridgeId = favBtn.dataset.fridgeId;

  const updateStarUI = (isFavorited) => {
    if (isFavorited) {
      starIcon.classList.add('fill-yellow-400', 'stroke-yellow-500');
      starIcon.classList.remove('fill-none', 'stroke-gray-400');
    } else {
      starIcon.classList.remove('fill-yellow-400', 'stroke-yellow-500');
      starIcon.classList.add('fill-none', 'stroke-gray-400');
    }
  };

  // ---------- INITIAL LOAD ----------
  try {
    const response = await fetch('/get-favorites');
    const favorites = await response.json();

    const isFavorited = favorites.some(f => (f.ID || f.id) == fridgeId);
    updateStarUI(isFavorited);

  } catch (err) {
    console.log("Not logged in or fetch error");
  }

  // ---------- CLICK TOGGLE ----------
  favBtn.addEventListener('click', async () => {
    const res = await fetch('/toggle-favorite', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ fridge_id: fridgeId })
    });

    if (res.ok) {
      // 🔥 Don’t rely on class state — track logically
      const isActive = starIcon.classList.contains('fill-yellow-400');
      updateStarUI(!isActive);
    }
  });

});
</script>
</body>
{% include "components/footer.html.jinja" %}

</html>