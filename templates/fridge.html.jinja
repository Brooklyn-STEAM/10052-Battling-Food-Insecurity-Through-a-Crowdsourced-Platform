<!DOCTYPE html>
<html> 
<head>
 <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
{% include "components/navbar.html.jinja" %}

<div class="min-h-screen bg-white">

  <!-- HEADER / FRIDGE HERO -->
  <section class="bg-gradient-to-r from-green-100 to-emerald-50 py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-extrabold text-green-800 mb-3"> {{ fridge["Name"] }} </h1>
          <p class="text-gray-700 text-lg"> 📍 {{ fridge ["Address"] }} </p>
        </div>

        <!-- STATUS + REPORT -->
        <div class="flex flex-col sm:flex-row gap-4">

          <!-- Dynamic Status Badge -->
          {% set status = fridge['Status'] | lower %}

{% if status == "open" %}
<span class="bg-green-600 text-white px-6 py-3 rounded-xl font-semibold text-center shadow-md">🟢 Open & Stocked</span>

{% elif status == "low" %}
<span class="bg-yellow-500 text-white px-6 py-3 rounded-xl font-semibold text-center shadow-md">🟡 Low Stock</span>

{% else %}
<span class="bg-red-600 text-white px-6 py-3 rounded-xl font-semibold text-center shadow-md">🔴 Closed / Needs Attention</span>
{% endif %}




          <a href="/report"
            class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-3 rounded-xl shadow-md transition text-center">
            Report Issue
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="py-16 px-6 max-w-6xl mx-auto">

  <!-- TWO-COLUMN GRID -->
  <div class="grid md:grid-cols-2 gap-12">

    <!-- IMAGE -->
    <img src="{{ fridge['Image']}}" alt="{{fridge['Name']}}">

    <!-- AVAILABLE ITEMS -->
    <ul class="space-y-4">
      {% for item in Fridge_items %}
      <li class="flex justify-between items-center bg-white p-4 rounded-xl shadow-sm">
        <div class="flex items-center space-x-4">
          <img src="{{ item['Image'] }}" class="w-12 h-12 rounded-lg object-cover">
          <p class="font-semibold text-green-700">{{ item['Name'] }}</p>
        </div>
        <span class="text-sm font-medium text-gray-600">
          {{ item['Quantity'] }} available
        </span>
      </li>
      {% endfor %}
    </ul>

  </div> <!-- END GRID -->


  <!-- REVIEWS NOW BELOW ITEMS -->
  <div class="space-y-6 mt-12 max-h-[600px] overflow-y-auto">

    <div class="flex justify-between items-center mb-6">
      <h2 class="text-3xl font-bold text-green-800">Community Reviews</h2>

      {% if current_user.is_authenticated %}
      <button id="open-popup"
        class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-xl shadow-md text-sm font-semibold transition">
        Add Review
      </button>
      {% endif %}
    </div>

    <div class="space-y-6">
      {% if reviews %}
        {% for review in reviews %}
        <div class="bg-white rounded-2xl shadow-md p-6">
          <div class="flex justify-between items-center mb-2">
            <p class="font-semibold text-green-700">{{ review["user_name"] }}</p>
            <span class="text-sm text-gray-500">⭐ {{ review["Rating"] }}/5</span>
          </div>
          <p class="text-gray-700">{{ review["Comment"] }}</p>
          <p class="text-xs text-gray-400 mt-3">Posted {{ review["Timestamp"] }}</p>
        </div>
        {% endfor %}
      {% else %}
      <div class="bg-green-50 rounded-2xl p-6">
        <p class="text-gray-600 italic">No reviews yet. Be the first to share your experience!</p>
      </div>
      {% endif %}
    </div>

  </div>

</section>

      </div>
    </div>

  </section>

</div>
<!-- REVIEW POPUP -->
<div id="popup"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center
            opacity-0 pointer-events-none transition-opacity duration-300 z-[9999]">

  <div id="popup-content"
       class="relative w-[420px] scale-95 transition-transform duration-300">

    <div class="bg-white p-8 rounded-xl shadow-lg border">

      <h2 class="text-2xl font-bold text-green-800 mb-6">
        Add Review
      </h2>

      <form method="POST" action="/individfridge/{{ fridge['ID'] }}" class="space-y-4">

        <div>
          <label class="block mb-1 text-sm font-medium">Rating</label>
          <input
            type="number"
            name="Rating"
            min="1"
            max="5"
            required
            class="w-full border px-3 py-2 rounded"
          />
        </div>

        <div>
          <label class="block mb-1 text-sm font-medium">Comment</label>
          <textarea
            name="Comment"
            required
            class="w-full border px-3 py-2 rounded"
          ></textarea>
        </div>

        <div class="flex gap-3 pt-2">
          <button
            type="submit"
            class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded">
            Submit Review
          </button>

          <button
            type="submit"
            id="close-popup"
            class="text-gray-600 underline">
            Cancel
          </button>
        </div>

      </form>

    </div>
  </div>
</div>

{% include "components/footer.html.jinja" %}

<script>
const popup = document.getElementById("popup");
const popupContent = document.getElementById("popup-content");
const openBtn = document.getElementById("open-popup");
const closeBtn = document.getElementById("close-popup");

openBtn.addEventListener("click", () => {
  popup.classList.remove("opacity-0", "pointer-events-none");
  popupContent.classList.remove("scale-95");
});

closeBtn.addEventListener("click", () => {
  popup.classList.add("opacity-0", "pointer-events-none");
  popupContent.classList.add("scale-95");
});

// close when clicking background
popup.addEventListener("click", (e) => {
  if (e.target === popup) {
    popup.classList.add("opacity-0", "pointer-events-none");
    popupContent.classList.add("scale-95");
  }
});
</script>
</body>











</html>