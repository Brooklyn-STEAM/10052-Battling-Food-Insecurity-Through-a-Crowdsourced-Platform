   MOBILE VERSION
========================= */

const mobileSteps = [

desktopSteps[0],
desktopSteps[2],
desktopSteps[4],
desktopSteps[6],
desktopSteps[7],
desktopSteps[9],
desktopSteps[17]
];

const steps =
    isMobile ? mobileSteps : desktopSteps;    
    const tour = driver({

    animate: true,

    smoothScroll: false,

    allowClose: true,

    overlayOpacity: 0.55,

    showProgress: true,

    stagePadding: isMobile ? 8 : 12,

    stageRadius: 20,

    nextBtnText: "Next",

    prevBtnText: "Back",

    doneBtnText: "Finish",

    popoverClass: "fridgenet-tour",

    steps,

    onHighlightStarted: (element) => {

        if (!element) return;

        element.classList.add(
            "tutorial-active"
        );

    },

    onDeselected: (element) => {

        if (!element) return;

        element.classList.remove(
            "tutorial-active"
        );

    },

    onDestroyed: () => {

        document.querySelectorAll(
            ".tutorial-active"
        ).forEach(el => {

            el.classList.remove(
                "tutorial-active"
            );

        });

        closeMenu("moneyFridgeMenu");
        closeMenu("foodTypeMenu");
        closeMenu("foodFridgeMenu");

        showTutorialCompleteToast();

    }

});

function showTutorialCompleteToast() {

    const toast =
        document.createElement("div");

    toast.className = `
    fixed bottom-6 left-1/2
    -translate-x-1/2 z-[9999]
    rounded-2xl px-6 py-4
    bg-green-600 dark:bg-purple-600
    text-white font-bold shadow-2xl`;

    toast.innerHTML =
        "🎉 You're ready to support your community!";

    document.body.appendChild(toast);

    setTimeout(() => {

        toast.style.opacity = "0";
        toast.style.transition =
            "opacity 0.4s ease";

        setTimeout(() => {

            toast.remove();

        }, 400);

    }, 3200);

}

    /* =========================
       Auto Start Tutorial
    ========================= */

    if (!localStorage.getItem(
        "fridgenet_donate_tutorial_seen"
    )) {

        setTimeout(() => {

            tour.drive();

        }, 700);

        localStorage.setItem(
            "fridgenet_donate_tutorial_seen",
            "true"
        );

    }

    /* =========================
       Restart Tutorial
    ========================= */

    window.restartDonateTutorial = () => {

        window.scrollTo({
            top: 0,
            behavior: "smooth"
        });

        setTimeout(() => {

            tour.drive();

        }, 450);

    };

});
