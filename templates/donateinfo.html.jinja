<!DOCTYPE html>
<html lang="en" id="htmlRoot">
<head>
    <meta charset="UTF-8">
    <title> FridgeNet - Community Support</title>
    <link rel="icon" type="image/png" href="/static/images/logo.png">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            darkMode: 'class'
        }
    </script>

    <style>
.input {
    width: 100%;
    padding: 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid #374151;

    /* 👇 LIGHT MODE BACKGROUND (light black / gray) */
    background: #eef0f3; /* slightly cooler gray */

    color: #111827;

    outline: none;
    transition: all 0.2s;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);

}

/* DARK MODE */
.dark .input {
    background: #2b3440;
    border-color: #40376E;
    color: white;

    box-shadow: 0 0 0 1px rgba(255,255,255,0.05);
}

        .input:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.2);
        }
    </style>
</head>

<body class="bg-gray-50 dark:bg-gray-900 transition-colors duration-300">

{% include "components/navbar.html.jinja" %}

<div class="max-w-5xl mx-auto px-4 py-10">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white">
                Help People In Need
            </h1>
            <p class="text-gray-600 dark:text-gray-300 mt-2">
                Donate money or food to support local communities.
            </p>
        </div>

        <button onclick="toggleDarkMode()"
            class="px-4 py-2 rounded-xl bg-gray-200 dark:bg-gray-800 text-gray-900 dark:text-white">
            🌙 Theme
        </button>
    </div>

    <!-- GRID -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- 💳 MONEY FORM -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 space-y-5">

            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                Donate Money
            </h2>

            <form method="POST" action="{{ url_for('donate_money') }}" class="space-y-5">

                <!-- AMOUNTS -->
                <div class="grid grid-cols-3 gap-3 text-gray-700 dark:text-gray-300 font-semibold">
                    {% for amount in [10, 25, 50] %}
                    <label class="cursor-pointer">
                        <input type="radio" name="amount" value="{{ amount }}" class="hidden peer">
                        <div class="p-4 text-center rounded-xl border
                            border-gray-200 dark:border-gray-700
                            peer-checked:bg-orange-500 peer-checked:text-white">
                            ${{ amount }}
                        </div>
                    </label>
                    {% endfor %}
                </div>

                <input type="number" name="custom_amount" placeholder="Custom amount" class="input">

                <!-- 🧊 MONEY FRIDGE -->
                <div class="relative">
                    <label class="block font-semibold mb-2 text-gray-700 dark:text-gray-300">
                        Select a Fridge
                    </label>

                    <input type="hidden" name="FridgeID" id="moneyFridgeValue" required>

                    <button type="button" id="moneyFridgeBtn"
                        class="w-full border rounded-lg p-3 flex justify-between items-center bg-white dark:bg-gray-800 dark:text-white">

                        <span id="moneyFridgeText" class="text-gray-500 dark:text-gray-300">
                            Choose a fridge
                        </span>

                        <span>▼</span>
                    </button>

                    <div id="moneyFridgeMenu"
                        class="absolute z-10 w-full bg-white dark:bg-gray-800 border rounded-lg mt-2 shadow-lg max-h-60 overflow-y-auto hidden">

                        {% for fridge in fridges %}
                        <div class="money-item flex items-center gap-3 p-3 cursor-pointer
                            hover:bg-orange-50 dark:hover:bg-gray-700 text-gray-800 dark:text-white"
                            
                            data-id="{{ fridge['ID'] }}"
                            data-name="{{ fridge['Name'] }}"
                            data-image="{{ fridge['Image'] }}">

                            <img src="{{ fridge['Image'] }}"
                                 class="w-8 h-8 rounded-full object-cover border border-gray-300 dark:border-gray-600">

                            <span class="font-medium">
                                {{ fridge['Name'] }}
                            </span>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <button class="w-full bg-orange-600 hover:bg-orange-700 text-white py-3 rounded-xl font-semibold">
                    Donate Now
                </button>
            </form>
        </div>

        <!-- 🍱 FOOD FORM -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 space-y-5">

            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                Schedule Food Drop-Off
            </h2>

            <form method="POST" action="{{ url_for('donate_food') }}" class="space-y-4">

                <input type="text" name="full_name" placeholder="Full Name" class="input">
                <input type="email" name="food_email" placeholder="Email" class="input">
                <input type="date" name="dropoff_date" class="input">
                <input type="number" name="quantity" placeholder="Quantity" class="input">
                <textarea name="notes" placeholder="Notes (optional)" class="input"></textarea>

                <!-- 🧊 FOOD FRIDGE -->
                <div class="relative">
                    <label class="block font-semibold mb-2 text-gray-700 dark:text-gray-300">
                        Select a Fridge
                    </label>

                    <input type="hidden" name="FridgeID" id="foodFridgeValue" required>

                    <button type="button" id="foodFridgeBtn"
                        class="w-full border rounded-lg p-3 flex justify-between items-center bg-white dark:bg-gray-800 dark:text-white">

                        <span id="foodFridgeText" class="text-gray-500 dark:text-gray-300">
                            Choose a fridge
                        </span>

                        <span>▼</span>
                    </button>

                    <div id="foodFridgeMenu"
                        class="absolute z-10 w-full bg-white dark:bg-gray-800 border rounded-lg mt-2 shadow-lg max-h-60 overflow-y-auto hidden">

                        {% for fridge in fridges %}
                        <div class="food-item flex items-center gap-3 p-3 cursor-pointer
                            hover:bg-orange-50 dark:hover:bg-gray-700 text-gray-800 dark:text-white"
                            
                            data-id="{{ fridge['ID'] }}"
                            data-name="{{ fridge['Name'] }}"
                            data-image="{{ fridge['Image'] }}">

                            <img src="{{ fridge['Image'] }}"
                                 class="w-8 h-8 rounded-full object-cover border border-gray-300 dark:border-gray-600">

                            <span class="font-medium">
                                {{ fridge['Name'] }}
                            </span>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <button class="w-full bg-orange-600 hover:bg-orange-700 text-white py-3 rounded-xl font-semibold">
                    Donate Now
                </button>
            </form>
        </div>

    </div>
</div>

<!-- 🌙 DARK MODE -->
<script>
function toggleDarkMode() {
    document.documentElement.classList.toggle("dark");

    localStorage.setItem(
        "theme",
        document.documentElement.classList.contains("dark") ? "dark" : "light"
    );
}

(function () {
    if (localStorage.getItem("theme") === "dark") {
        document.documentElement.classList.add("dark");
    }
})();
</script>

<!-- 🧊 DROPDOWN LOGIC -->
<script>
function setupDropdown(btnId, menuId, itemsClass, inputId, textId) {
    const btn = document.getElementById(btnId);
    const menu = document.getElementById(menuId);
    const input = document.getElementById(inputId);
    const text = document.getElementById(textId);

    btn.addEventListener("click", (e) => {
        e.stopPropagation();
        menu.classList.toggle("hidden");
    });

    document.querySelectorAll("." + itemsClass).forEach(item => {
        item.addEventListener("click", () => {

            const id = item.dataset.id;
            const name = item.dataset.name;
            const image = item.dataset.image;

            input.value = id;

            text.innerHTML = `
                <div class="flex items-center gap-2">
                    <img src="${image}" class="w-6 h-6 rounded-full object-cover">
                    <span class="text-gray-900 dark:text-white">${name}</span>
                </div>
            `;

            menu.classList.add("hidden");
        });
    });

    document.addEventListener("click", () => {
        menu.classList.add("hidden");
    });
}

// INIT
setupDropdown("moneyFridgeBtn", "moneyFridgeMenu", "money-item", "moneyFridgeValue", "moneyFridgeText");
setupDropdown("foodFridgeBtn", "foodFridgeMenu", "food-item", "foodFridgeValue", "foodFridgeText");
</script>

</body>
</html>