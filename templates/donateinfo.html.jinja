<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Donate | Community Food Support</title>
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0/dist/css/select2.min.css" rel="stylesheet" />
   <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0/dist/js/select2.min.js"></script>
   <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body class="bg-gray-50">
{% include "components/navbar.html.jinja" %}
<div class="max-w-7xl mx-auto px-6 py-12">

    <!-- Page Header -->
    <div class="text-center mb-16">
        <h1 class="text-5xl font-extrabold tracking-wide mb-4">
            Help People In Need 
        </h1>
        <p class="text-lg text-gray-600">
            Support families in need by donating money or food.
        </p>
    </div>

    
    <!-- Main Grid -->
    <div class="grid lg:grid-cols-2 gap-16">
        <!-- 💳 MONEY DONATION -->
        <div class="bg-white p-8 rounded-2xl shadow-lg">
            <h2 class="text-3xl font-bold mb-6">Donate Money</h2>
        <form method="POST" action="{{ url_for('donate_money') }}" class="space-y-6">
            <!-- Preset Amounts -->
             <div>
                <label class="block font-semibold mb-3">Select Amount</label>
             <div class="grid grid-cols-3 gap-4">
                {% for amount in [10, 25, 50] %}
<label class="cursor-pointer">
    <input type="radio" name="amount" value="{{ amount }}" class="hidden peer">

    <div class="border rounded-lg p-4 text-center transition peer-checked:shadow-lg peer-checked:border-orange-500 peer-checked:bg-orange-50">
        <span class="text-lg font-semibold">${{ amount }}</span>
    </div>
</label>
{% endfor %}
            </div>
            </div>
    <!-- Custom Amount -->
        <div>
            <label class="block font-semibold mb-2">Or Enter Custom Amount</label>
            <input type="number" name="custom_amount" placeholder="Enter amount" class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-orange-400 outline-none">
        </div>

     <!-- Submit -->
        <button type="submit" action="/thanks" class="w-full bg-orange-600 text-white py-3 rounded-lg text-lg font-semibold hover:bg-green-700 transition"> Donate Now </button>
            </form>
        </div>

            <!-- Drop-off Form -->
            <form method="post" action="/type_donate" class="space-y-5">

                <h3 class="text-xl font-semibold mb-4">Schedule a Drop-Off</h3>

                <div>
                    <label class="block font-semibold mb-2">Full Name</label>
                    <input type="text" name="full_name" required
                           class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-orange-400 outline-none">
                </div>

                <div>
                    <label class="block font-semibold mb-2">Email</label>
                    <input type="email" name="food_email" required
                           class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-orange-400 outline-none">
                </div>

                <div>
                    <label class="block font-semibold mb-2">Preferred Drop-Off Date</label>
                    <input type="date" name="dropoff_date" required
                           class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-orange-400 outline-none">
                </div>

<div class="relative">
    <label class="block font-semibold mb-2">Type of Donation</label>

    <!-- Hidden input for form submission -->
    <input type="hidden" name="item_type" id="selectedItem" required>

    <!-- Dropdown button -->
    <button type="button" id="dropdownButton"
        class="w-full border rounded-lg p-3 flex justify-between items-center bg-white hover:border-orange-400">

        <span id="selectedText" class="text-gray-500">Select donation type</span>
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 9l-7 7-7-7"></path>
        </svg>
    </button>

    <!-- Dropdown menu -->
    <div id="dropdownMenu"
        class="absolute z-10 w-full bg-white border rounded-lg mt-2 shadow-lg max-h-60 overflow-y-auto">

        {% for item in items %}
        <div
            class="flex items-center gap-3 p-3 hover:bg-orange-50 cursor-pointer dropdown-item"
            data-value="{{ item[Image] }}"
            data-name="{{ item[Name] }}">

            <img src="{{ item[Image]}}" class="w-6 h-6">

            <span>{{ items.name }}</span>

        </div>
        {% endfor %}

    </div>
</div>
                <div>
                    <label class="block font-semibold mb-2">Notes (Optional)</label>
                    <textarea name="notes" rows="3"
                              class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-orange-400 outline-none"></textarea>
                </div>

                <button type="submit" 
                        class="w-full bg-orange-600 text-white py-3 rounded-lg text-lg font-semibold hover:bg-green-700 transition">
                    Schedule Drop-Off
                </button>

            </form>

        </div>

    </div>
</div>
<script>
const button = document.getElementById("dropdownButton");
const menu = document.getElementById("dropdownMenu");
const selectedText = document.getElementById("selectedText");
const hiddenInput = document.getElementById("selectedItem");

button.addEventListener("click", () => {
    menu.classList.toggle("hidden");
});

document.querySelectorAll(".dropdown-item").forEach(item => {
    item.addEventListener("click", () => {

        const value = item.dataset.value;
        const name = item.dataset.name;

        hiddenInput.value = value;
        selectedText.textContent = name;

        menu.classList.add("hidden");
    });
});

document.addEventListener("click", (e) => {
    if (!button.contains(e.target) && !menu.contains(e.target)) {
        menu.classList.add("hidden");
    }
});
</script>

</body>
</html>
