<!DOCTYPE html>
<html lang="en" id="htmlRoot">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FridgeNet - Community Support</title>
    <link rel="icon" type="image/png" href="/static/images/logo.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class'
        }
    </script>

    <script>
        (function() {
            const saved = localStorage.getItem("theme");
            if (saved === "dark") document.documentElement.classList.add("dark");
            else if (saved === "light") document.documentElement.classList.remove("dark");
            else {
                const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                document.documentElement.classList.toggle("dark", prefersDark);
            }
        })();
    </script>

    <style>
        .input {
    width: 100%;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    transition: 0.25s;
    font-size: 15px;
}

        .input:focus {
    border-color: #22c55e;
    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.15);
    outline: none;
}

        .form-card {
    background: rgba(255,255,255,0.95);
    border: 1px solid #e5e7eb;
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.04);
}

        .dark .form-card {
    background: linear-gradient(135deg, #1e1b2e, #2a2545);
    border: 1px solid #40376E;
}

        .dark .input {
            background: #2a2545;
            border-color: #40376E;
            color: #fff;
        }

        .dropdown {
            background: white;
        }

        .dark .dropdown {
            background: #2a2545;
            border-color: #40376E;
        }

        html {
            scroll-behavior: smooth;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
    </style>
</head>

<body class="bg-[#f7fff9] text-gray-900 dark:bg-[#1b1730] dark:text-gray-100 transition-colors duration-300">

    {% include "components/navbar.html.jinja" %}

    <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-4">
        {% with messages = get_flashed_messages(with_categories=true) %} 
            {% if messages %} 
                {% for category, message in messages %} 
                    {% if category.startswith("donation_") %}
                        <div class="flash-message mb-4 px-4 py-3 rounded-xl text-white text-sm shadow-md {% if category == 'donation_error' %} bg-red-500 dark:bg-red-700 {% else %} bg-green-600 dark:bg-[#6f52c9] {% endif %}">
                            {{ message }}
                        </div>
                    {% endif %} 
                {% endfor %} 
            {% endif %} 
        {% endwith %}
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 lg:py-12">
        
        <div class="rounded-[32px] border border-purple-100 dark:border-[#40376E] bg-[#f7f3ff] dark:bg-[#241f3d] p-8 mb-12 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
            <div class="flex items-center gap-5">
    <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center text-3xl">
        💜
    </div>

    <div class="space-y-2">
       <h2 class="text-3xl font-extrabold text-purple-700 dark:text-purple-300">
            Your Support Matters
        </h2>

       <p class="text-gray-600 dark:text-gray-300 max-w-2xl text-lg leading-relaxed">
            100% of your donations go directly to restocking community fridges.
            Whether you give food or funds, you're helping feed a neighbor today.
        </p>
    </div>
</div>      
           <a href="/donations" 
class="whitespace-nowrap rounded-xl px-6 py-3 font-bold transition-all duration-300
bg-white text-gray-900 border border-gray-200 shadow-sm
hover:shadow-orange-500/20 hover:border-orange-500 hover:-translate-y-0.5 hover:text-orange-600
dark:bg-[#2a2545] dark:text-white dark:border-[#40376E]
dark:hover:border-purple-500 dark:hover:shadow-purple-500/20 dark:hover:text-purple-300">
    Learn How it Works ↓
</a>
        </div>

        <div class="mb-8 lg:mb-12 text-center lg:text-left">
            <h1 class="text-5xl lg:text-6xl font-black tracking-tight leading-tight">Help People In Need</h1>
            <p class="text-gray-500 dark:text-gray-300 mt-4 text-xl">Donate money or food to support local communities.</p>
        </div>
        <div class="relative h-40 mb-8 overflow-hidden rounded-[32px]
bg-gradient-to-r from-green-50 to-green-100
dark:from-[#241f3d] dark:to-[#2d2750]
border border-green-100 dark:border-[#40376E]">

    <div class="absolute inset-0 opacity-20">
        <div class="absolute bottom-0 left-10 text-8xl">🌿</div>
        <div class="absolute bottom-0 right-20 text-8xl">🥕</div>
        <div class="absolute top-6 right-1/3 text-7xl">🥬</div>
    </div>

    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-8xl">
        🧊
    </div>
</div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">

            <div class="form-card rounded-[32px] p-8 shadow-sm">
                <div>
                    <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">Donate Money</h2>
                    <form method="POST" action="{{ url_for('donate_money') }}" id="moneyForm">
                        <input type="hidden" name="final_amount" id="finalAmountValue">
                        <input type="hidden"
                       name="csrf_token"
                       value="{{ csrf_token() }}">
                        <div class="grid grid-cols-3 gap-3 sm:gap-4 font-semibold">
                            {% for amount in [10, 25, 50] %}
                            <label class="cursor-pointer group">
                                <input type="radio" name="amount" value="{{ amount }}" class="hidden peer preset-radio">
                                <div class="py-4 text-lg font-bold text-center rounded-2xl border border-gray-200 dark:border-[#40376E] bg-white dark:bg-[#2a2545] text-gray-700 dark:text-white transition-all duration-200 peer-checked:border-orange-500 peer-checked:bg-orange-50 peer-checked:text-orange-600 dark:peer-checked:bg-[#3a3261] dark:peer-checked:text-orange-300 group-hover:border-gray-300">
                                    ${{ amount }}
                                </div>
                            </label>
                            {% endfor %}
                        </div>

                        <div class="mt-4">
                            <input type="number" name="custom_amount" id="customAmount" placeholder="$ Custom amount" class="input" min="1" max="10000">
                        </div>

                        <div class="mt-6 relative space-y-1.5">
                            <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Target Fridge</label>
                            <input type="hidden" name="money_fridge_id" id="moneyFridgeValue" required>
                            <button type="button" id="moneyFridgeBtn" class="flex w-full items-center justify-between rounded-xl border border-gray-200 dark:border-[#40376E] bg-white dark:bg-[#2a2545] p-4 text-sm shadow-sm dark:text-white">
                                <span id="moneyFridgeText">Choose a fridge</span>
                                <span class="text-xs opacity-50">▼</span>
                            </button>
                            <div id="moneyFridgeMenu" class="dropdown absolute z-30 mt-2 hidden max-h-60 w-full overflow-y-auto rounded-xl border border-gray-200 dark:border-[#40376E] shadow-2xl bg-white dark:bg-[#2a2545]">
                                {% for fridge in fridges %}
                                <div class="money-item border-gray-100 dark:border-gray-700/50 flex cursor-pointer items-center gap-3 border-b p-4 last:border-0 hover:bg-orange-50 dark:hover:bg-[#40376E]" data-id="{{ fridge['ID'] }}" data-name="{{ fridge['Name'] }}">
                                    <img src="{{ fridge['Image'] }}" class="h-10 w-10 rounded-lg object-cover" alt="{{ fridge['Name'] }}">
                                    <span class="text-sm font-bold">{{ fridge['Name'] }}</span>
                                </div>
                                {% endfor %}
                            </div>
                        </div>

                        <button type="submit" class="mt-8 w-full transform rounded-2xl bg-green-600 py-4 font-bold text-white shadow-lg transition-all active:scale-[0.98] hover:bg-orange-600 dark:bg-purple-600 dark:hover:bg-purple-700">
                            Donate Now
                        </button>
                    </form>
                </div>
            </div>

            <div class="form-card rounded-3xl p-5 shadow-xl sm:p-8">
                <h2 class="mb-6 flex items-center gap-2 text-2xl font-bold">Schedule Drop-Off</h2>
                <form method="POST" action="{{ url_for('donate_food') }}" class="space-y-4">
                <input type="hidden"
                       name="csrf_token"
                       value="{{ csrf_token() }}">
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div class="space-y-1">
                            <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Name</label>
                            <input type="text" name="full_name" placeholder="Full Name" class="input" required>
                        </div>
                        <div class="space-y-1">
                            <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Email</label>
                            <input type="email" name="food_email" placeholder="Email" class="input" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div class="space-y-1">
                            <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Dropoff Date</label>
                            <input type="date" name="dropoff_date" id="dropoffDate" class="input" required>
                        </div>
                        <div class="space-y-1">
                            <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Quantity</label>
                            <input type="number" name="quantity" min="1" placeholder="No. of items" class="input" required>
                        </div>
                    </div>

                    <div class="relative space-y-1">
                        <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Type of Food</label>
                        <input type="hidden" name="food_type" id="foodTypeValue" required>
                        <button type="button" id="foodTypeBtn" class="border-gray-200 flex w-full items-center justify-between rounded-xl border bg-white p-4 text-sm shadow-sm transition-colors dark:border-gray-700 dark:bg-[#2a2545] dark:text-white">
                            <span id="foodTypeText">Select category</span>
                            <span class="text-xs opacity-50">▼</span>
                        </button>
                        <div id="foodTypeMenu" class="absolute z-20 mt-2 hidden max-h-60 w-full overflow-y-auto rounded-xl border bg-white shadow-2xl dark:border-gray-700 dark:bg-[#2a2545]">
                            {% for item in food_types %}
                            <div class="food-type-item border-gray-100 dark:border-gray-700/50 cursor-pointer border-b p-4 transition-colors last:border-0 hover:bg-orange-50 dark:hover:bg-[#40376E]" data-id="{{ item['ID'] }}" data-name="{{ item['Name'] }}">
                                <span class="text-sm font-bold">{{ item['Name'] }}</span>
                            </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="relative space-y-1">
                        <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Target Fridge</label>
                        <input type="hidden" name="FridgeID" id="foodFridgeValue" required>
                        <button type="button" id="foodFridgeBtn" class="flex w-full items-center justify-between rounded-xl border border-gray-200 dark:border-[#40376E] bg-white dark:bg-[#2a2545] p-4 text-sm shadow-sm dark:text-white">
                            <span id="foodFridgeText">Choose a location</span>
                            <span class="text-xs opacity-50">▼</span>
                        </button>
                        <div id="foodFridgeMenu" class="dropdown absolute z-30 mt-2 hidden max-h-60 w-full overflow-y-auto rounded-xl border border-gray-200 dark:border-[#40376E] shadow-2xl bg-white dark:bg-[#2a2545]">
                            {% for fridge in fridges %}
                            <div class="food-item border-gray-100 dark:border-gray-700/50 flex cursor-pointer items-center gap-3 border-b p-4 last:border-0 hover:bg-orange-50 dark:hover:bg-[#40376E]" data-id="{{ fridge['ID'] }}" data-name="{{ fridge['Name'] }}">
                                <img src="{{ fridge['Image'] }}" class="h-10 w-10 rounded-lg object-cover" alt="{{ fridge['Name'] }}">
                                <span class="text-sm font-bold">{{ fridge['Name'] }}</span>
                            </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label class="ml-1 block text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Notes</label>
                        <textarea name="notes" rows="2" class="input" placeholder="Any dietary info or specifics?"></textarea>
                    </div>

                    <button type="submit"
class="mt-4 w-full rounded-2xl bg-[#16a34a] py-4 text-lg font-bold text-white shadow-lg transition-all duration-300 hover:scale-[1.01] hover:bg-[#15803d]">Donate Food</button>
                </form>
            </div>
        </div>
    </div>


<div class="max-w-6xl mx-auto px-4 sm:px-6 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-4 overflow-hidden rounded-[32px] border border-green-100 dark:border-[#40376E] bg-white dark:bg-[#241f3d] shadow-sm">
        <div class="p-8 flex gap-4 items-start">
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-2xl">
                👥
            </div>
            <div>
                <h3 class="font-bold text-lg">Support Local Communities</h3>
                <p class="text-gray-500 dark:text-gray-300 text-sm mt-1">
                    Your support stays in your community.
                </p>
            </div>
        </div>

        <div class="p-8 flex gap-4 items-start border-t md:border-t-0 md:border-l border-gray-100 dark:border-[#40376E]">
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-2xl">
                🌱
            </div>
            <div>
                <h3 class="font-bold text-lg">Reduce Food Waste</h3>
                <p class="text-gray-500 dark:text-gray-300 text-sm mt-1">
                    Help good food reach those who need it.
                </p>
            </div>
        </div>

        <div class="p-8 flex gap-4 items-start border-t md:border-t-0 md:border-l border-gray-100 dark:border-[#40376E]">
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-2xl">
                💚
            </div>
            <div>
                <h3 class="font-bold text-lg">Make an Impact</h3>
                <p class="text-gray-500 dark:text-gray-300 text-sm mt-1">
                    Every donation brings hope and nourishment.
                </p>
            </div>
        </div>

        <div class="p-8 flex gap-4 items-start border-t md:border-t-0 md:border-l border-gray-100 dark:border-[#40376E]">
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-2xl">
                🔒
            </div>
            <div>
                <h3 class="font-bold text-lg">Safe & Secure</h3>
                <p class="text-gray-500 dark:text-gray-300 text-sm mt-1">
                    Your information and donations are protected.
                </p>
            </div>
        </div>

    </div>
</div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Dropdown Logic
            function setupDropdown(btnId, menuId, hiddenInputId, textId, itemClass) {
                const btn = document.getElementById(btnId);
                const menu = document.getElementById(menuId);
                const hiddenInput = document.getElementById(hiddenInputId);
                const btnText = document.getElementById(textId);

                if (!btn || !menu) return;

                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    document.querySelectorAll('.dropdown, #foodTypeMenu').forEach(m => {
                        if (m !== menu) m.classList.add('hidden');
                    });
                    menu.classList.toggle('hidden');
                });

                menu.querySelectorAll(itemClass).forEach(item => {
                    item.addEventListener('click', function() {
                        hiddenInput.value = this.getAttribute('data-id');
                        btnText.innerText = this.getAttribute('data-name');
                        menu.classList.add('hidden');
                        btn.classList.add('border-orange-500', 'dark:border-purple-500');
                    });
                });
            }

            setupDropdown('moneyFridgeBtn', 'moneyFridgeMenu', 'moneyFridgeValue', 'moneyFridgeText', '.money-item');
            setupDropdown('foodFridgeBtn', 'foodFridgeMenu', 'foodFridgeValue', 'foodFridgeText', '.food-item');
            setupDropdown('foodTypeBtn', 'foodTypeMenu', 'foodTypeValue', 'foodTypeText', '.food-type-item');

            // Close on outside click
            document.addEventListener('click', () => {
                document.querySelectorAll('.dropdown, #foodTypeMenu').forEach(m => m.classList.add('hidden'));
            });

            // Money Form Amount Logic
            const moneyForm = document.getElementById("moneyForm");
            const customInput = document.getElementById("customAmount");
            const presetRadios = document.querySelectorAll('.preset-radio');
            const finalAmountInput = document.getElementById("finalAmountValue");

            customInput?.addEventListener("input", () => {
                if (customInput.value !== "") {
                    presetRadios.forEach(r => r.checked = false);
                }
            });

            presetRadios.forEach(radio => {
                radio.addEventListener("change", () => {
                    if (radio.checked) customInput.value = "";
                });
            });

            moneyForm?.addEventListener("submit", function(e) {
                const selectedRadio = document.querySelector('.preset-radio:checked');
                const fridgeSelected = document.getElementById("moneyFridgeValue").value;

                let total = selectedRadio ? selectedRadio.value : customInput.value;

                if (!total || total <= 0) {
                    e.preventDefault();
                    alert("Please select or enter a donation amount.");
                    return;
                }

                if (!fridgeSelected) {
                    e.preventDefault();
                    alert("Please select a target fridge.");
                    return;
                }

                finalAmountInput.value = total;

                const btn = this.querySelector("button[type='submit']");
                btn.innerHTML = `<span class="flex items-center justify-center gap-2">
            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            Processing...
        </span>`;
                btn.disabled = true;
            });

            // Date Restriction
            const dateInput = document.getElementById("dropoffDate");
            if (dateInput) {
                dateInput.min = new Date().toISOString().split("T")[0];
            }

            // Auto-hide flash messages
            const flashes = document.querySelectorAll(".flash-message");
            flashes.forEach(flash => {
                setTimeout(() => {
                    flash.style.opacity = "0";
                    flash.style.transition = "opacity 0.5s ease";
                    setTimeout(() => flash.remove(), 500);
                }, 3000);
            });
        });
    </script>
</body>

</html>