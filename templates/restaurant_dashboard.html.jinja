<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <link rel="icon" type="image/png" href="/static/images/logo.png">
   <title>Restaurant Dashboard</title>

   <script src="https://cdn.tailwindcss.com"></script>
   <script>
       tailwind.config = {
           darkMode: 'class'
       }
   </script>
  
   <script>
       (function () {
           const saved = localStorage.getItem("theme");
           if (saved === "dark") {
               document.documentElement.classList.add("dark");
           } else if (saved === "light") {
               document.documentElement.classList.remove("dark");
           } else {
               const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
               document.documentElement.classList.toggle("dark", prefersDark);
           }
       })();
   </script>
</head>

<body class="bg-gray-100 dark:bg-[#0f0c1f] text-gray-900 dark:text-gray-100 transition-colors duration-300">
{% include "components/navbar.html.jinja" %}

<div class="lg:hidden flex items-center justify-between p-4 bg-white dark:bg-[#1b1730] border-b dark:border-[#40376E]">
    <button onclick="toggleSidebar()" class="p-2 rounded-lg bg-gray-100 dark:bg-[#2a2545] text-gray-600 dark:text-gray-200">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
    </button>
    <h2 class="font-bold">Dashboard</h2>
    <div class="w-10"></div> </div>

<div class="flex min-h-screen relative">

   <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 transform -translate-x-full lg:translate-x-0 lg:static transition-transform duration-300 ease-in-out bg-gray-50 dark:bg-[#1b1730] p-6 border-r border-gray-200 dark:border-[#40376E] shadow-xl lg:shadow-sm">
       <button onclick="toggleSidebar()" class="lg:hidden absolute top-4 right-4 p-2 text-gray-400">
           <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
       </button>

       <div class="mb-10 px-4">
           <span class="text-xs font-semibold uppercase tracking-wider text-orange-500">Welcome back</span>
           <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
               {{ current_user.name }} <span class="text-lg">🍽️</span>
           </h2>
       </div>

       <nav class="space-y-2">
           <a href="/restaurant-dashboard" class="flex items-center px-4 py-3 rounded-xl bg-green-600 dark:bg-[#7b2cbf] text-white font-medium transition-all shadow-md shadow-green-200 dark:shadow-none">
               <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
               </svg>
               Dashboard
           </a>

           <div class="pt-8 mt-8 border-t border-gray-200 dark:border-[#40376E]">
               <a href="/logout" class="flex items-center px-4 py-3 rounded-xl text-gray-500 dark:text-purple-300 hover:bg-orange-50 dark:hover:bg-[#2a2545] hover:text-orange-600 transition-colors">
                   <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                   </svg>
                   Logout
               </a>
           </div>
       </nav>
   </aside>

   <div id="sidebar-overlay" onclick="toggleSidebar()" class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden"></div>

   <main class="flex-1 p-4 md:p-8">

       <div class="mb-8">
           <h1 class="text-2xl md:text-3xl font-bold text-gray-800 dark:text-white">
               Welcome back, {{ current_user.name }} 👋
           </h1>
           <p class="text-gray-500 dark:text-purple-300/70">
               Here's your impact today
           </p>
       </div>

       <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
           <div class="bg-white dark:bg-[#2a2545] p-6 rounded-xl shadow border dark:border-[#40376E]">
               <h3 class="text-gray-500 dark:text-purple-300/70 text-sm">Meals Donated</h3>
               <p class="text-3xl font-bold text-blue-600 dark:text-purple-400 mt-2">{{ total_meals }}</p>
           </div>

           <div class="bg-white dark:bg-[#2a2545] p-6 rounded-xl shadow border dark:border-[#40376E]">
               <h3 class="text-gray-500 dark:text-purple-300/70 text-sm">Money Donated</h3>
               <p class="text-3xl font-bold text-green-600 dark:text-green-400 mt-2">$ {{ total_money }}</p>
           </div>

           <div class="bg-white dark:bg-[#2a2545] p-6 rounded-xl shadow border dark:border-[#40376E]">
               <h3 class="text-gray-500 dark:text-purple-300/70 text-sm">Scheduled Pickups</h3>
               <p class="text-3xl font-bold text-orange-500 mt-2">{{ scheduled }}</p>
           </div>
       </div>

       <div class="mt-8 overflow-hidden rounded-[28px] border border-green-100 dark:border-[#40376E] bg-gradient-to-r from-[#eefaf0] to-white dark:from-[#2a2545] dark:to-[#1b1730] shadow-sm">
    <div class="flex flex-col md:flex-row items-center justify-between">
        
        <div class="relative w-full md:w-[38%] h-[220px] overflow-hidden">
            <img 
                src="/static/images/dashbaord.png" 
                alt="Dashboard Illustration"
                class="w-full h-full object-cover"
            >
        </div>

        <div class="flex-1 px-8 py-10">
            <div class="flex items-start gap-5">
                
                

                <div>
                    <h2 class="text-3xl font-black text-gray-900 dark:text-white">
                        Amazing Work!
                    </h2>

                    <p class="mt-3 text-xl text-gray-700 dark:text-purple-100 leading-relaxed">
                        You've helped save
                        <span class="font-black text-green-600 dark:text-green-400">
                            {{ total_meals }} meals
                        </span>
                        from going to waste.
                    </p>

                    <p class="mt-2 text-gray-500 dark:text-purple-300/70 text-lg">
                        Thank you for making a difference in your community!
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

       <div class="mt-8 bg-white dark:bg-[#1b1730] p-4 md:p-6 rounded-xl shadow-sm border border-gray-100 dark:border-[#40376E]">
           <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
               <h2 class="text-xl font-bold text-gray-800 dark:text-white flex items-center gap-2">
                   <span class="text-orange-500 text-3xl">📅</span> Upcoming Pickups
               </h2>
               <a href="/donate" class="inline-flex justify-center items-center px-4 py-2.5 bg-green-600 dark:bg-[#7b2cbf] hover:bg-green-700 dark:hover:bg-[#5a189a] text-white text-sm font-semibold rounded-lg transition-transform active:scale-95 shadow-md">
                   <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                   </svg>
                   Schedule Pickup
               </a>
           </div>

           <ul class="space-y-3">
               {% for donation in scheduled_list %}
            <li onclick="showDonationDetails({{ donation.ID }})"
                class="cursor-pointer p-4 border border-gray-100 dark:border-[#40376E] rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-gray-50/50 dark:bg-[#2a2545]/50 hover:bg-white dark:hover:bg-[#2a2545] transition-all group">

                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-orange-400"></div>
                    <div>
                        <span class="block font-medium text-gray-700 dark:text-gray-200">
                            {{ donation.Dropoff.strftime('%B %d, %Y') }}
                        </span>
                        <span class="text-xs text-gray-400 dark:text-purple-300/50">
                            {{ donation.Quantity }} meals scheduled
                        </span>
                    </div>
                </div>

                <div class="flex items-center justify-between w-full sm:w-auto gap-3 border-t sm:border-none pt-3 sm:pt-0">
                    <span class="text-sm font-semibold text-green-600 dark:text-purple-300 bg-green-50 dark:bg-[#1b1730] px-3 py-1 rounded-full">
                        {{ donation.Dropoff.strftime('%I:%M %p') }}
                    </span>
                    <button onclick="openDeleteModal({{ donation.ID }}); event.stopPropagation();"
                            class="text-red-500 text-xs font-bold hover:underline">
                        Delete
                    </button>
                </div>
            </li>
            {% endfor %}
           </ul>
       </div>

       <div class="mt-12 bg-white dark:bg-[#1b1730] rounded-[28px] border border-gray-200 dark:border-[#40376E] shadow-sm overflow-hidden">

    <div class="flex items-center justify-between px-8 pt-8 pb-6">
        <h2 class="text-3xl font-black text-gray-900 dark:text-white flex items-center gap-3">
            <span class="text-green-600 text-3xl">☑️</span>
            Previous Dropoffs
        </h2>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100 dark:border-[#40376E]">
                    <th class="text-left px-8 py-4 text-gray-500 dark:text-purple-300/60 font-bold">Date</th>
                    <th class="text-left px-8 py-4 text-gray-500 dark:text-purple-300/60 font-bold">Type</th>
                    <th class="text-left px-8 py-4 text-gray-500 dark:text-purple-300/60 font-bold">Items/Meals</th>
                    <th class="text-left px-8 py-4 text-gray-500 dark:text-purple-300/60 font-bold">Location</th>
                    <th class="text-left px-8 py-4 text-gray-500 dark:text-purple-300/60 font-bold">Status</th>
                </tr>
            </thead>

            <tbody>
                {% for donation in previous_list %}
                <tr onclick="showDonationDetails({{ donation.ID }})"
                    class="cursor-pointer border-b border-gray-100 dark:border-[#2a2545] hover:bg-gray-50 dark:hover:bg-[#2a2545]/40 transition">

                    <td class="px-8 py-6 text-gray-700 dark:text-gray-200 font-medium">
                        {{ donation.Dropoff.strftime('%B %d, %Y') }}
                    </td>

                    <td class="px-8 py-6 text-gray-500 dark:text-purple-300/70">
                        Food Donation
                    </td>

                    <td class="px-8 py-6 text-gray-700 dark:text-gray-200">
                        {{ donation.Quantity }} meals
                    </td>

                    <td class="px-8 py-6 text-gray-500 dark:text-purple-300/70">
                        Community Fridge
                    </td>

                    <td class="px-8 py-6">
                        <span class="bg-green-100 dark:bg-green-500/20 text-green-700 dark:text-green-400 font-bold px-4 py-2 rounded-full text-sm">
                            Completed
                        </span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center py-16 text-gray-400 italic">
                        Your donation history will appear here.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="flex justify-end px-8 py-6">
        <a href="#"
           class="flex items-center gap-2 text-green-600 dark:text-green-400 font-bold hover:gap-3 transition-all">
            View all history →
        </a>
    </div>
</div>
   </main>
</div>

<div id="donationModal" class="hidden fixed inset-0 bg-gray-900/60 dark:bg-black/80 backdrop-blur-sm z-[60] flex items-center justify-center p-4">
   <div class="bg-white dark:bg-[#1b1730] rounded-2xl max-w-md w-full max-h-[90vh] overflow-y-auto shadow-2xl border dark:border-[#40376E]">
       <div class="p-6">
           <div class="flex justify-between items-center mb-6">
               <h3 class="text-xl font-bold text-gray-900 dark:text-white">Summary</h3>
               <button onclick="closeDonationModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-white text-2xl">&times;</button>
           </div>
          
           <div id="modalLoading" class="py-10 text-center">
               <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-green-500 dark:border-purple-500 border-t-transparent"></div>
           </div>

           <div id="modalBody" class="hidden space-y-6">
               <div class="flex flex-col sm:flex-row items-center gap-4 p-4 bg-green-50 dark:bg-[#2a2545] rounded-xl border border-green-100 dark:border-[#40376E]">
                   <img id="detItemImg" src="" class="w-20 h-20 sm:w-16 sm:h-16 rounded-lg object-cover bg-white">
                   <div class="text-center sm:text-left">
                       <p class="text-xs font-bold text-green-600 dark:text-purple-400 uppercase tracking-wider">Inventory Added</p>
                       <p class="text-lg font-bold text-gray-800 dark:text-white"><span id="detQty"></span>x <span id="detItemName"></span></p>
                   </div>
               </div>

               <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                   <div class="space-y-1">
                       <p class="text-gray-400 dark:text-purple-300/50 font-medium uppercase text-[10px]">Destination</p>
                       <p id="detFridge" class="font-semibold text-gray-700 dark:text-gray-200"></p>
                   </div>
                   <div class="space-y-1">
                       <p class="text-gray-400 dark:text-purple-300/50 font-medium uppercase text-[10px]">Scheduled Time</p>
                       <p id="detTime" class="font-semibold text-gray-700 dark:text-gray-200"></p>
                   </div>
               </div>

               <div id="detNotesContainer" class="hidden border-t dark:border-[#40376E] pt-4">
                   <p class="text-gray-400 dark:text-purple-300/50 font-medium uppercase text-[10px] mb-1">Notes</p>
                   <p id="detNotes" class="text-sm italic text-gray-600 dark:text-gray-300 bg-gray-50 dark:bg-[#2a2545] p-3 rounded-lg"></p>
               </div>
           </div>
       </div>
       <div class="bg-gray-50 dark:bg-[#2a2545]/50 px-6 py-4 flex justify-end">
           <button onclick="closeDonationModal()" class="w-full sm:w-auto px-6 py-2 bg-gray-200 dark:bg-[#40376E] hover:bg-gray-300 dark:hover:bg-[#5a4fd6] text-gray-700 dark:text-white font-bold rounded-lg transition-colors">Close</button>
       </div>
   </div>
</div>

<div id="deleteModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-[70] p-4">
    <div class="bg-white dark:bg-[#1b1730] p-6 rounded-xl shadow-xl w-full max-w-xs text-center">
        <h2 class="text-lg font-bold mb-2 text-gray-800 dark:text-white">Cancel Donation?</h2>
        <p class="text-sm text-gray-500 mb-6">This action cannot be undone.</p>
        <div class="flex flex-col-reverse sm:flex-row justify-center gap-3">
            <button onclick="closeDeleteModal()" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 rounded-lg font-medium">No, Keep</button>
            <form id="deleteForm" method="POST" class="w-full sm:w-auto">
              
                <input type="hidden"
                name="csrf_token"
                value="{{ csrf_token() }}">
                <button type="submit" class="w-full px-4 py-2 bg-red-600 text-white rounded-lg font-medium">Yes, Delete</button>
            </form>
        </div>
    </div>
</div>

{% include "components/footer.html.jinja" %}

<script>
/* Sidebar Toggle Logic */
function toggleSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebar-overlay");
    sidebar.classList.toggle("-translate-x-full");
    overlay.classList.toggle("hidden");
}

function openDeleteModal(id) {
    const modal = document.getElementById("deleteModal");
    const form = document.getElementById("deleteForm");
    form.action = `/donation/${id}/delete`;
    modal.classList.remove("hidden");
}

function closeDeleteModal() {
    document.getElementById("deleteModal").classList.add("hidden");
}

function showDonationDetails(id) {
   const modal = document.getElementById('donationModal');
   const body = document.getElementById('modalBody');
   const loader = document.getElementById('modalLoading');
  
   modal.classList.remove('hidden');
   body.classList.add('hidden');
   loader.classList.remove('hidden');

   fetch(`/api/donation-details/${id}`)
       .then(res => res.json())
       .then(data => {
           document.getElementById('detItemImg').src = data.ItemImage || '/static/default-food.png';
           document.getElementById('detItemName').innerText = data.ItemName;
           document.getElementById('detQty').innerText = data.Quantity;
           document.getElementById('detFridge').innerText = data.FridgeName;

           if (data.FormattedDate && data.FormattedTime) {
               document.getElementById('detTime').innerText = `${data.FormattedDate} at ${data.FormattedTime}`;
           } else if (data.Dropoff) {
               const dateObj = new Date(data.Dropoff);
               const dateString = dateObj.toLocaleDateString(undefined, { month: 'long', day: 'numeric', year: 'numeric' });
               const timeString = dateObj.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
               document.getElementById('detTime').innerText = `${dateString} at ${timeString}`;
           }
          
           const notesContainer = document.getElementById('detNotesContainer');
           if (data.Notes && data.Notes.trim() !== "") {
               document.getElementById('detNotes').innerText = data.Notes;
               notesContainer.classList.remove('hidden');
           } else {
               notesContainer.classList.add('hidden');
           }

           loader.classList.add('hidden');
           body.classList.remove('hidden');
       })
       .catch(err => {
           console.error("Error:", err);
           closeDonationModal();
       });
}

function closeDonationModal() {
   document.getElementById('donationModal').classList.add('hidden');
}

window.addEventListener('keydown', (e) => {
   if (e.key === 'Escape') {
       closeDonationModal();
       closeDeleteModal();
   }
});
</script>
</body>
</html>