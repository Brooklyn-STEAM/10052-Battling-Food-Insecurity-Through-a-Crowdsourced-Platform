<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurant Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Smooth transition for the sidebar */
        #sidebar { transition: transform 0.3s ease-in-out; }
    </style>
</head>

<body class="bg-gray-100 overflow-x-hidden">
    {% include "components/navbar.html.jinja" %}

    <div class="lg:hidden bg-white border-b p-4 flex justify-between items-center sticky top-0 z-30">
        <h2 class="font-bold text-gray-900">Dashboard</h2>
        <button onclick="toggleSidebar()" class="p-2 text-gray-600 hover:bg-gray-100 rounded-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>

    <div class="flex min-h-screen relative">
        <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-64 bg-gray-50 text-gray-800 p-6 border-r border-gray-200 shadow-sm transform -translate-x-full lg:translate-x-0 lg:static lg:inset-0">
            <div class="mb-10 px-4 flex justify-between items-center">
                <div>
                    <span class="text-xs font-semibold uppercase tracking-wider text-orange-500">Welcome back</span>
                    <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2">
                        {{ current_user.name }} <span class="text-lg">🍽️</span>
                    </h2>
                </div>
                <button onclick="toggleSidebar()" class="lg:hidden text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <nav class="space-y-2">
                <a href="/restaurant-dashboard" class="flex items-center px-4 py-3 rounded-xl bg-green-600 text-white font-medium transition-all shadow-md shadow-green-200">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                    </svg>
                    Dashboard
                </a>

                <div class="pt-8 mt-8 border-t border-gray-200">
                    <a href="/logout" class="flex items-center px-4 py-3 rounded-xl text-gray-500 hover:bg-orange-50 hover:text-orange-600 transition-colors">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                        </svg>
                        Logout
                    </a>
                </div>
            </nav>
        </aside>

        <main class="flex-1 p-4 md:p-8 w-full">
            <div class="mb-8">
                <h1 class="text-2xl md:text-3xl font-bold text-gray-800">
                    Welcome back, {{ current_user.name }} 👋
                </h1>
                <p class="text-gray-500">Here's your impact today</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
                <div class="bg-white p-6 rounded-xl shadow border border-gray-50">
                    <h3 class="text-gray-500 text-sm">Meals Donated</h3>
                    <p class="text-3xl font-bold text-blue-600 mt-2">{{ total_meals }}</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow border border-gray-50">
                    <h3 class="text-gray-500 text-sm">Money Donated</h3>
                    <p class="text-3xl font-bold text-green-600 mt-2">$ {{ total_money }}</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow border border-gray-50 sm:col-span-2 lg:col-span-1">
                    <h3 class="text-gray-500 text-sm">Scheduled Pickups</h3>
                    <p class="text-3xl font-bold text-orange-500 mt-2">{{ scheduled }}</p>
                </div>
            </div>

            <div class="mt-8 bg-white text-orange-500 p-6 rounded-xl shadow border border-orange-50">
                <h2 class="text-xl font-semibold">🎉 Amazing Work!</h2>
                <p class="mt-2 text-gray-700">
                    You've helped save <strong class="text-orange-600">{{ total_meals }}</strong> meals from going to waste.
                </p>
            </div>

            <div class="mt-8 bg-white p-4 md:p-6 rounded-xl shadow-sm border border-gray-100">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                    <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                        <span class="text-orange-500">📅</span> Upcoming Pickups
                    </h2>
                    <a href="/donate" class="inline-flex justify-center items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition-transform active:scale-95 shadow-md">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Schedule Pickup
                    </a>
                </div>

                <ul class="space-y-3">
                    {% for donation in scheduled_list %}
                    <li onclick="showDonationDetails({{ donation.ID }})"
                        class="cursor-pointer p-4 border border-gray-100 rounded-xl flex flex-wrap justify-between items-center bg-gray-50/50 hover:bg-white hover:border-green-400 transition-all group">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-orange-400"></div>
                            <div>
                                <span class="block font-medium text-gray-700 text-sm md:text-base">
                                    {{ donation.Dropoff.strftime('%B %d, %Y') }}
                                </span>
                                <span class="text-xs text-gray-400">
                                    {{ donation.Quantity }} meals scheduled
                                </span>
                            </div>
                        </div>
                        <span class="text-sm font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full mt-2 sm:mt-0">
                            {{ donation.Dropoff.strftime('%I:%M %p') }}
                        </span>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </main>
    </div>

    <div id="donationModal" class="hidden fixed inset-0 bg-gray-900/70 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl overflow-hidden max-h-[90vh] flex flex-col transform transition-all">
            <div class="p-6 overflow-y-auto">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">Donation Summary</h3>
                    <button onclick="closeDonationModal()" class="text-gray-400 hover:text-gray-600 text-2xl px-2">&times;</button>
                </div>
               
                <div id="modalLoading" class="py-10 text-center">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-green-500 border-t-transparent"></div>
                </div>

                <div id="modalBody" class="hidden space-y-6">
                    <div class="flex flex-col sm:flex-row items-center gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
                        <img id="detItemImg" src="" class="w-20 h-20 rounded-lg object-cover bg-white shadow-sm">
                        <div class="text-center sm:text-left">
                            <p class="text-xs font-bold text-green-600 uppercase tracking-wider">Inventory Added</p>
                            <p class="text-lg font-bold text-gray-800"><span id="detQty"></span>x <span id="detItemName"></span></p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div class="p-3 bg-gray-50 rounded-lg">
                            <p class="text-gray-400 font-medium uppercase text-[10px]">Destination</p>
                            <p id="detFridge" class="font-semibold text-gray-700"></p>
                        </div>
                        <div class="p-3 bg-gray-50 rounded-lg">
                            <p class="text-gray-400 font-medium uppercase text-[10px]">Scheduled Time</p>
                            <p id="detTime" class="font-semibold text-gray-700"></p>
                        </div>
                    </div>

                    <div id="detNotesContainer" class="hidden border-t pt-4">
                        <p class="text-gray-400 font-medium uppercase text-[10px] mb-1">Notes</p>
                        <p id="detNotes" class="text-sm italic text-gray-600 bg-gray-50 p-3 rounded-lg"></p>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-6 py-4 flex justify-end">
                <button onclick="closeDonationModal()" class="w-full sm:w-auto px-6 py-2 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-lg transition-colors">Close</button>
            </div>
        </div>
    </div>

    {% include "components/footer.html.jinja" %}

    <script>
        // Sidebar Toggle for Mobile
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('-translate-x-full');
        }

        // Modal Functionality
        function showDonationDetails(id) {
            const modal = document.getElementById('donationModal');
            const body = document.getElementById('modalBody');
            const loader = document.getElementById('modalLoading');
            
            // Show modal and loader immediately
            modal.classList.remove('hidden');
            body.classList.add('hidden');
            loader.classList.remove('hidden');

            fetch(`/api/donation-details/${id}`)
                .then(res => res.json())
                .then(data => {
                    // Fill Data
                    document.getElementById('detItemImg').src = data.ItemImage || '/static/default-food.png';
                    document.getElementById('detItemName').innerText = data.ItemName;
                    document.getElementById('detQty').innerText = data.Quantity;
                    document.getElementById('detFridge').innerText = data.FridgeName;
                    document.getElementById('detTime').innerText = `${data.FormattedDate} at ${data.FormattedTime}`;
                    
                    const notesContainer = document.getElementById('detNotesContainer');
                    if (data.Notes && data.Notes.trim() !== "") {
                        document.getElementById('detNotes').innerText = data.Notes;
                        notesContainer.classList.remove('hidden');
                    } else {
                        notesContainer.classList.add('hidden');
                    }

                    // Toggle visibility
                    loader.classList.add('hidden');
                    body.classList.remove('hidden');
                })
                .catch(err => {
                    console.error("Error loading donation details:", err);
                    alert("Could not load donation details.");
                    closeDonationModal();
                });
        }

        function closeDonationModal() {
            document.getElementById('donationModal').classList.add('hidden');
        }

        // Close on escape key
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeDonationModal();
        });

        // Close modal if user clicks the dark backdrop
        document.getElementById('donationModal').addEventListener('click', function(e) {
            if (e.target === this) closeDonationModal();
        });
    </script>
</body>
</html>