<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet</title>
</head>

<body class="bg-white text-gray-800 min-h-screen flex flex-col">
  {% include "components/navbar.html.jinja" %}

  <main class="flex-grow">
    <!-- HERO SECTION -->
    <section class="bg-gradient-to-r from-green-100 to-emerald-50 py-20 px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold text-green-800 mb-6">
        Share Food. Support Community. Reduce Waste.
      </h1>
      <p class="max-w-2xl mx-auto text-lg text-gray-700 mb-8 font-semibold">
        FridgeNet connects neighbors, restaurants, and community fridges to make
        free food easy to find, share, and protect—right in your neighborhood.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-6">

  <a href="/map"
     class="bg-orange-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-xl shadow-md transition">
     Find a Fridge Near You
  </a>

  <a href="/donations"
     class="bg-green-600 hover:bg-orange-500 text-white font-semibold px-8 py-3 rounded-xl shadow-md transition">
     Donate Food
  </a>

  <a href="/signup?role=restaurant"
     class="bg-white border-2 border-green-700 text-green-700 hover:bg-green-700 hover:text-white font-semibold px-8 py-3 rounded-xl shadow-md transition">
     Partner as a Restaurant
  </a>

</div>
     
    </section>


    <!-- ABOUT SECTION -->
    <section class="py-20 px-6 max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-4xl font-bold text-green-800 mb-4">Building Stronger Communities Through Shared Food</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Every day, good food is thrown away while families struggle to access fresh meals.
        </p>
        <p class="text-gray-700 leading-relaxed">
          Quickly find nearby community fridges, donate extra food, and report maintenance needs.
        </p>
      </div>
      <div class="bg-green-50 rounded-2xl h-72 flex items-center justify-center overflow-hidden">
        <img src="/static/images/cimage.jpg" alt="Community image" class="object-cover h-full w-full">
      </div>
    </section>

    <!-- SERVICES SECTION -->
    <section class="bg-green-50 py-20 px-6">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-green-800 mb-12">How FridgeNet Helps You Help Others</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl shadow-md p-8">
            <h3 class="text-xl font-semibold text-green-700 mb-3">Find Nearby Fridges</h3>
            <p class="text-gray-600">Instantly locate community fridges on an interactive map.</p>
          </div>
          <div class="bg-white rounded-2xl shadow-md p-8">
            <h3 class="text-xl font-semibold text-green-700 mb-3">Donate Food Easily</h3>
            <p class="text-gray-600">Restaurants and neighbors can quickly share extra food.</p>
          </div>
          <div class="bg-white rounded-2xl shadow-md p-8">
            <h3 class="text-xl font-semibold text-green-700 mb-3">Keep Fridges Safe</h3>
            <p class="text-gray-600">Report issues or low supplies to support a reliable network.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="bg-orange-200  py-20 px-6">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-green-800 mb-12">Real Impact in Real Neighborhoods</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl shadow-md p-6 italic">“FridgeNet helped me find fresh groceries close to home.” - Herold H</div>
          <div class="bg-white rounded-2xl shadow-md p-6 italic">“Our restaurant now donates extra meals in minutes.” - Caleb S</div>
          <div class="bg-white rounded-2xl shadow-md p-6 italic">“Volunteering feels easier and more organized.” - Delilah W</div>
        </div>
      </div>
    </section>

    <!-- CTA / SIGNUP -->
    <div class="bg-green-200 py-20 px-6 text-center text-green-800">
      <h2 class="text-4xl font-bold mb-4">Join the Movement to End Food Waste</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/signup?role=restaurant"" class="bg-white text-green-700 font-semibold px-8 py-3 rounded-xl shadow-md hover:bg-gray-100 transition">Partner as a Restaurant </a>
        <a href="/signup" class="bg-white text-green-700 font-semibold px-8 py-3 rounded-xl shadow-md hover:bg-gray-100 transition">Create Your Free Account</a>
        <a href="/map" class="bg-white text-green-700 font-semibold px-8 py-3 rounded-xl shadow-md hover:bg-gray-100 transition">Explore the Map</a>
      </div>
    </div>
    
  </main>

  {% include "components/footer.html.jinja" %}

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const flashMessage = document.getElementById('flash-message');
      if (flashMessage) {
        setTimeout(() => {
          flashMessage.style.opacity = '0';
          setTimeout(() => flashMessage.remove(), 500);
        }, 4000);
      }
    });
  </script>
</body>
</html>
