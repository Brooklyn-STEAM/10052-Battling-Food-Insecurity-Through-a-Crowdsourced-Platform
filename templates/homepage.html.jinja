
<!doctype html>
<html lang="en" id="htmlRoot">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/png" href="/static/images/logo.png">

  <title>FridgeNet</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>

  <!-- SAME THEME SYSTEM AS DONATION PAGE -->
  <script>
    (function () {
      const saved = localStorage.getItem("theme");

      if (saved === "dark") {
        document.documentElement.classList.add("dark");
      } else if (saved === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.classList.toggle("dark", prefersDark);
      }
    })();
  </script>

  <style>
    html {
      scroll-behavior: smooth;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    body {
      transition: background-color 0.3s ease, color 0.3s ease;
    }
  </style>

</head>

<body class="bg-white text-gray-800 
             dark:bg-[#1b1730] dark:text-gray-100 
             transition-colors duration-300">

  {% include "components/navbar.html.jinja" %}

  <main>

    <!-- HERO -->
    <section class="text-center py-24 px-6 
                    bg-gradient-to-r from-green-100 to-emerald-50
                    dark:from-[#1e1b2e] dark:to-[#1b1730]">

      <h1 class="text-5xl md:text-6xl font-extrabold text-green-800 dark:text-white mb-6">
        Share Food. Support Community. Reduce Waste.
      </h1>

      <p class="max-w-2xl mx-auto text-lg text-gray-700 dark:text-gray-300 mb-8">
        FridgeNet connects neighbors, restaurants, and community fridges
        to make free food easy to find and share.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">

        <a href="/map"
           class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl shadow-md dark:bg-[#7209b7] dark:hover:bg-[#2a2545] transition">
          Find a Fridge
        </a>

        <a href="/donations"
           class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl shadow-md dark:bg-[#7b2cbf] dark:hover:bg-[#2a2545] transition">
          Donate Food
        </a>

      </div>
    </section>

    <!-- ABOUT -->
    <section class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-10 items-center">

      <div>
        <h2 class="text-4xl font-bold text-green-800 dark:text-white mb-4">
          Building Stronger Communities
        </h2>

        <p class="text-gray-700 dark:text-gray-300 mb-3">
          Reduce food waste and help neighbors access fresh meals.
        </p>

        <p class="text-gray-700 dark:text-gray-300">
          Donate, share, and find community fridges near you.
        </p>
      </div>

      <div class="rounded-2xl overflow-hidden bg-gray-100 dark:bg-[#1f1b35] h-72">
        <img src="/static/images/cimage.jpg" class="w-full h-full object-cover">
      </div>

    </section>

    <!-- FEATURES -->
    <section class="py-20 px-6 bg-green-50 dark:bg-[#1f1b35]">

      <div class="max-w-6xl mx-auto text-center">

        <h2 class="text-4xl font-bold text-green-800 dark:text-white mb-12">
          How FridgeNet Helps
        </h2>

        <div class="grid md:grid-cols-3 gap-8">

          <div class="bg-white dark:bg-[#5a189a] p-6 rounded-2xl shadow">
            <h3 class="text-xl font-semibold mb-2 text-green-700 dark:text-white">
              Find Fridges
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Locate nearby community fridges instantly.
            </p>
          </div>

          <div class="bg-white dark:bg-[#5a189a] p-6 rounded-2xl shadow">
            <h3 class="text-xl font-semibold mb-2 text-green-700 dark:text-white">
              Donate Food
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Share extra food easily with your community.
            </p>
          </div>

          <div class="bg-white dark:bg-[#5a189a] p-6 rounded-2xl shadow">
            <h3 class="text-xl font-semibold mb-2 text-green-700 dark:text-white">
              Support Network
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Keep fridges stocked and maintained.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA (UPDATED AS REQUESTED) -->
    <section class="text-center py-24 px-6 bg-green-200 dark:bg-[#1b1730]">

      <h2 class="text-4xl font-bold text-green-900 dark:text-white mb-6">
        Join the Movement
      </h2>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">

        <a href="/map"
           class="bg-white dark:bg-[#7209b7] text-green-800 dark:text-white px-8 py-3 rounded-xl shadow hover:bg-gray-100 dark:hover:bg-[#40376E] transition">
          Explore Map
        </a>

        <a href="/signup"
           class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl shadow dark:bg-[#7b2cbf] dark:hover:bg-[#2a2545] transition">
          Create New Account
        </a>

      </div>

    </section>

  </main>

  {% include "components/footer.html.jinja" %}

</body>
</html>
