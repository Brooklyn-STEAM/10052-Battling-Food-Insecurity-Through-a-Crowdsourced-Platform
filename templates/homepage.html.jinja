
<!doctype html>
<html lang="en" id="htmlRoot">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/static/images/logo.png">

  <title>FridgeNet</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>

  <script>
    (function () {
      const saved = localStorage.getItem("theme");

      if (saved === "dark") {
        document.documentElement.classList.add("dark");
      } else if (saved === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.classList.toggle("dark", prefersDark);
      }
    })();


    document.addEventListener("DOMContentLoaded", function () {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    });
  </script>

  <style>
    html {
      scroll-behavior: smooth;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    body {
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease-out;
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-200 { transition-delay: 0.2s; }
    .reveal-delay-400 { transition-delay: 0.4s; }
  </style>
<style>
  @keyframes tabFadeIn {
  from { 
    opacity: 0; 
    transform: translateY(15px); 
  }
  to { 
    opacity: 1; 
    transform: translateY(0); 
  }
}

.tab-panel:not(.hidden) {
  display: grid; /* Ensures it stays a grid when visible */
  animation: tabFadeIn 0.5s ease-out forwards;
}
.glow-blob {
  filter: blur(80px);
  z-index: 0;
  pointer-events: none;
}
  
</style>
</head>

<body class="bg-white text-gray-800 
             dark:bg-[#1b1730] dark:text-gray-100 
             transition-colors duration-300">

  {% include "components/navbar.html.jinja" %}

  <main>

    <section class="text-center py-24 px-6 
                    bg-gradient-to-r from-green-100 to-emerald-50
                    dark:from-[#2a2545] dark:to-[#1b1730]">

      <h1 class="text-5xl md:text-6xl font-extrabold text-green-800 dark:text-white mb-6">
        Share Food. Support Community. Reduce Waste.
      </h1>

      <p class="max-w-2xl mx-auto text-lg text-gray-700 dark:text-purple-100/80 mb-8">
        FridgeNet connects neighbors, restaurants, and community fridges
        to make free food easy to find and share.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">

        <a href="{{ url_for('map_page') }}"
           class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl font-semibold shadow-md dark:bg-[#7b2cbf] dark:hover:bg-[#5a189a] transition">
          Find a Fridge
        </a>

        <a href="{{ url_for('donations') }}"
           class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl shadow-md font-semibold dark:bg-[#6f52c9] dark:hover:bg-[#40376E] transition">
          Donate Food
        </a>

      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-10 items-center">

      <div>
        <h2 class="text-4xl font-bold text-green-800 dark:text-purple-300 mb-4">
          Building Stronger Communities
        </h2>

        <p class="text-gray-700 dark:text-purple-100/90 mb-3">
          Reduce food waste and help neighbors access fresh meals.
        </p>

        <p class="text-gray-700 dark:text-purple-100/90">
          Donate, share, and find community fridges near you.
        </p>
      </div>

      <div class="rounded-2xl overflow-hidden bg-gray-100 dark:bg-[#2a2545] border dark:border-[#40376E] h-72 shadow-xl">
        <img src="/static/images/cimage.jpg" class="w-full h-full object-cover">
      </div>

    </section>

    <section class="py-24 px-6 bg-green-50/50 dark:bg-[#231d3d] overflow-hidden">
    <div class="max-w-6xl mx-auto text-center">
    
        <h2 class="text-4xl font-black mb-12 text-green-800 dark:text-white">How do you want to help?</h2>

        <div class="flex p-1 bg-gray-200/50 dark:bg-[#2a2545] rounded-2xl mb-12 max-w-md mx-auto border dark:border-white/5">
            <button onclick="switchTab('neighbor')" id="btn-neighbor" class="tab-btn flex-1 py-3 rounded-xl font-bold text-sm transition-all">
                Neighbors
            </button>
            <button onclick="switchTab('restaurant')" id="btn-restaurant" class="tab-btn flex-1 py-3 rounded-xl font-bold text-sm transition-all">
                Restaurants
            </button>
        </div>

        <div class="relative min-h-[400px]">
            
            <div id="panel-neighbor" class="tab-panel hidden grid md:grid-cols-2 gap-8 items-center text-left p-8 bg-white dark:bg-[#2a2545] rounded-[2.5rem] shadow-xl border dark:border-white/5">
                <div>
                    <span class="text-4xl mb-4 block">🏠</span>
                    <h3 class="text-2xl font-bold mb-4 dark:text-purple-300">Feed Your Block</h3>
                    <p class="text-gray-700 dark:text-purple-100/70 mb-6">FridgeNet is powered by people like you. Use the map to find a meal, drop off extra groceries, or simply update a fridge's status to help others. No commitment, just community.</p>
                    <ul class="space-y-2 mb-8 text-sm font-medium text-gray-500 dark:text-gray-400">
                        <li class="flex items-center gap-2">📍 Find or share food near you</li>
                        <li class="flex items-center gap-2">🔄 Update fridge stock levels</li>
                    </ul>
                    <a href="{{ url_for('map_page') }}" class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl font-bold shadow-lg transition-transform hover:scale-105">Open the Map</a>
                </div>
                <div class="bg-green-100 dark:bg-green-900/20 rounded-3xl h-72 overflow-hidden shadow-inner">
                    <img src="/static/images/peopledonate.webp" class="w-full h-full object-cover">
                </div>
            </div>

            <div id="panel-restaurant" class="tab-panel hidden grid md:grid-cols-2 gap-8 items-center text-left p-8 bg-white dark:bg-[#2a2545] rounded-[2.5rem] shadow-xl border dark:border-white/5">
                <div>
                    <span class="text-4xl mb-4 block">🍳</span>
                    <h3 class="text-2xl font-bold mb-4 dark:text-purple-300">Restaurant Partners</h3>
                    <p class="text-gray-700 dark:text-purple-100/70 mb-6">Don’t let your surplus go to waste. Register your business to track your social impact, reduce waste costs, and ensure your extra food reaches those who need it most.</p>
                    <a href="{{ url_for('signup') }}" class="inline-block bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-xl font-bold shadow-lg transition-transform hover:scale-105">Register Business</a>
                </div>
                <div class="bg-orange-100 dark:bg-orange-900/20 rounded-3xl h-72 overflow-hidden shadow-inner">
                    <img src="/static/images/donatefood.jpg" class="w-full h-full object-cover">
                </div>
            </div>

        </div>
    </div>
</section>

    <div class="relative text-center py-24 px-6
                bg-gradient-to-r from-green-300 via-green-200 to-emerald-200
                dark:from-[#1b1730] dark:via-[#2a2545] dark:to-[#1b1730]
                transition-colors overflow-hidden">

      
  </main>
  <!-- Flash Messages Container -->
<div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-3 w-full max-w-md px-4">
  {% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
      {% for category, message in messages %}
        <div class="flash-message p-4 rounded-xl shadow-2xl border bg-white dark:bg-[#2a2545] 
                    {% if category == 'info' %} border-blue-500 text-blue-700 dark:text-blue-300 
                    {% else %} border-green-500 text-green-700 dark:text-green-300 {% endif %} 
                    transition-opacity duration-500">
          <div class="flex items-center gap-3">
            <span class="font-medium">{{ message }}</span>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  {% endwith %}
</div>

  {% include "components/footer.html.jinja" %}
<script>
document.addEventListener("DOMContentLoaded", () => {
  const messages = document.querySelectorAll(".flash-message");

  messages.forEach((msg) => {
    // wait before fading out
    setTimeout(() => {
      msg.classList.add("flash-hide");

      // remove from DOM after animation
      setTimeout(() => {
        msg.remove();
      }, 600);
    }, 3000); // visible for 3 seconds
  });
});

function switchTab(role) {
  // Hide all panels
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('grid'));
  
  // Show active panel
  const active = document.getElementById('panel-' + role);
  active.classList.remove('hidden');
  active.classList.add('grid');
  
  // Update button styles
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.classList.remove('bg-white', 'dark:bg-[#40376E]', 'shadow-sm', 'text-green-600', 'dark:text-purple-300');
    btn.classList.add('text-gray-500', 'dark:text-gray-400');
  });
  
  // Highlight active button
  const activeBtn = document.getElementById('btn-' + role);
  activeBtn.classList.add('bg-white', 'dark:bg-[#40376E]', 'shadow-sm', 'text-green-600', 'dark:text-purple-300');
  activeBtn.classList.remove('text-gray-500', 'dark:text-gray-400');
}
document.addEventListener("DOMContentLoaded", () => {
    // This makes sure the Neighbor tab is active and styled correctly on load
    switchTab('neighbor'); 
});
</script>
</body>
</html>
