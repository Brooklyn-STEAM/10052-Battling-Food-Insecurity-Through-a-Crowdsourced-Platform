<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Profile</title>
</head>

<body class="min-h-screen bg-gray-100 flex items-center justify-center p-6">

<div class="bg-white w-full max-w-md rounded-2xl p-8 shadow-lg">

  <!-- Profile Header -->
  <div class="flex flex-col items-center mb-8">
    {% if current_user.profile_picture %}
      <img src="{{ current_user.profile_picture }}"
           class="w-24 h-24 rounded-full object-cover shadow-md mb-4"
           onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
      <div class="w-24 h-24 rounded-full bg-green-700 hidden items-center justify-center shadow-md mb-4">
        <span class="text-white text-3xl font-bold">{{ current_user.name[0] | upper }}</span>
      </div>
    {% else %}
      <div class="w-24 h-24 rounded-full bg-green-600 flex items-center justify-center shadow-md mb-4">
        <span class="text-white text-3xl font-bold">{{ current_user.name[0] | upper }}</span>
      </div>
    {% endif %}

    <h2 class="text-2xl font-bold text-gray-900">{{ current_user.name }}</h2>
    <p class="text-gray-600 text-sm mt-1">{{ current_user.email }}</p>
  </div>

  <!-- Flash Messages -->
  {% with messages = get_flashed_messages() %}
    {% if messages %}
      {% for message in messages %}
        <div class="flash-message mb-4 px-4 py-3 rounded-xl bg-green-700 text-white text-sm">
          {{ message }}
        </div>
      {% endfor %}
    {% endif %}
  {% endwith %}

  <!-- Username -->
  <form method="POST" action="/profile/update-username" class="mb-6">
    <label class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2 block">Username</label>
    <div class="flex gap-2">
      <input type="text" name="username" value="{{ current_user.name }}" required
        class="flex-1 px-4 py-3 rounded-xl bg-gray-100 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600 text-gray-900">
      <button type="submit"
        class="px-4 py-3 rounded-xl bg-orange-500 text-white font-semibold hover:bg-green-800 transition text-sm">
        Save
      </button>
    </div>
  </form>

  <!-- Password -->
  <form method="POST" action="/profile/update-password" class="mb-6">
    <label class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2 block">New Password</label>
    <div class="flex gap-2">
      <input type="password" name="password" placeholder="••••••••" required minlength="8"
        class="flex-1 px-4 py-3 rounded-xl bg-gray-100 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600 text-gray-900">
      <button type="submit"
        class="px-4 py-3 rounded-xl bg-orange-500 text-white font-semibold hover:bg-green-800 transition text-sm">
        Save
      </button>
    </div>
  </form>

  <!-- Profile Picture -->
  <form method="POST" action="/profile/update-picture" class="mb-8">
    <label class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2 block">Profile Picture URL</label>
    <div class="flex gap-2">
      <input type="url" name="picture_url" placeholder="https://example.com/photo.jpg"
             value="{{ current_user.profile_picture or '' }}"
        class="flex-1 px-4 py-3 rounded-xl bg-gray-100 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-600 text-gray-900">
      <button type="submit"
        class="px-4 py-3 rounded-xl bg-orange-500 text-white font-semibold hover:bg-green-800 transition text-sm">
        Save
      </button>
    </div>
  </form>

  <div class="border-t border-gray-300 mb-6"></div>

  <!-- Actions -->
  <div class="space-y-3">
    <a href="/"
      class="block text-center w-full py-3 rounded-xl bg-green-600 text-white font-semibold hover:bg-green-800 transition">
      Return to Home
    </a>
    <a href="/logout"
      class="block text-center w-full py-3 rounded-xl bg-orange-600 text-white font-semibold hover:bg-orange-700 transition">
      Log Out
    </a>
  </div>

</div>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const alerts = document.querySelectorAll(".flash-message");

    alerts.forEach(alert => {
      setTimeout(() => {
        alert.classList.add("opacity-0", "translate-y-2", "transition-all", "duration-700");
        setTimeout(() => alert.remove(), 700);
      }, 3000);
    });
  });
</script>

</body>
</html>
