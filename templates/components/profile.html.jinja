<!doctype html>
<html>
 <head>
   <meta charset="UTF-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <link rel="icon" type="image/png" href="/static/images/logo.png">
   <title>Profile - FridgeNet</title>

   <script src="https://cdn.tailwindcss.com"></script>

   <script>
     tailwind.config = { darkMode: 'class' }
   </script>

   <script>
     (function () {
       const saved = localStorage.getItem("theme");

       if (saved === "dark") {
         document.documentElement.classList.add("dark");
       } else if (saved === "light") {
         document.documentElement.classList.remove("dark");
       } else {
         const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
         document.documentElement.classList.toggle("dark", prefersDark);
       }
     })();
   </script>

   <style>
     html {
       transition: background-color 0.3s ease, color 0.3s ease;
     }
     body, div, input {
       transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
     }
   </style>
 </head>

<body class="bg-gradient-to-br from-green-50 to-emerald-100
            dark:from-[#1b1730] dark:to-[#7C5EDB]
            min-h-screen text-gray-900 dark:text-gray-100">

{% include "components/navbar.html.jinja" %}

<div class="flex justify-center py-8 sm:py-16 px-4">
 <div class="bg-white dark:bg-[#1b1730]
             w-full max-w-lg rounded-3xl p-6 sm:p-10 shadow-xl
             border border-green-100 dark:border-[#40376E]">

   <div class="flex flex-col sm:flex-row items-center gap-6 mb-8 text-center sm:text-left">
     <div class="relative w-28 h-28 flex-shrink-0">
       <img src="{{ current_user.profile_picture or '/static/images/default-profile.png' }}"
            class="w-28 h-28 rounded-full object-cover shadow-lg ring-4 ring-green-200 dark:ring-[#5a4fd6]"
            onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');">

       <div class="w-28 h-28 rounded-full bg-green-600 dark:bg-[#7b2cbf] flex items-center justify-center hidden shadow-lg ring-4 ring-green-200 dark:ring-[#5a4fd6]">
         <span class="text-white text-4xl font-bold">
           {{ current_user.name[0] | upper }}
         </span>
       </div>
     </div>
       
     <div class="flex flex-col min-w-0 w-full">
       <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white break-words">
         {{ current_user.name }}
       </h2>
       <p class="text-gray-600 dark:text-gray-400 text-md mt-1 break-all">
         {{ current_user.email }}
       </p>
     </div>
   </div>

   {% with messages = get_flashed_messages(with_categories=true) %}
     {% if messages %}
       {% for category, message in messages %}
         {% if category.startswith("profile_") %}
           <div class="flash-message mb-4 px-4 py-3 rounded-xl text-white text-sm shadow-md transition-all duration-500
             {% if category == 'profile_error' %}
               bg-red-500 dark:bg-red-700
             {% else %}
               bg-green-600 dark:bg-[#6f52c9]
             {% endif %}
           ">
             {{ message }}
           </div>
         {% endif %}
       {% endfor %}
     {% endif %}
   {% endwith %}

   <form method="POST" action="/profile/update-username" class="mb-6">
     <label class="text-xs font-semibold text-gray-700 dark:text-gray-400 uppercase mb-2 block">
       Username
     </label>
     <div class="flex flex-col sm:flex-row gap-2">
       <input type="text" name="username" value="{{ current_user.name }}" required
         class="w-full px-4 py-3 rounded-xl
                bg-gray-50 dark:bg-[#2a2545]
                border border-gray-300 dark:border-[#40376E]
                text-gray-900 dark:text-white
                focus:ring-2 focus:ring-green-600 dark:focus:ring-[#7b2cbf]
                outline-none">
       <button type="submit"
         class="w-full sm:w-auto px-6 py-3 rounded-xl bg-green-600 text-white font-semibold
                hover:bg-green-700 dark:bg-[#7b2cbf] dark:hover:bg-[#5a189a] transition">
         Save
       </button>
     </div>
   </form>

   <form method="POST" action="/profile/update-password" class="mb-6">
     <label class="text-xs font-semibold text-gray-700 dark:text-gray-400 uppercase mb-2 block">
       New Password
     </label>
     <div class="flex flex-col sm:flex-row gap-2">
       <input type="password" name="password" required minlength="8"
         class="w-full px-4 py-3 rounded-xl
                bg-gray-50 dark:bg-[#2a2545]
                border border-gray-300 dark:border-[#40376E]
                text-gray-900 dark:text-white
                focus:ring-2 focus:ring-green-600 dark:focus:ring-[#7b2cbf]
                outline-none">
       <button type="submit"
         class="w-full sm:w-auto px-6 py-3 rounded-xl bg-green-600 text-white font-semibold
                hover:bg-green-700 dark:bg-[#7b2cbf] dark:hover:bg-[#5a189a] transition">
         Save
       </button>
     </div>
   </form>

   <form method="POST" action="/profile/update-picture" class="mb-8">
     <label class="text-xs font-semibold text-gray-700 dark:text-gray-400 uppercase mb-2 block">
       Profile Picture URL
     </label>
     <div class="flex flex-col gap-2">
       <input type="url" name="picture_url" value="{{ current_user.profile_picture or '' }}"
         class="w-full px-4 py-3 rounded-xl
                bg-gray-50 dark:bg-[#2a2545]
                border border-gray-300 dark:border-[#40376E]
                text-gray-900 dark:text-white
                focus:ring-2 focus:ring-green-600 dark:focus:ring-[#7b2cbf]
                outline-none">
       
       <div class="flex flex-col sm:flex-row gap-2 w-full mt-1">
         <button type="submit" name="action" value="save"
           class="flex-1 px-6 py-3 rounded-xl bg-green-600 text-white font-semibold
                  hover:bg-green-700 dark:bg-[#7b2cbf] dark:hover:bg-[#5a189a] transition">
           Save URL
         </button>
         
         {% if current_user.profile_picture and current_user.profile_picture != '/static/images/default-profile.png' %}
           <button type="submit" name="action" value="reset"
             class="flex-1 px-6 py-3 rounded-xl border-2 border-red-500 text-red-500 font-semibold
                    hover:bg-red-500 hover:text-white dark:border-red-600 dark:text-red-400 
                    dark:hover:bg-red-600 dark:hover:text-white transition">
             Reset Picture
           </button>
         {% endif %}
       </div> 
     </div>
   </form>

   <div class="mb-8 p-5 sm:p-6 border border-red-200 dark:border-red-900/30 rounded-3xl bg-red-50 dark:bg-red-900/10">
     <h3 class="text-xl font-bold text-red-700 dark:text-red-400 mb-2">Danger Zone</h3>
     <p class="text-sm text-red-600 dark:text-red-300/70 mb-4">
       Once you delete your account, there is no going back. All your reviews, favorites, and profile data will be permanently removed.
     </p>
     <form action="{{ url_for('delete_account') }}" method="POST" 
           onsubmit="return confirm('Are you absolutely sure? This action cannot be undone.');">
         <button type="submit" 
                 class="w-full sm:w-auto px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl transition-all active:scale-95 shadow-lg shadow-red-500/20">
             Delete My Account
         </button>
     </form>
   </div>

   <div class="border-t border-gray-300 dark:border-[#40376E] mb-8"></div>

   <div class="space-y-3">
     <a href="/"
        class="block text-center py-3 rounded-xl bg-green-600 text-white font-semibold
               hover:bg-green-700 dark:bg-[#6f52c9] dark:hover:bg-[#40376E] transition">
       Return to Home
     </a>
     <a href="/logout"
        class="block text-center py-3 rounded-xl bg-red-500 text-white font-semibold
               hover:bg-red-600 dark:bg-[#d00000] dark:hover:bg-[#9b0000] transition">
       Log Out
     </a>
   </div>

 </div>
</div>

<script>
 document.addEventListener("DOMContentLoaded", () => {
   const alerts = document.querySelectorAll(".flash-message");

   alerts.forEach(alert => {
     setTimeout(() => {
       alert.classList.add("opacity-0", "translate-y-2");
       setTimeout(() => alert.remove(), 700);
     }, 3000);
   });
 });
</script>

</body>
</html>