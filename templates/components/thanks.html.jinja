<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet | Thank You</title>

  <script>
    tailwind.config = { darkMode: 'class' }
  </script>

  <script>
    (function () {
      const saved = localStorage.getItem("theme");
      if (saved === "dark") {
        document.documentElement.classList.add("dark");
      } else if (saved === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.classList.toggle("dark", prefersDark);
      }
    })();
  </script>

  <style>
    html {
      scroll-behavior: smooth;
    }
    body, div, h1, h2, h3, p, a {
      transition: background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.4s ease, color 0.4s ease;
    }
  </style>
</head>

{% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    <div class="fixed top-24 right-6 z-[6000] space-y-3 pointer-events-none">
    {% for category, message in messages %}
      <div class="pointer-events-auto bg-white dark:bg-gray-800 border-l-4 border-green-500 shadow-xl rounded-r-xl p-4 max-w-sm transition transform translate-x-0 animate-bounce">
        <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{{ message }}</p>
      </div>
    {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<body class="bg-gradient-to-br from-green-50 via-white to-yellow-50 
             dark:from-[#0b0a18] dark:via-[#121028] dark:to-[#1a1635] 
             text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">

  {% include "components/navbar.html.jinja" %}

  <main class="flex-1 relative overflow-hidden py-20 px-6">

  <!-- Background Glow Effects -->
  <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-green-300/20 dark:bg-purple-700/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-yellow-300/20 dark:bg-indigo-700/10 rounded-full blur-3xl pointer-events-none"></div>

  <!-- Floating Decorative Icons -->
  <div class="absolute top-28 left-10 text-5xl opacity-20 animate-bounce">🥦</div>
  <div class="absolute bottom-24 right-12 text-6xl opacity-20 animate-pulse">💚</div>
  <div class="absolute top-1/2 right-20 text-5xl opacity-20 animate-bounce delay-300">🧊</div>

  <section class="max-w-5xl mx-auto relative z-10">

    <!-- Main Card -->
    <div class="relative overflow-hidden rounded-[40px]
                bg-white/80 dark:bg-white/5
                backdrop-blur-2xl
                border border-white/30 dark:border-white/10
                shadow-[0_20px_80px_rgba(0,0,0,0.08)]
                dark:shadow-[0_20px_80px_rgba(0,0,0,0.45)]
                p-8 md:p-14">

      <!-- Top Gradient Accent -->
      <div class="absolute inset-x-0 top-0 h-2 bg-gradient-to-r from-green-500 via-emerald-400 to-yellow-400 dark:from-purple-500 dark:via-indigo-500 dark:to-fuchsia-500"></div>

      <!-- Success Badge -->
      <div class="flex justify-center mb-10">
        <div class="relative">
          <div class="absolute inset-0 bg-green-400 dark:bg-purple-500 blur-2xl opacity-30 rounded-full"></div>

          <div class="relative inline-flex items-center justify-center
                      w-24 h-24 rounded-full
                      bg-gradient-to-br from-green-100 to-green-50
                      dark:from-purple-700/40 dark:to-indigo-700/40
                      border border-green-200 dark:border-purple-500/30
                      shadow-xl">

            <svg class="w-12 h-12 text-green-600 dark:text-purple-300"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="2.5"
                 viewBox="0 0 24 24">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Heading -->
      <div class="text-center">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-tight
                   bg-gradient-to-r from-green-700 via-emerald-500 to-green-400
                   dark:from-purple-300 dark:via-indigo-300 dark:to-fuchsia-300
                   bg-clip-text text-transparent mb-6">
          Thank You!
        </h1>

        <p class="max-w-3xl mx-auto text-lg md:text-xl
                  text-gray-600 dark:text-gray-300
                  leading-relaxed font-medium">
          Your donation helps feed families, reduce food waste, and strengthen
          communities. Every contribution makes a real impact and helps keep
          community fridges stocked for neighbors in need.
        </p>
      </div>

      <!-- Impact Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-14">

        <div class="rounded-3xl p-6 bg-green-50 dark:bg-[#1b1730]
                    border border-green-100 dark:border-[#40376E]
                    text-center shadow-sm">
          <div class="text-4xl mb-3">🥗</div>
          <h3 class="text-3xl font-black text-green-600 dark:text-green-400">
            {{ total_meals or "25+" }}
          </h3>
          <p class="text-gray-500 dark:text-purple-300/70 text-sm mt-1">
            Meals Supported
          </p>
        </div>

        <div class="rounded-3xl p-6 bg-green-50 dark:bg-[#1b1730]
                    border border-green-100 dark:border-[#40376E]
                    text-center shadow-sm">
          <div class="text-4xl mb-3">🌍</div>
          <h3 class="text-3xl font-black text-green-600 dark:text-green-400">
            Community
          </h3>
          <p class="text-gray-500 dark:text-purple-300/70 text-sm mt-1">
            Helping Local Families
          </p>
        </div>

        <div class="rounded-3xl p-6 bg-green-50 dark:bg-[#1b1730]
                    border border-green-100 dark:border-[#40376E]
                    text-center shadow-sm">
          <div class="text-4xl mb-3">♻️</div>
          <h3 class="text-3xl font-black text-green-600 dark:text-green-400">
            Less Waste
          </h3>
          <p class="text-gray-500 dark:text-purple-300/70 text-sm mt-1">
            Food Saved From Disposal
          </p>
        </div>

      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-14">

        <a href="{{ url_for('index') }}"
          class="group relative overflow-hidden
                 w-full sm:w-auto inline-flex items-center justify-center
                 bg-gray-900 dark:bg-white
                 text-white dark:text-gray-900
                 font-black py-4 px-9 rounded-2xl
                 shadow-2xl transition-all duration-300
                 hover:scale-105 active:scale-95">

          <span class="relative z-10">Return Home</span>
        </a>

        <a href="/restaurant-dashboard"
          class="group relative overflow-hidden
                 w-full sm:w-auto inline-flex items-center justify-center
                 bg-gradient-to-r from-green-600 to-emerald-500
                 dark:from-purple-600 dark:to-indigo-600
                 text-white font-black
                 py-4 px-9 rounded-2xl
                 shadow-2xl transition-all duration-300
                 hover:scale-105 active:scale-95">

          <span class="relative z-10 flex items-center gap-2">
            My Donations
            <svg class="w-5 h-5"
                 fill="none"
                 stroke="currentColor"
                 viewBox="0 0 24 24">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </span>
        </a>
      </div>

    </div>
  </section>
</main>

  {% include "components/footer.html.jinja" %}

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const duration = 3500; // Slightly longer duration for the multi-color festival feel
      const end = Date.now() + duration;
      const isDark = document.documentElement.classList.contains("dark");

      // Enhanced rich, multi-tonal color configurations
      const colors = isDark
        ? [
            '#c084fc', '#a855f7', '#7e22ce', // Purples & Amethysts
            '#38bdf8', '#0284c7',             // Electric Blues
            '#f59e0b', '#fbbf24'              // Warm Amber Highlights
          ]
        : [
            '#10B981', '#059669', '#a7f3d0', // Emeralds & Mint Greens
            '#fbbf24', '#f59e0b',             // Festive Marigold & Golds
            '#f43f5e', '#fda4af'              // Coral Rose pops
          ];

      (function frame() {
        // Left side cannon
        confetti({
          particleCount: 5,
          angle: 50,
          spread: 70,
          origin: { x: 0, y: 0.75 },
          colors: colors,
          ticks: 200
        });

        // Right side cannon
        confetti({
          particleCount: 5,
          angle: 130,
          spread: 70,
          origin: { x: 1, y: 0.75 },
          colors: colors,
          ticks: 200
        });

        if (Date.now() < end) {
          requestAnimationFrame(frame);
        }
      })();
    });
  </script>
</body>
</html>