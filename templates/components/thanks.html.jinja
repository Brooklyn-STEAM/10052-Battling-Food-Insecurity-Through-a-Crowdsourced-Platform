<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet | Thank You</title>
</head>

<body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col">

  {% include "components/navbar.html.jinja" %}

  <!-- HERO SECTION -->
  <section class="bg-gradient-to-r from-green-100 to-emerald-50 py-24 px-6 text-center flex flex-col items-center relative">
    <h1 class="text-5xl md:text-6xl font-extrabold text-green-800 mb-6 animate-fade-in">
      Thank You!
    </h1>

    <p class="max-w-3xl mx-auto text-lg md:text-xl text-gray-700 mb-12 leading-relaxed">
      You save lives and reduce waste by donating to a community fridge. We deeply appreciate your generosity and
      commitment to building a stronger, more connected community. Your contribution helps ensure that fresh food is
      available to those in need while minimizing food waste. Thank you for being a part of the FridgeNet movement!
    </p>

    <a href="{{ url_for('index') }}"
       class="inline-block bg-green-600 text-white font-semibold py-3 px-8 rounded-lg shadow-lg hover:bg-green-700 transition">
      Return Home
    </a>
  </section>

  <!-- OPTIONAL FEATURE HIGHLIGHTS -->
  <section class="py-20 px-6 bg-white text-center">
    <h2 class="text-3xl font-bold text-gray-800 mb-10">Your Impact</h2>
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10">
      <div class="p-6 bg-green-50 rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3">Reduce Waste</h3>
        <p class="text-gray-700">Every donation prevents food from going to landfill and supports families in need.</p>
      </div>
      <div class="p-6 bg-green-50 rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3">Help Your Community</h3>
        <p class="text-gray-700">Your contribution ensures fresh food is available locally for those who need it most.</p>
      </div>
      <div class="p-6 bg-green-50 rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3">Join a Movement</h3>
        <p class="text-gray-700">Be part of FridgeNet’s growing network of donors, volunteers, and community leaders.</p>
      </div>
    </div>
  </section>

  {% include "components/footer.html.jinja" %}

  <!-- CONFETTI SCRIPT -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const duration = 3000; // 3 seconds
      const end = Date.now() + duration;

      (function frame() {
        confetti({
          particleCount: 5,
          angle: 60,
          spread: 55,
          origin: { x: 0 },
          colors: ['#10B981', '#059669', '#34D399', '#6EE7B7', '#A7F3D0']
        });
        confetti({
          particleCount: 5,
          angle: 120,
          spread: 55,
          origin: { x: 1 },
          colors: ['#10B981', '#059669', '#34D399', '#6EE7B7', '#A7F3D0']
        });

        if (Date.now() < end) {
          requestAnimationFrame(frame);
        }
      })();
    });
  </script>

</body>

</html>