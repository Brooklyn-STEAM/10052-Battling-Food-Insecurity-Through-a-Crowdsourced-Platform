                   opacity-0 invisible group-hover:opacity-100 group-hover:visible
                   transition-all duration-200 transform origin-top-right group-hover:scale-100 scale-95">

          {% if not current_user.is_authenticated %}

            <li>
              <a href="/login"
                 class="block px-4 py-3 hover:bg-green-600 dark:hover:bg-[#40376E] transition">
                Sign In
              </a>
            </li>

            <li>
              <a href="/signup"
                 class="block px-4 py-3 hover:bg-green-600 dark:hover:bg-[#40376E] transition">
                Register
              </a>
            </li>

          {% else %}

            <li>
              <a href="/profile_page"
                 class="block px-4 py-3 hover:bg-green-600 dark:hover:bg-[#40376E] transition">
                Profile
              </a>
            </li>

            <li>
              <a href="/restaurant-dashboard"
                 class="block px-4 py-3 hover:bg-green-600 dark:hover:bg-[#40376E] transition">
                Dashboard
              </a>
            </li>

            <li class="border-t border-green-500/30 dark:border-white/10">
              <a href="/logout"
                 class="block px-4 py-3 hover:bg-red-600 text-red-100 transition">
                Logout
              </a>
            </li>

          {% endif %}
        </ul>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-button"
        class="md:hidden p-2 rounded-lg hover:bg-white/10 transition">

        <svg xmlns="http://www.w3.org/2000/svg"
             class="h-6 w-6"
             fill="none"
             viewBox="0 0 24 24"
             stroke="currentColor">

          <path stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu"
       class="hidden md:hidden bg-green-700 dark:bg-[#1b1730] border-t border-white/10 shadow-xl">

    <ul class="flex flex-col px-6 py-6 space-y-4 font-medium">

      <li><a id="mobile-nav-map" class="block hover:text-yellow-300 transition" href="/map">Map</a></li>

      <li><a id="mobile-nav-donate" class="block hover:text-yellow-300 transition" href="/donate">Donate</a></li>

      <li><a id="mobile-nav-partner" class="block hover:text-yellow-300 transition" href="/restaurants-connect">Partner With Us</a></li>

      <li><a id="mobile-nav-about" class="block hover:text-yellow-300 transition" href="/about">About Us</a></li>

      {% if current_user.is_authenticated %}

        <li><a class="block hover:text-yellow-300 transition" href="/profile_page">Profile</a></li>

        <li><a class="block hover:text-yellow-300 transition" href="/restaurant-dashboard">Dashboard</a></li>

        <li><a class="block text-red-300" href="/logout">Logout</a></li>

      {% else %}

        <li><a class="block hover:text-yellow-300 transition" href="/login">Sign In</a></li>

        <li><a class="block hover:text-yellow-300 transition" href="/signup">Register</a></li>

      {% endif %}
    </ul>
  </div>
</nav>

<script>
  // Mobile Menu Toggle logic
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Theme Toggle logic
  const themeToggle = document.getElementById("theme-toggle");
  
  function updateRouteTheme() {
    if (!window.currentRouteLayer) return;

    const isDark = document.documentElement.classList.contains("dark");

    window.currentRouteLayer.setStyle({
      color: isDark ? '#a855f7' : '#16a34a'
    });
  }

  if (themeToggle) {

    themeToggle.addEventListener("click", () => {

      const isDark = document.documentElement.classList.toggle("dark");

      localStorage.setItem(
        "theme",
        isDark ? "dark" : "light"
      );

      if (window.applyMapTheme) {
        window.applyMapTheme();
      }

      updateRouteTheme();

    });

  }

  /* =========================================================
     GLOBAL TUTORIAL EVENT
  ========================================================= */

  window.restartTutorial = window.restartTutorial || function () {

    // Donate Page Tutorial
    if (
      window.location.pathname === "/donate" &&
      typeof window.restartDonateTutorial === "function"
    ) {

      window.restartDonateTutorial();
      return;

    }

    // Homepage Tutorial
    if (typeof window.startHomepageTutorial === "function") {

      window.startHomepageTutorial();
      return;

    }

    // Generic fallback
    window.dispatchEvent(
      new CustomEvent("start-tutorial")
    );

  };

  /* =========================================================
     NAVBAR TUTORIAL BUTTONS
  ========================================================= */

  document
    .querySelectorAll("[data-tutorial-trigger]")
    .forEach(btn => {

      btn.addEventListener("click", () => {

        window.restartTutorial();

      });

    });

</script>