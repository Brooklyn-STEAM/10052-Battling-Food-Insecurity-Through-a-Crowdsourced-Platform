<!-- FridgeNet Navbar -->
<nav class="relative z-[2000] bg-green-600 dark:bg-[#8C65DB] text-white w-full"> <div class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between px-6 flex items-center justify-between h-full">


   <!-- Logo -->
    <a class="text-2xl font-bold flex-shrink-0" href="/">
      FridgeNet
    </a>

    <ul class="hidden md:flex items-center font-semibold space-x-10">
      <li><a class="hover:text-yellow-300 transition" href="/map">Map</a></li>
      <li><a class="hover:text-yellow-300 transition" href="/donations">Donate</a></li>
      <li><a class="hover:text-yellow-300 transition" href="/restaurants-connect">Partner with Us</a></li>
      <li><a class="hover:text-yellow-300 transition" href="/about">About Us</a></li>
    </ul>


   <!-- Right Side -->
   <div class="flex items-center space-x-4">


     <!-- Theme Toggle -->
     <button id="theme-toggle"
       class="group relative w-14 h-8 flex items-center rounded-full
              bg-gradient-to-r from-green-400 to-green-500
              dark:from-[#40376E] dark:to-[#5a4fd6]
              transition-all duration-500 ease-in-out
              shadow-inner hover:shadow-lg hover:scale-105 active:scale-95">


       <!-- Glow -->
       <div class="absolute inset-0 rounded-full opacity-0
                   group-hover:opacity-100 transition duration-500
                   bg-white/20 dark:bg-purple-300/20 blur-sm"></div>


       <!-- Slider -->
       <div id="toggle-circle"
         class="absolute left-1 top-1 w-6 h-6 rounded-full
                bg-white dark:bg-gray-800
                flex items-center justify-center
                transform transition-all duration-500 ease-in-out
                dark:translate-x-6 shadow-md">


         <!-- Moon -->
         <svg xmlns="http://www.w3.org/2000/svg"
           class="h-4 w-4 hidden dark:block text-white
                  drop-shadow-[0_0_6px_rgba(255,255,255,0.7)]
                  bg-purple-300 rounded-full p-0.5
                  group-hover:animate-spin"
           fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
             d="M21 12.79A9 9 0 1111.21 3A7 7 0 0021 12.79z"/>
         </svg>


         <!-- Sun -->
         <svg xmlns="http://www.w3.org/2000/svg"
           class="h-4 w-4 block dark:hidden text-yellow-400
                  drop-shadow-[0_0_10px_rgba(255,200,0,0.9)]
                  group-hover:animate-spin"
           fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
             d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M6.05 6.05L4.636 4.636m12.728 0l-1.414 1.414M6.05 17.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8"/>
         </svg>


       </div>
     </button>


     <!-- Account Dropdown -->
     <div class="relative group hidden md:block">
 <button class="flex items-center gap-2 hover:text-gray-200 dark:hover:text-gray-300 focus:outline-none">


   {% if current_user.is_authenticated and current_user.profile_picture %}
     <img src="{{ current_user.profile_picture }}"
          class="w-8 h-8 rounded-full object-cover border-2 border-white dark:border-purple-300"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">


     <div class="w-8 h-8 rounded-full bg-green-800 dark:bg-[#7b2cbf] hidden items-center justify-center text-sm font-bold">
       {{ current_user.name[0] | upper }}
     </div>


   {% else %}
     <div class="w-8 h-8 rounded-full bg-green-800 dark:bg-[#7b2cbf] flex items-center justify-center">
       <span class="text-sm font-bold">
         {% if current_user.is_authenticated %}
           {{ current_user.name[0] | upper }}
         {% else %}
           ?
         {% endif %}
       </span>
     </div>
   {% endif %}


   {% if current_user.is_authenticated %}
     <span>Hi {{ current_user.name }}</span>
   {% else %}
     <span>Account</span>
   {% endif %}


   <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
   </svg>
 </button>




       <!-- Dropdown -->
       <ul class="absolute right-0 w-40
                  bg-green-800 dark:bg-[#1b1730]
                  border border-green-700 dark:border-[#40376E]
                  rounded-md
                  opacity-0 invisible group-hover:opacity-100 group-hover:visible
                  transition duration-200">


         {% if not current_user.is_authenticated %}
         <li><a href="/login" class="block px-4 py-2 hover:bg-green-700 font-semibold dark:hover:bg-[#40376E]">Sign In</a></li>
         <li><a href="/signup" class="block px-4 py-2 hover:bg-green-700 font-semibold dark:hover:bg-[#40376E]">Register</a></li>
         {% else %}
         <li>
           <a href="/profile_page" class="block px-4 font-semibold py-2 hover:bg-green-700 dark:hover:bg-[#40376E]">
             Profile
           </a>
         </li>


         <li>
           <a href="/restaurant-dashboard" class="block px-4 py-2 font-semibold hover:bg-green-700 dark:hover:bg-[#40376E]">
             Dashboard
           </a>
         </li>


         <li>
           <a href="/logout" class="block px-4 py-2 font-semibold hover:bg-green-700 dark:hover:bg-red-600">
             Logout
           </a>
         </li>
         {% endif %}




       </ul>
     </div>


     <!-- Mobile Menu Button -->
     <button id="mobile-menu-button" class="md:hidden">
       <svg xmlns="http://www.w3.org/2000/svg"
         class="h-6 w-6 hover:text-yellow-300 dark:hover:text-yellow-200 transition"
         fill="none" viewBox="0 0 24 24"
         stroke="currentColor">
         <path stroke-linecap="round"
           stroke-linejoin="round"
           stroke-width="2"
           d="M4 6h16M4 12h16M4 18h16"/>
       </svg>
     </button>
   </div>
 </div>


 <!-- Mobile Menu -->
 <div id="mobile-menu" class="hidden bg-green-800 dark:bg-[#1b1730]">
   <ul class="flex flex-col px-6 py-4 space-y-4">
     <li><a class="hover:text-yellow-300 dark:hover:text-yellow-200 transition" href="/map">Map</a></li>
     <li><a class="hover:text-yellow-300 dark:hover:text-yellow-200 transition" href="/donations">Donate</a></li>


     {% if current_user.is_authenticated %}
     <li><a class="hover:text-yellow-300 dark:hover:text-yellow-200 transition" href="/profile_page">Profile</a></li>
     <li><a class="hover:text-red-300 dark:hover:text-red-400 transition" href="/logout">Logout</a></li>
     <li><a href="/restaurant-dashboard" class="hover:text-red-300 dark:hover:text-red-400 transition">Dashboard</a></li>


     {% else %}
     <li><a class="hover:text-yellow-300 dark:hover:text-yellow-200 transition" href="/login">Sign In</a></li>
     <li><a class="hover:text-yellow-300 dark:hover:text-yellow-200 transition" href="/signup">Register</a></li>
     {% endif %}
   </ul>
 </div>
</nav>


<!-- Script (unchanged except cleaned) -->
<script>
 const menuButton = document.getElementById('mobile-menu-button');
 const mobileMenu = document.getElementById('mobile-menu');


 if (menuButton && mobileMenu) {
   menuButton.addEventListener('click', () => {
     mobileMenu.classList.toggle('hidden');
   });
 }


 const themeToggle = document.getElementById("theme-toggle");


 if (themeToggle) {
   themeToggle.addEventListener("click", () => {
     const isDark = document.documentElement.classList.toggle("dark");
     localStorage.setItem("theme", isDark ? "dark" : "light");
   });
 }
</script>

