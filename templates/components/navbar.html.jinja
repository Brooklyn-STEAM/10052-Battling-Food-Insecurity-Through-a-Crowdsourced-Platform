      <li><a id="nav-map" class="hover:text-yellow-300 transition" href="/map">Map</a></li>
      <li><a id="nav-donate" class="hover:text-yellow-300 transition" href="/donate">Donate</a></li>
      <li><a id="nav-partner" class="hover:text-yellow-300 transition" href="/restaurants-connect">Partner with Us</a></li>
      <li><a id="nav-about" class="hover:text-yellow-300 transition" href="/about">About Us</a></li>
