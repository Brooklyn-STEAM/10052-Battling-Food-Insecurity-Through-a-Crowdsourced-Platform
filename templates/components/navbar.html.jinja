               dark:from-[#40376E] dark:to-[#5a4fd6]
               transition-all duration-500 ease-in-out
               shadow-inner hover:shadow-lg active:scale-95">

        <div class="absolute inset-0 rounded-full opacity-0
                    group-hover:opacity-100 transition duration-500
                    bg-white/20 dark:bg-purple-300/20 blur-sm"></div>

        <div id="toggle-circle"
          class="absolute left-1 top-1 w-5 h-5 sm:w-6 sm:h-6 rounded-full
                 bg-white dark:bg-gray-800
                 flex items-center justify-center
                 transform transition-all duration-500 ease-in-out
                 dark:translate-x-5 sm:dark:translate-x-6 shadow-md">

          <!-- Moon -->
          <svg xmlns="http://www.w3.org/2000/svg"
            class="h-3 w-3 sm:h-4 sm:w-4 hidden dark:block text-white
                   drop-shadow-[0_0_6px_rgba(255,255,255,0.7)]
                   bg-purple-300 rounded-full p-0.5
                   group-hover:animate-spin"
            fill="none" viewBox="0 0 24 24" stroke="currentColor">

            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 12.79A9 9 0 1111.21 3A7 7 0 0021 12.79z"/>
          </svg>

          <!-- Sun -->
          <svg xmlns="http://www.w3.org/2000/svg"
            class="h-3 w-3 sm:h-4 sm:w-4 block dark:hidden text-yellow-400
                   drop-shadow-[0_0_10px_rgba(255,200,0,0.9)]
                   group-hover:animate-spin"
            fill="none" viewBox="0 0 24 24" stroke="currentColor">

            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M6.05 6.05L4.636 4.636m12.728 0l-1.414 1.414M6.05 17.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8"/>
          </svg>
        </div>
      </button>
      <!-- Desktop Profile -->
      <div class="relative group hidden md:block">
        <button class="flex items-center gap-2 hover:text-gray-200 dark:hover:text-gray-300 focus:outline-none py-2">

          {% if current_user.is_authenticated and current_user.profile_picture %}
            <img src="{{ current_user.profile_picture }}"
                 class="w-8 h-8 rounded-full object-cover border-2 border-white dark:border-purple-300"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">

            <div class="w-8 h-8 rounded-full bg-green-800 dark:bg-[#7b2cbf] hidden items-center justify-center text-sm font-bold">
              {{ current_user.name[0] | upper }}
            </div>

          {% else %}

            <div class="w-8 h-8 rounded-full bg-green-800 dark:bg-[#7b2cbf] flex items-center justify-center">
              <span class="text-sm font-bold">
                {% if current_user.is_authenticated %}
                  {{ current_user.name[0] | upper }}
                {% else %}
                  ?
                {% endif %}
              </span>
            </div>

          {% endif %}

          <span class="font-semibold">
            {% if current_user.is_authenticated %}
              Hi {{ current_user.name }}
            {% else %}
              Account
            {% endif %}
          </span>

          <svg class="w-4 h-4 transition-transform group-hover:rotate-180"
               fill="none"
               stroke="currentColor"
               viewBox="0 0 24 24">

            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"/>
