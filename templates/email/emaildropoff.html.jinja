<!DOCTYPE html>
<html>
<head>
<style>
@media (prefers-color-scheme: dark) {
    body {
        background-color: #0f0b1f !important;
    }

    .email-wrapper {
        background-color: #0f0b1f !important;
    }

    .email-container {
        background-color: #1a1333 !important;
        border-color: #2b1f55 !important;
    }

    .header {
        background: linear-gradient(135deg, #8b5cf6, #6d28d9) !important;
    }

    .content {
        color: #e5e7eb !important;
    }

    .content h2 {
        color: #ffffff !important;
    }

    .summary-box {
        background-color: #2a1f4a !important;
        border-color: #6d28d9 !important;
    }

    .summary-title {
        color: #c4b5fd !important;
    }

    .accent-text {
        color: #a78bfa !important;
    }

    .button {
        background-color: #8b5cf6 !important;
    }

    .footer {
        background-color: #0f0b1f !important;
        color: #9ca3af !important;
    }
}
</style>
</head>

<body class="email-wrapper" style="margin: 0; padding: 0; background-color: #f8fafc; font-family: sans-serif;">
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f8fafc; padding: 20px;">
        <tr>
            <td align="center">
                <table class="email-container" width="600" border="0" cellspacing="0" cellpadding="0"
                    style="background-color: #ffffff; border-radius: 16px; overflow: hidden; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                    
                    <!-- HEADER -->
                    <tr>
                        <td class="header" style="background: linear-gradient(135deg, #3dd16a); padding: 40px; text-align: center;">
                            <h1 style="margin: 0; color: #ffffff; font-size: 28px;">FridgeNet</h1>
                            <p style="margin: 10px 0 0 0; color: #ffffff; opacity: 0.9;">Community Support System</p>
                        </td>
                    </tr>

                    <!-- CONTENT -->
                    <tr>
                        <td class="content" style="padding: 40px; color: #1e1b2e; line-height: 1.6;">
                            <h2 style="margin-top: 0; color: #1e1b2e;">Donation Scheduled!</h2>
                            <p>Hi <strong>{{ full_name }}</strong>,</p>
                            <p>Thank you for contributing to the community. Your donation helps keep our local fridges stocked for those who need it most.</p>

                            <!-- SUMMARY BOX -->
                            <div class="summary-box" style="background-color: #f3f0ff; border: 1px solid #ddd6fe; border-radius: 12px; padding: 20px; margin: 25px 0;">
                                
                                <h3 class="summary-title" style="margin-top: 0; color: #339614; font-size: 16px; text-transform: uppercase; letter-spacing: 1px;">
                                    Drop-off Summary
                                </h3>

                                <p style="margin: 5px 0;"><strong>Fridge:</strong> {{ fridge_name }}</p>
                                <p style="margin: 5px 0;"><strong>Item:</strong> {{ item_name }}</p>
                                <p style="margin: 5px 0;"><strong>Quantity:</strong> {{ quantity }}</p>
                                <p style="margin: 5px 0;">
                                    <strong>Dropoff Date:</strong>
                                    <span class="accent-text" style="color: #339614; font-weight: bold;">
                                        {{ dropoff_date }}
                                    </span>
                                </p>

                                {% if notes and notes.strip() %}
                                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px dashed #ddd6fe;">
                                    <p style="margin: 0; font-size: 14px; color: #339614;"><strong>Your Notes:</strong></p>
                                    <p style="margin: 5px 0; font-style: italic; color: #4b5563;">"{{ notes }}"</p>
                                </div>
                                {% endif %}
                            </div>

                            <p><strong>Quick Reminders:</strong></p>
                            <ul style="padding-left: 20px;">
                                <li>Ensure items are factory-sealed or properly labeled.</li>
                                <li>Check the "Use By" dates before dropping off.</li>
                                <li>Place items neatly inside the fridge.</li>
                            </ul>

                            <!-- BUTTON -->
                            <div style="text-align: center; margin-top: 30px;">
                                <a href="{{ url_for('map_page', _external=True) }}"
                                   class="button"
                                   style="background-color: #ed6e2a; color: #ffffff; padding: 12px 25px; text-decoration: none; border-radius: 8px; font-weight: bold; display: inline-block;">
                                   View Fridge Map
                                </a>
                            </div>
                        </td>
                    </tr>

                    <!-- FOOTER -->
                    <tr>
                        <td class="footer" style="background-color: #1e1b2e; padding: 20px; text-align: center; color: #a4aebc; font-size: 12px;">
                            <p style="margin: 0;">&copy; 2026 FridgeNet. Supporting local communities together.</p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>
</html>