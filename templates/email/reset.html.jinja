```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body, table, td, a {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table, td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        @media (prefers-color-scheme: dark) {
            body, .email-wrapper {
                background-color: #0f0b1f !important;
            }

            .email-container {
                background-color: #1a1333 !important;
                border-color: #2b1f55 !important;
            }

            .header {
                background: linear-gradient(135deg, #8b5cf6, #6d28d9) !important;
            }

            .content {
                color: #e5e7eb !important;
            }

            .content h2,
            .content p strong {
                color: #ffffff !important;
            }

            .button {
                background-color: #8b5cf6 !important;
            }

            .footer {
                background-color: #0f0b1f !important;
                color: #9ca3af !important;
            }
        }
    </style>
</head>

<body class="email-wrapper"
      style="margin:0; padding:0; background-color:#f8fafc;
             font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">

<table width="100%" border="0" cellspacing="0" cellpadding="0"
       style="background-color:#f8fafc; padding:20px;">

<tr>
<td align="center">

<table class="email-container"
       width="100%"
       border="0"
       cellspacing="0"
       cellpadding="0"
       style="max-width:600px;
              background-color:#ffffff;
              border-radius:16px;
              overflow:hidden;
              border:1px solid #e2e8f0;
              box-shadow:0 4px 6px rgba(0,0,0,0.05);">

    <!-- HEADER -->
    <tr>
        <td class="header"
            style="background:#3dd16a;
                   background:linear-gradient(135deg,#3dd16a 0%,#2eb357 100%);
                   padding:40px;
                   text-align:center;">

            <h1 style="margin:0;
                       color:#ffffff;
                       font-size:28px;
                       letter-spacing:-0.5px;">

                FridgeNet

            </h1>

            <p style="margin:10px 0 0 0;
                      color:#ffffff;
                      opacity:0.9;
                      font-size:14px;
                      text-transform:uppercase;
                      letter-spacing:1px;">

                Password Reset Request

            </p>
        </td>
    </tr>

    <!-- CONTENT -->
    <tr>
        <td class="content"
            style="padding:40px;
                   color:#1e1b2e;
                   line-height:1.6;
                   font-size:16px;">

            <h2 style="margin-top:0;
                       color:#1e1b2e;
                       font-size:22px;">

                Reset Your Password

            </h2>

            <p>
                Hi <strong>{{ name }}</strong>,
            </p>

            <p>
                We received a request to reset your FridgeNet account password.
            </p>

            <p>
                Click the button below to create a new password:
            </p>

            <!-- BUTTON -->
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tr>
                    <td align="center">

                        <a href="{{ reset_link }}"
                           class="button"
                           style="background-color:#3dd16a;
                                  color:#ffffff;
                                  padding:14px 30px;
                                  text-decoration:none;
                                  border-radius:10px;
                                  font-weight:bold;
                                  display:inline-block;
                                  box-shadow:0 4px 10px rgba(61,209,106,0.3);">

                            Reset Password

                        </a>

                    </td>
                </tr>
            </table>

            <p style="margin-top:30px;">
                This link expires in <strong>1 hour</strong>.
            </p>

            <p>
                If you did not request this reset, you can safely ignore this email.
            </p>

        </td>
    </tr>

    <!-- FOOTER -->
    <tr>
        <td class="footer"
            style="background-color:#1e1b2e;
                   padding:30px 20px;
                   text-align:center;
                   color:#a4aebc;
                   font-size:12px;">

            <p style="margin:0; letter-spacing:0.5px;">
                &copy; 2026 FridgeNet. Supporting local communities together.
            </p>

            <p style="margin:10px 0 0 0;">
                This email was sent because a password reset was requested.
            </p>

        </td>
    </tr>

</table>

</td>
</tr>
</table>

</body>
</html>
