<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <title>Report a Problem | FridgeNet</title>
</head>

<body class="bg-gray-50 min-h-screen font-sans antialiased">
    {% include "components/navbar.html.jinja" %}

    <main class="max-w-7xl mx-auto px-4 py-12">
        <div class="flex flex-col lg:flex-row items-center lg:items-start gap-12">

            <!-- Left Side: Form -->
            <div class="w-full lg:w-1/2">
                <div class="mb-8">
                    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">REPORT A PROBLEM</h1>
                    <p class="text-gray-600 mt-2">Our team will investigate the issue immediately.</p>
                </div>

                <form action="/report/{{ fridge['ID'] }}" method="POST" ...
                    class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 space-y-5">
                    <label class="text-2xl font-extrabold text-gray-900 py-2 tracking-tight"> Status of the Fridge</label>
<div class="text-gray-600 font-semibold p-2">
<form id="fridgeStatusForm">
  <label><input type="radio" name="fridgeStatus" value="empty"> Empty</label><br>
  <label><input type="radio" name="fridgeStatus" value="Few"> Few Items</label><br>
  <label><input type="radio" name="fridgeStatus" value="half_stock"> Half Stock</label><br>
  <label><input type="radio" name="fridgeStatus" value="full"> Full</label><br>
  <label><input type="radio" name="fridgeStatus" value="maintenance_required"> Maintenance Required</label><br>
  <label><input type="radio" name="fridgeStatus" value="offline"> Offline</label>
</form>
</div>
<br>
                    <div>
                        <label for="fridge_id" class="block text-sm font-semibold text-gray-700 mb-1">Fridge Name</label>
                        <input type="text" name="fridge_id" id="fridge_id" required placeholder="e.g. FN-2024-01"
                            class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-green-500/20 focus:border-green-600 transition-all">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="priority"
                                class="block text-sm font-semibold text-gray-700 mb-1">Priority</label>
                            <select name="priority" id="priority" required
                                class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-green-500/20 focus:border-green-600">
                                <option value="">Select...</option>
                                <option value="low">Low</option>
                                <option value="medium">Medium</option>
                                <option value="high">High</option>
                            </select>
                        </div>
                        <div>
                            <label for="reproducibility"
                                class="block text-sm font-semibold text-gray-700 mb-1">Reproducibility</label>
                            <select name="reproducibility" id="reproducibility" required
                                class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-green-500/20 focus:border-green-600">
                                <option value="">Select...</option>
                                <option value="always">Always</option>
                                <option value="sometimes">Sometimes</option>
                                <option value="rarely">Rarely</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="issue_description" class="block text-sm font-semibold text-gray-700 mb-1">Issue
                            Description</label>
                        <textarea name="issue_description" id="issue_description" rows="4" required
                            placeholder="What happened?"
                            class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-green-500/20 focus:border-green-600"></textarea>
                    </div>

                    <div>
                        <label for="contact_info" class="block text-sm font-semibold text-gray-700 mb-1">Contact Info
                            <span class="text-gray-400 font-normal">(Optional)</span></label> <input type="text"
                            name="contact_info" id="contact_info" placeholder="Email or Phone"
                            class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-green-500/20 focus:border-green-600">
                    </div>
<br>
                    <button type="submit"
                        class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg shadow-green-200 transition-all active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-green-500/50">
                        Submit Report
                    </button>


                </form>
            </div>

            <!-- Right Side: Info & Image -->
            <div class="w-full lg:w-1/2 space-y-8">
                <div class="relative group">
                    <div
                        class="absolute -inset-3 to-emerald-500 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000">
                    </div>
                    <img src="{{ fridge['Image'] }}" alt="{{ fridge['Name'] }} Image">
                </div>

                <div class="bg-green-50 p-6 rounded-xl border border-green-100 text-center">
                <p class="text-green-900 font-medium text-lg">{{fridge['Name']}}</p>
                <br>
                    <h3 class="text-green-800 font-bold uppercase tracking-widest text-xs mb-2">Location</h3>
                    <p class="text-green-900 font-medium text-lg">{{fridge['Address']}}</p>
                </div>
            </div>

        </div>
    </main>
<script>
    const radios = document.querySelectorAll('input[name="fridgeStatus"]');
const statusText = document.getElementById("statusText");

radios.forEach(radio => {
  radio.addEventListener("change", (e) => {
    const selectedStatus = e.target.value;

    // update UI
    statusText.textContent = selectedStatus;

    // example API call to update backend
    fetch("/api/fridge/status", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ status: selectedStatus })
    });
  });
});
</script>
</body>

</html>