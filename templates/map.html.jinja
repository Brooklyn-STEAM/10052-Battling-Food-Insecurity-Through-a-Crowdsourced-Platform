                window.routeToFridge(
                    fLat,
                    fLng
                );

                if (isMobile()) {
                    hideSidebar();
                }
            };

        DOM.favoritesList.appendChild(li);
    });
}


/* =========================================================
   RECENTS
========================================================= */
function saveRecentlyViewed(fridge) {

    let recent =
        JSON.parse(
            localStorage.getItem("recentFridges")
        ) || [];

    recent = recent.filter(
        f => f.id !== (
            fridge.id || fridge.ID
        )
    );

    recent.unshift({
        id: fridge.id || fridge.ID,
        name: fridge.name || fridge.Name
    });

    recent = recent.slice(0, 5);

    localStorage.setItem(
        "recentFridges",
        JSON.stringify(recent)
    );

    renderRecent();
}

function renderRecent() {

    if (!DOM.recentList) return;

    const data =
        JSON.parse(
            localStorage.getItem("recentFridges")
        ) || [];

    clearHTML(DOM.recentList);

    if (!data.length) {

        DOM.recentList.innerHTML = `
<li class="p-3 text-xs text-gray-400 italic text-center bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] rounded-xl">
    No recent activity
</li>
`;

        return;
    }

    data.forEach(f => {

        const li =
            document.createElement("li");

        li.className = `
p-3 bg-gray-50 dark:bg-[#2a2545]
border border-gray-200 dark:border-[#40376E]
rounded-xl flex justify-between items-center
cursor-pointer hover:bg-green-50
dark:hover:bg-[#40376E]
transition-all
`;

        li.innerHTML = `
<div class="flex items-center gap-2 flex-grow">

    <span class="text-xs">🕒</span>

    <span class="text-sm font-semibold text-gray-800 dark:text-gray-200 truncate">
        ${f.name}
    </span>

</div>

<span class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase">
    View
</span>
`;

        li.onclick = () => {
            window.location.href =
                `/individfridge/${f.id}`;
        };

        DOM.recentList.appendChild(li);
    });
}


/* =========================================================
   CLEAR / UNDO RECENTS
========================================================= */
DOM.clearRecents.onclick = () => {

    const current =
        localStorage.getItem("recentFridges");

    if (!current) return;

    state.recentsBackup = current;

    localStorage.removeItem("recentFridges");

    renderRecent();

    show(DOM.undoRecents);
    hide(DOM.clearRecents);

    let timeLeft = 3;

    DOM.undoRecents.textContent =
        `Undo (${timeLeft})`;

    clearTimeout(state.undoTimeout);
    clearInterval(state.undoInterval);

    state.undoInterval = setInterval(() => {

        timeLeft--;

        if (timeLeft > 0) {

            DOM.undoRecents.textContent =
                `Undo (${timeLeft})`;

        } else {

            DOM.undoRecents.textContent =
                "Undo";

            clearInterval(state.undoInterval);
        }

    }, 1000);

    state.undoTimeout = setTimeout(() => {

        state.recentsBackup = null;

        hide(DOM.undoRecents);
        show(DOM.clearRecents);

        DOM.undoRecents.textContent =
            "Undo";

        clearInterval(state.undoInterval);

    }, 3000);
};

DOM.undoRecents.onclick = () => {

    if (!state.recentsBackup) return;

    localStorage.setItem(
        "recentFridges",
        state.recentsBackup
    );

    renderRecent();

    state.recentsBackup = null;

    hide(DOM.undoRecents);
    show(DOM.clearRecents);

    clearTimeout(state.undoTimeout);
    clearInterval(state.undoInterval);
};


