<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Community Fridge Map</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>
    <style>
        .leaflet-routing-container { display: none; }
        #itinerary-container .leaflet-routing-alt {
            max-height: 300px;
            overflow-y: auto;
            background: transparent !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            font-size: 13px;
            color: #166534;
        }
        #itinerary-container tr {
            display: flex;
            padding: 8px 0;
            border-bottom: 1px solid #e2e8f0;
            align-items: center;
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: 'class'
        }
    </script>


    <script>
            (function () {
                const saved = localStorage.getItem("theme");

                if (saved === "dark") {
                    document.documentElement.classList.add("dark");
                } else if (saved === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                    document.documentElement.classList.toggle("dark", prefersDark);
                }
            })();
    </script>

    <style>
        /* INPUT */
        .input {
            width: 100%;
            padding: 0.75rem;
            border-radius: 0.75rem;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            transition: 0.25s;
        }

        .input:focus {
            border-color: #a78bfa;
            box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.3);
        }

        /* FORM CARD (purple theme) */
        .form-card {
            background: linear-gradient(135deg, #ffffff, #f3f0ff);
            border: 1px solid #cac2d2;
        }

        .dark .form-card {
            background: linear-gradient(135deg, #1e1b2e, #2a2545);
            border: 1px solid #40376E;
        }

        /* DARK MODE */
        .dark .input {
            background: #2a2545;
            border-color: #40376E;
            color: #fff;
        }

        .dark .dropdown {
            background: #2a2545;
            border-color: #40376E;
        }

        html {
            scroll-behavior: smooth;
        }

        html {
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        nav {
    position: relative; /* or fixed/sticky depending on your navbar design */
    z-index: 2000;      /* Higher than Leaflet's default z-index */
}
    </style>
</head>

<body class="bg-gray-100 dark:bg-[#0f0c1f] text-gray-900 dark:text-gray-100 font-sans">

{% include "components/navbar.html.jinja" %}

<div class="relative w-full h-screen overflow-hidden flex flex-col md:flex-row">

    <!-- MAP (UNCHANGED) -->
    <div id="map" class="absolute inset-0 md:relative md:w-2/3 h-full z-0 order-1 md:order-2"></div>

    <!-- FLOAT BUTTON -->
    <button id="toggle-sidebar"
        class="md:hidden fixed bottom-6 right-6 z-[1001]
        bg-green-600 text-white p-4 rounded-full shadow-2xl
        dark:bg-purple-600 dark:hover:bg-purple-700 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>

    <!-- SIDEBAR -->
    <aside id="sidebar"
        class="fixed inset-x-0 bottom-0 z-[1000] w-full h-[70vh]
        bg-white dark:bg-[#1b1730]
        transition-transform duration-300 transform translate-y-full
        md:translate-y-0 md:static md:w-1/3 md:h-full
        overflow-hidden flex flex-col
        border-t md:border-t-0 md:border-r
        border-gray-200 dark:border-[#40376E]">

        <!-- CLOSE HANDLE -->
        <div id="close-sidebar"
            class="md:hidden w-full flex flex-col items-center py-3 cursor-pointer">
            <div class="w-12 h-1.5 bg-gray-300 dark:bg-gray-600 rounded-full mb-1"></div>
            <span class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase">
                Close List
            </span>
        </div>

        <div class="p-6 overflow-y-auto flex-grow">

            <!-- ROUTE BOX -->
            <div id="routing-directions"
                class="hidden mb-6 p-4 rounded-xl border
                bg-green-50 border-green-200
                dark:bg-[#2a2545] dark:border-[#40376E]">

                <div class="flex justify-between items-center mb-2 border-b pb-2
                    border-green-200 dark:border-[#40376E]">
                    <h3 class="font-bold text-green-800 dark:text-purple-300 text-sm uppercase">
                        Route Instructions
                    </h3>
                    <button onclick="window.clearRoute()"
                        class="text-[10px] text-red-500 font-bold hover:underline">
                        CLEAR
                    </button>
                </div>

                <div id="itinerary-container"></div>
            </div>

            <h2 class="text-2xl font-bold mb-4 dark:text-white">
                Nearby Fridges
            </h2>

            <!-- START LOCATION -->
            <div class="mb-4">
                <label class="font-semibold text-xs text-gray-600 dark:text-gray-400 block mb-1">
                    Starting Location
                </label>

                <div class="flex gap-2">
                    <input type="text" id="start-location"
                        placeholder="Enter address"
                        class="flex-grow p-2 border rounded-lg text-sm
                        bg-gray-50 dark:bg-[#2a2545]
                        border-gray-200 dark:border-[#40376E]
                        text-gray-900 dark:text-white
                        outline-none focus:ring-2 focus:ring-green-500" />

                    <button id="set-start"
                        class="bg-green-500 text-white px-3 py-1 rounded-lg font-bold text-sm
                        dark:bg-purple-600 dark:hover:bg-purple-700">
                        Set
                    </button>
                </div>
            </div>

            <!-- SEARCH -->
            <input type="text" id="fridge-search"
                placeholder="Search fridges..."
                class="w-full p-2 border rounded-lg mb-4 text-sm
                bg-gray-50 dark:bg-[#2a2545]
                border-gray-200 dark:border-[#40376E]
                text-gray-900 dark:text-white outline-none" />

            <!-- TRANSPORT -->
            <div class="grid grid-cols-3 gap-2 mb-6">

                <label class="cursor-pointer">
                    <input type="radio" name="transport" value="foot" class="hidden peer" checked>
                    <div class="p-2 border-2 rounded-xl text-center text-[10px] font-bold uppercase
                        border-gray-200 dark:border-[#40376E]
                        peer-checked:border-green-600
                        peer-checked:bg-green-50 dark:peer-checked:bg-[#2a2545]">
                        Walk
                    </div>
                </label>

                <label class="cursor-pointer">
                    <input type="radio" name="transport" value="bicycle" class="hidden peer">
                    <div class="p-2 border-2 rounded-xl text-center text-[10px] font-bold uppercase
                        border-gray-200 dark:border-[#40376E]
                        peer-checked:border-green-600
                        peer-checked:bg-green-50 dark:peer-checked:bg-[#2a2545]">
                        Bike
                    </div>
                </label>

                <label class="cursor-pointer">
                    <input type="radio" name="transport" value="car" class="hidden peer">
                    <div class="p-2 border-2 rounded-xl text-center text-[10px] font-bold uppercase
                        border-gray-200 dark:border-[#40376E]
                        peer-checked:border-green-600
                        peer-checked:bg-green-50 dark:peer-checked:bg-[#2a2545]">
                        Drive
                    </div>
                </label>
            </div>

            <!-- FAVORITES -->
            <h3 class="text-sm font-bold mb-2 text-gray-500 dark:text-gray-400">
                Favorites
            </h3>
            <ul id="favorites-list" class="space-y-2 mb-4"></ul>

            <!-- RECENT -->
            <h3 class="text-md font-bold mb-2 text-gray-500 dark:text-gray-400">
                Recently Viewed
            </h3>
            <ul id="recent-list" class="space-y-2 mb-4 text-sm font-semibold"></ul>

            <!-- LIST -->
            <ul id="fridge-list" class="space-y-3 font-semibold pb-10"></ul>

        </div>
    </aside>
</div>
<script>
    
const sidebar = document.getElementById('sidebar');
const toggleBtn = document.getElementById('toggle-sidebar');
const closeBtn = document.getElementById('close-sidebar');

// Sidebar Toggle Logic
toggleBtn.onclick = () => { 
    sidebar.classList.remove('translate-y-full'); 
    toggleBtn.classList.add('hidden'); 
};
closeBtn.onclick = () => { 
    sidebar.classList.add('translate-y-full'); 
    toggleBtn.classList.remove('hidden'); 
};

// Map Initialization
const map = L.map('map').setView([40.7128, -74.0060], 12);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
L.control.zoom({ position: 'topright' }).addTo(map); 


const userIcon = L.icon({ iconUrl: "/static/images/pin.png", iconSize: [35, 35] });
const fridgeIcon = L.icon({ iconUrl: "/static/images/fridge.png", iconSize: [45, 45] });

let userLat, userLng, userMarker;
let currentRouteLayer = null; // Stores the polyline
let currentTargetFridge = null;
let allFridges = [], fridgeMarkers = [];

// Profile Map for Geoapify
const profileMap = {
    "foot": "walk",
    "bicycle": "bicycle",
    "car": "drive"
};

function getDistance(lat1, lon1, lat2, lon2) {
    const R = 3958.8;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
    return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)));
}

function setUserLocation(lat, lng) {
    userLat = lat; userLng = lng;
    if (userMarker) map.removeLayer(userMarker);
    userMarker = L.marker([lat, lng], { icon: userIcon }).addTo(map).bindPopup("Your Location").openPopup();
    map.setView([lat, lng], 13);
    renderFridges(allFridges);
}

// THE FIXED ROUTING FUNCTION
window.routeToFridge = function(lat, lng) {
    if (!userLat || !userLng) return alert("Please set your starting location first.");

    currentTargetFridge = { lat, lng };

    if (currentRouteLayer) map.removeLayer(currentRouteLayer);

    const isMobile = window.innerWidth < 768;
    const directionsContainer = document.getElementById('routing-directions');
    const itineraryContainer = document.getElementById('itinerary-container');
    const mobileItinerary = document.getElementById('mobile-itinerary-container');
    const modal = document.getElementById('directions-modal');
    
    // Show loading state
    const loadingHtml = "<p class='text-xs text-green-600 animate-pulse'>Calculating route...</p>";
    if (isMobile) {
        modal.classList.remove('hidden');
        mobileItinerary.innerHTML = loadingHtml;
    } else {
        directionsContainer.classList.remove('hidden');
        itineraryContainer.innerHTML = loadingHtml;
    }

    const selectedMode = document.querySelector('input[name="transport"]:checked').value;
    const geoMode = profileMap[selectedMode] || "walk";
    const apiKey = "364fdb68178f4a09b69ef7df5051e13b";

    const url = `https://api.geoapify.com/v1/routing?waypoints=${userLat},${userLng}|${lat},${lng}&mode=${geoMode}&apiKey=${apiKey}`;

    fetch(url)
        .then(res => res.json())
        .then(data => {
            if (!data.features || data.features.length === 0) throw new Error("No route found");

            const routeData = data.features[0];
            const coords = routeData.geometry.coordinates[0].map(c => [c[1], c[0]]);
            currentRouteLayer = L.polyline(coords, {color: '#16a34a', weight: 5, opacity: 0.8}).addTo(map);
            map.fitBounds(currentRouteLayer.getBounds(), { padding: [50, 50] });

            const distMi = (routeData.properties.distance * 0.000621371).toFixed(1);
            const timeMin = Math.round(routeData.properties.time / 60);
            
            // Build the HTML for the steps
            let stepsHtml = `
<div class="mb-4 p-4 bg-green-600 dark:bg-purple-600 rounded-xl text-white shadow-md">
        <div class="flex justify-between items-center gap-2">
            <div class="flex flex-col">
                <span class="text-[10px] uppercase opacity-80 font-bold">Distance</span>
                <span class="text-lg font-extrabold leading-none">${distMi} mi</span>
            </div>
            <div class="h-8 w-px bg-white/20"></div>
            <div class="flex flex-col text-right">
                <span class="text-[10px] uppercase opacity-80 font-bold">Est. Time</span>
                <span class="text-lg font-extrabold leading-none">${timeMin} mins</span>
            </div>
        </div>
    </div>
`;

            routeData.properties.legs[0].steps.forEach((step, i) => {
                const stepDist = (step.distance * 0.000621371).toFixed(2);
                stepsHtml += `
                    <div class="text-sm py-3 border-b border-gray-100 dark:border-[#40376E] last:border-0 flex gap-3">
                        <span class="font-bold text-green-600 dark:text-purple-400">${i + 1}.</span> 
                        <div class="flex-grow">
                            <p class="text-gray-800 dark:text-gray-200">${step.instruction.text}</p>
                            <span class="text-[10px] text-gray-400 dark:text-gray-200 font-bold uppercase">${stepDist}</span>
                        </div>
                    </div>
                `;
            });

            // Inject into the correct container
            if (isMobile) {
                mobileItinerary.innerHTML = stepsHtml;
            } else {
                itineraryContainer.innerHTML = stepsHtml;
            }
        })
        .catch(err => {
            const errorHtml = "<p class='text-xs text-red-500'>Route not found.</p>";
            isMobile ? mobileItinerary.innerHTML = errorHtml : itineraryContainer.innerHTML = errorHtml;
        });
};

// Add this helper function
window.closeDirectionsModal = function() {
    document.getElementById('directions-modal').classList.add('hidden');
};

window.clearRoute = function() {
    if (currentRouteLayer) map.removeLayer(currentRouteLayer);
    document.getElementById('routing-directions').classList.add('hidden');
    currentTargetFridge = null;
};

function renderFridges(fridges) {
    const list = document.getElementById("fridge-list");
    list.innerHTML = "";
    fridgeMarkers.forEach(m => map.removeLayer(m));
    fridgeMarkers = [];

    const fridgesWithData = fridges.map(f => ({
        ...f,
        distance: userLat ? getDistance(userLat, userLng, f.lat, f.lng) : null
    })).sort((a, b) => (a.distance || 999) - (b.distance || 999));

   fridgesWithData.forEach(f => {

    // ✅ Marker (FIXED)
    const marker = L.marker([f.lat, f.lng], { icon: fridgeIcon })
        .addTo(map)
.bindPopup(`
    <div class="p-3 text-center rounded-xl
        text-gray-900 dark:text-white">

        <b class="text-lg text-black">${f.name}</b><br>

        <span class="text-[10px] text-gray-500 dark:text-gray-600 uppercase">
            ${f.status || 'Active'}
        </span><br>

        <button onclick="window.routeToFridge(${f.lat},${f.lng})"
            class="bg-green-600 dark:bg-purple-600
            hover:bg-green-700 dark:hover:bg-purple-700
            text-white px-3 py-1 rounded-lg mt-2 w-full font-bold transition">
            Get Directions
        </button>
    </div>
`);

    // ✅ Double click on marker → go to page
    marker.on('dblclick', () => {
        window.location.href = `/individfridge/${f.id}`;
    });

    fridgeMarkers.push(marker);

    // ✅ Sidebar item
    const li = document.createElement("li");
    li.className = "p-4 bg-gray-50 dark:bg-[#2a2545] border border-transparent dark:border-[#40376E] rounded-xl cursor-pointer hover:bg-green-50 dark:hover:bg-[#40376E] transition-all flex justify-between items-center";

    li.innerHTML = `
        <div class="flex flex-col">
                <span class="font-bold text-gray-900 dark:text-white">${f.name}</span>
                <span class="text-[10px] text-gray-400 dark:text-gray-500 uppercase">${f.status || 'Active'}</span>
            <div class="flex gap-2 mt-2">
                <button class="details-btn text-[10px] bg-green-600 text-white px-2 py-1 rounded">Details</button>
                <button class="fav-btn text-[10px] bg-yellow-500 text-white px-2 py-1 rounded">⭐</button>
            </div>
        </div>
        ${f.distance ? `<span class="text-xs font-bold text-green-700 dark:text-green-300 bg-green-100 dark:bg-[#1f1a3a] px-2 py-1 rounded-lg">${f.distance.toFixed(1)} mi</span>` : ''}
    `;

    // Existing buttons (unchanged)
    li.querySelector(".details-btn").onclick = (e) => {
        e.stopPropagation();
        saveRecentlyViewed(f);
        window.location.href = `/individfridge/${f.id}`;
    };

    li.querySelector(".fav-btn").onclick = (e) => {
        e.stopPropagation();
        toggleFavorite(f);
    };

    // ✅ Double click on list item → go to page
    li.ondblclick = () => {
        window.location.href = `/individfridge/${f.id}`;
    };

    // Normal click (UNCHANGED behavior)
    li.onclick = () => {
        saveRecentlyViewed(f);
        map.setView([f.lat, f.lng], 16);
        marker.openPopup();
        window.routeToFridge(f.lat, f.lng);

        if (window.innerWidth < 768) {
            sidebar.classList.add('translate-y-full');
            toggleBtn.classList.remove('hidden');
        }
    };

    list.appendChild(li);
});
}

document.querySelectorAll('input[name="transport"]').forEach(radio => {
    radio.onchange = () => {
        if (currentTargetFridge) {
            window.routeToFridge(currentTargetFridge.lat, currentTargetFridge.lng);
        }
    };
});

document.getElementById("fridge-search").oninput = (e) => {
    renderFridges(allFridges.filter(f => f.name.toLowerCase().includes(e.target.value.toLowerCase())));
};

document.getElementById("set-start").onclick = () => {
    const address = document.getElementById("start-location").value;
    fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
        .then(res => res.json())
        .then(data => { 
            if(data[0]) setUserLocation(parseFloat(data[0].lat), parseFloat(data[0].lon)); 
        });
};

function loadFridges() {
    fetch("/get-fridges")
        .then(res => res.json())
        .then(data => { 
            allFridges = data; 
            renderFridges(allFridges); 
        });
}

navigator.geolocation.getCurrentPosition(
    pos => { setUserLocation(pos.coords.latitude, pos.coords.longitude); loadFridges(); },
    () => { setUserLocation(40.7128, -74.0060); loadFridges(); }
);


// 1. Initial Load: Get everything from Database when page opens
document.addEventListener("DOMContentLoaded", () => {
    loadFridges(); // Existing map load
    loadFavoritesFromServer(); // Sync with DB
    renderRecent(); // Keep local storage for "Recently Viewed" only
});

// 2. Fetch Favorites from Python API (Syncs with Fridge Page)
async function loadFavoritesFromServer() {
    try {
        const res = await fetch('/get-favorites');
        const favorites = await res.json();
        renderFavoritesList(favorites);
    } catch (err) {
        console.error("Error loading favorites from server:", err);
    }
}

// 3. The Toggle Function (Connects to your Python route)
// We use 'window' so it can be called from the marker popups
window.toggleFavorite = async function(fridge) {
    try {
        const res = await fetch('/toggle-favorite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fridge_id: fridge.id || fridge.ID })
        });

        if (res.status === 401) {
            alert("Please log in to save favorites!");
            return;
        }

        const data = await res.json();
        console.log("Server response:", data.message);
        
        // Refresh the list from the database so the sidebar updates instantly
        loadFavoritesFromServer();

    } catch (err) {
        console.error("Error toggling favorite:", err);
    }
};

// 4. Render the Sidebar Favorites List
function renderFavoritesList(favorites) {
    const list = document.getElementById("favorites-list");
    if (!list) return;
    
    list.innerHTML = "";

    if (!favorites || favorites.length === 0) {
        list.innerHTML = '<li class="p-2 text-xs text-gray-400 italic text-center">No favorites yet.</li>';
        return;
    }

    favorites.forEach(f => {
        const li = document.createElement("li");
        const fID = f.ID || f.id;
        const fName = f.Name || f.name;
        const fLat = f.Latitude || f.lat;
        const fLng = f.Longitude || f.lng;

        // Container styling
        li.className = "p-2 bg-yellow-50 dark:bg-[#2a2545] border border-yellow-200 dark:border-[#40376E] rounded-xl flex justify-between items-center gap-2";
        
        li.innerHTML = `
            <span class="font-semibold text-sm cursor-pointer hover:text-yellow-700 flex-grow py-1">⭐ ${fName}</span>
            <button class="go-to-btn text-[10px] bg-yellow-500 text-white px-2 py-1 rounded-lg font-bold uppercase hover:bg-yellow-600 transition-colors">
                Go to →
            </button>
        `;
        
        // CLICK 1: Clicking the Name just centers the map or goes to the page
        li.querySelector('span').onclick = () => {
            if (fLat && fLng) {
                map.setView([fLat, fLng], 15);
            } else {
                window.location.href = `/individfridge/${fID}`;
            }
        };

        // CLICK 2: ONLY the button triggers the route
        li.querySelector('.go-to-btn').onclick = (e) => {
            e.stopPropagation(); // Prevents clicking the row
            if (fLat && fLng) {
                map.setView([fLat, fLng], 16);
                window.routeToFridge(fLat, fLng);
                
                // On mobile, close sidebar so they see the map/popup immediately
                if (window.innerWidth < 768) { 
                    sidebar.classList.add('translate-y-full'); 
                    toggleBtn.classList.remove('hidden'); 
                }
            } else {
                alert("Location data not available for this fridge.");
            }
        };

        list.appendChild(li);
    });
}

// 5. Update renderFridges to use the DB toggle
// (Modified part of your existing renderFridges function)

// 6. Recently Viewed (Stays in LocalStorage)
function saveRecentlyViewed(fridge) {
    let recent = JSON.parse(localStorage.getItem("recentFridges")) || [];
    // Remove if already exists, then add to front
    recent = recent.filter(f => f.id !== (fridge.id || fridge.ID));
    recent.unshift({ id: fridge.id || fridge.ID, name: fridge.name || fridge.Name });
    recent = recent.slice(0, 3);
    localStorage.setItem("recentFridges", JSON.stringify(recent));
    renderRecent();
}

function renderRecent() {
    const list = document.getElementById("recent-list");
    if (!list) return;
    const data = JSON.parse(localStorage.getItem("recentFridges")) || [];
    list.innerHTML = "";
    
    if (data.length === 0) {
        list.innerHTML = '<li class="p-2 text-xs text-gray-400 italic">None recently viewed.</li>';
        return;
    }

    data.forEach(f => {
        const li = document.createElement("li");
        li.className = "p-2 bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] rounded-lg";
        li.textContent = f.name;
        li.onclick = () => window.location.href = `/individfridge/${f.id}`;
        list.appendChild(li);
    });
}
</script>

</body>
</html>