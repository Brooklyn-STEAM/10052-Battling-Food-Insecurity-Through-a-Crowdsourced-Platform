    .addTo(map)

.bindPopup(`
<div class="p-3 text-center rounded-xl text-gray-900 dark:text-white">

    <div class="text-lg font-black mb-1">
        📍 Your Location
    </div>

    <div class="text-[11px] uppercase tracking-wide
                text-gray-500 dark:text-gray-400">
        Starting Point
    </div>

</div>
`)
    .openPopup();

    map.flyTo(
        [lat, lng],
