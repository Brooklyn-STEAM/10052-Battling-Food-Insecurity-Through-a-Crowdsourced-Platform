    <script>
            (function () {
                const saved = localStorage.getItem("theme");

                if (saved === "dark") {
                    document.documentElement.classList.add("dark");
                } else if (saved === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                    document.documentElement.classList.toggle("dark", prefersDark);
                }
            })();
    </script>

    <style>
        /* INPUT */
        .input {
            width: 100%;
            padding: 0.75rem;
            border-radius: 0.75rem;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            transition: 0.25s;
        }

        .input:focus {
            border-color: #a78bfa;
            box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.3);
        }

        /* FORM CARD (purple theme) */
        .form-card {
            background: linear-gradient(135deg, #ffffff, #f3f0ff);
            border: 1px solid #cac2d2;
        }

        .dark .form-card {
            background: linear-gradient(135deg, #1e1b2e, #2a2545);
            border: 1px solid #40376E;
        }

        /* DARK MODE */
        .dark .input {
            background: #2a2545;
            border-color: #40376E;
            color: #fff;
        }

        .dark .dropdown {
            background: #2a2545;
            border-color: #40376E;
        }

        html {
            scroll-behavior: smooth;
        }

        html {
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        #map {
#map {
    transition: filter 0.4s ease, opacity 0.3s ease;
    width: 100%;
    height: 100%;
    min-height: 300px;
}

.dark #map {
    filter: brightness(0.75) contrast(1.2) saturate(0.9);
}
#mobile-itinerary-container {
