        return;
    }

    favorites.forEach(f => {

        const li =
            document.createElement("li");

        const fID = f.ID || f.id;
        const fName = f.Name || f.name;
        const fLat = f.Latitude || f.lat;
        const fLng = f.Longitude || f.lng;

        li.className =
