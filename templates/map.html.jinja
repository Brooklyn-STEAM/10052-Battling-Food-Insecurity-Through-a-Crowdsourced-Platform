<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <meta charset="UTF-8">
    <title>Community Fridge Map</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css"/>

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

    <style>
        #map { height: 100%; min-height: 500px; z-index:0; }

        .leaflet-marker-icon {
            transition: transform 0.2s;
        }
        .leaflet-marker-icon:hover {
            transform: scale(1.2);
            z-index: 1000 !important;
        }

        #fridge-list::-webkit-scrollbar { width: 6px; }
        #fridge-list::-webkit-scrollbar-thumb { background-color: #94a3b8; border-radius: 3px; }
    </style>
</head>

<body class="bg-gray-100 font-sans">
{% include "components/navbar.html.jinja" %}

<div class="flex h-screen">

    <!-- Sidebar -->
    <div class="w-1/3 bg-white shadow-lg overflow-y-auto p-6">
        <h2 class="text-2xl font-bold mb-4 text-gray-800">
            Nearby Community Fridges
        </h2>

        <!-- Search Bar -->
        <input 
            type="text" 
            id="fridge-search" 
            placeholder="Search fridges..." 
            class="w-full p-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-green-500"
        />

        <!-- Sidebar fridge list -->
        <ul id="fridge-list" class="space-y-4"></ul>
    </div>

    <!-- Map -->
    <div id="map" class="w-2/3 rounded-l-lg shadow-inner"></div>

</div>

<script>
const targetFridge = {{ target_fridge|tojson if target_fridge else 'null' }};

// Initialize map
var map = L.map('map').setView([40.7128, -74.0060], 12);

L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap &copy; CARTO',
    subdomains: 'abcd',
    maxZoom: 19
}).addTo(map);

const list = document.getElementById("fridge-list");
const searchInput = document.getElementById("fridge-search");

const userIcon = L.icon({ iconUrl: "/static/images/pin.png", iconSize: [35,35], iconAnchor: [17,35], popupAnchor: [0,-35] });
const fridgeIcon = L.icon({ iconUrl: "/static/images/fridge.png", iconSize: [45,45], iconAnchor: [22,45], popupAnchor: [0,-45] });

let allFridges = [];
let userLat = null;
let userLng = null;
let routingControl = null;

function getDistance(lat1, lon1, lat2, lon2){
    const R = 6371;
    const dLat = (lat2-lat1)*Math.PI/180;
    const dLon = (lon2-lon1)*Math.PI/180;
    const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return R * c;
}

function routeToFridge(lat, lng){
    if(!userLat){ alert("Location not found"); return; }
    if(routingControl) map.removeControl(routingControl);

    routingControl = L.Routing.control({
        waypoints: [L.latLng(userLat, userLng), L.latLng(lat, lng)],
        routeWhileDragging: false,
        showAlternatives: false
    }).addTo(map);
}

function loadFridges(userLat, userLng){
    fetch("/get-fridges")
    .then(res => res.json())
    .then(data => {

        list.innerHTML = "";
        allFridges = [];

        const sortedFridges = data
            .map(f => ({...f, lat: parseFloat(f.lat), lng: parseFloat(f.lng), distance: getDistance(userLat,userLng,parseFloat(f.lat),parseFloat(f.lng))}))
            .filter(f => !isNaN(f.lat) && !isNaN(f.lng))
            .sort((a,b) => a.distance-b.distance);

        sortedFridges.forEach(f => {
            const marker = L.marker([f.lat,f.lng], {icon: fridgeIcon})
                .addTo(map)
                .bindPopup(`
                    <div class="text-lg font-semibold">${f.name}</div>
                    <div class="text-sm text-gray-600">Status: ${f.status}</div>
                    <div class="text-sm text-gray-600">${f.distance.toFixed(2)} km away</div>
                    <button onclick="routeToFridge(${f.lat},${f.lng})" class="mt-2 bg-green-500 text-white px-3 py-1 rounded hover:bg-green-600">Route Here</button>
                `);

            marker.on("dblclick", () => window.location.href="/individfridge/"+f.id);

            const li = document.createElement("li");
            li.className = "p-4 bg-gray-50 rounded-lg shadow hover:bg-gray-100 cursor-pointer transition duration-150";
            li.innerHTML = `<div class="font-semibold text-gray-800">${f.name}</div><div class="text-sm text-gray-500">${f.distance.toFixed(2)} km away</div>`;

            li.addEventListener("click", () => { map.setView([f.lat,f.lng],15); marker.openPopup(); });
            li.addEventListener("dblclick", () => { window.location.href="/individfridge/"+f.id; });

            list.appendChild(li);
            allFridges.push({name:f.name.toLowerCase(), li, marker});
        });
    });
}

searchInput.addEventListener("input", ()=>{
    const query = searchInput.value.toLowerCase();
    allFridges.forEach(f=>{
        if(f.name.includes(query)){
            f.li.style.display="block";
            f.marker.addTo(map);
        }else{
            f.li.style.display="none";
            map.removeLayer(f.marker);
        }
    });
});

navigator.geolocation.getCurrentPosition(
    pos => {
        userLat = pos.coords.latitude;
        userLng = pos.coords.longitude;
        map.setView([userLat,userLng],13);
        L.marker([userLat,userLng], {icon:userIcon}).addTo(map).bindPopup("You are here");
        loadFridges(userLat,userLng);
    },
    err => {
        console.log("Location denied, using default.");
        userLat = 40.7128;
        userLng = -74.0060;
        loadFridges(userLat,userLng);
    }
);

if(targetFridge){
    setTimeout(()=>{ 
        routeToFridge(targetFridge.lat,targetFridge.lng); 
        map.setView([targetFridge.lat,targetFridge.lng],15); 
    },1000);
}
</script>

{% include "components/footer.html.jinja" %}
</body>
</html>