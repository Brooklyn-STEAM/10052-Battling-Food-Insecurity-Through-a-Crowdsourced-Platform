/* =========================================================
   RENDER FRIDGES
========================================================= */
let lastRenderKey = "";
function renderFridges(fridges) {

    clearHTML(DOM.fridgeList);

    state.fridgeMarkers.forEach(marker => {
        map.removeLayer(marker);
    });

    state.fridgeMarkers = [];

    const fragment =
        document.createDocumentFragment();

    const fridgesWithData = fridges
        .map(f => ({
            ...f,
            distance: state.userLat
                ? getDistance(
                    state.userLat,
                    state.userLng,
                    f.lat,
                    f.lng
                )
                : null
        }))

        .sort((a, b) =>
            (a.distance || 999) -
            (b.distance || 999)
        );

    fridgesWithData.forEach(f => {

        /* -----------------------------
           MARKER
        ----------------------------- */
        const marker = L.marker(
            [f.lat, f.lng],
            { icon: fridgeIcon }
        )

        .addTo(map)

        .bindPopup(createFridgePopup(f));

        marker.on('dblclick', () => {
            window.location.href =
                `/individfridge/${f.id}`;
        });

        marker.on('click', () => {

            saveRecentlyViewed(f);

            map.flyTo(
                [f.lat, f.lng],
                CONFIG.FRIDGE_ZOOM,
                {
                    duration: 0.6,
                    easeLinearity: 0.25
                }
            );

            marker.openPopup();
        });

        state.fridgeMarkers.push(marker);


        /* -----------------------------
           SIDEBAR ITEM
        ----------------------------- */
        const li =
            document.createElement("li");

        li.className = `
p-4 rounded-2xl cursor-pointer
bg-white dark:bg-[#2a2545]
border border-gray-200 dark:border-[#40376E]
shadow-sm hover:shadow-lg
transition-all duration-200
active:scale-[0.97]
flex flex-col sm:flex-row
sm:justify-between sm:items-center
gap-3
`;

        li.innerHTML = `
<div class="flex flex-col">

    <span class="font-bold text-base">
        ${f.name}
    </span>

    <span class="text-xs text-gray-400 uppercase tracking-wide">
        ${f.status || 'Active'}
    </span>

    <div class="flex gap-2 mt-2">

        <button class="details-btn text-[10px] bg-green-600 text-white px-2 py-1 rounded">
            Details
        </button>

        <button class="fav-btn text-[10px] bg-yellow-500 text-white px-2 py-1 rounded">
            ⭐
        </button>

    </div>
</div>

${f.distance
? `<span class="text-xs font-bold text-green-700 dark:text-green-300 bg-green-100 dark:bg-[#1f1a3a] px-2 py-1 rounded-lg">${f.distance.toFixed(1)} mi</span>`
: ''}
`;

        li.querySelector(".details-btn")
            .onclick = (e) => {

                e.stopPropagation();

                saveRecentlyViewed(f);

                window.location.href =
                    `/individfridge/${f.id}`;
            };

        li.querySelector(".fav-btn")
            .onclick = (e) => {

                e.stopPropagation();

                toggleFavorite(f);
            };

        li.onclick = () => {

            saveRecentlyViewed(f);

            map.setView(
                [f.lat, f.lng],
                CONFIG.FRIDGE_ZOOM
            );

            marker.openPopup();

            if (!isMobile()) {
                window.routeToFridge(f.lat, f.lng);
            }
        };

        fragment.appendChild(li);
    });

    DOM.fridgeList.appendChild(fragment);
}


