<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <meta charset="UTF-8">
    <title>Community Fridge Map</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Leaflet CSS -->
    <link rel="stylesheet"
          href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <style>
        #map {
            height: 100%;
            min-height: 500px;
            z-index:0
        }

        .leaflet-marker-icon {
            transition: transform 0.2s;
        }
        .leaflet-marker-icon:hover {
            transform: scale(1.2);
            z-index: 1000 !important;
        }

        /* Sidebar scrollbar */
        #fridge-list::-webkit-scrollbar {
            width: 6px;
        }
        #fridge-list::-webkit-scrollbar-thumb {
            background-color: #94a3b8;
            border-radius: 3px;
        }
    </style>
</head>

<body class="bg-gray-100 font-sans">
{% include "components/navbar.html.jinja" %}

<div class="flex h-screen">

    <!-- Sidebar -->
    <div class="w-1/3 bg-white shadow-lg overflow-y-auto p-6">
        <h2 class="text-2xl font-bold mb-4 text-gray-800">
            Nearby Community Fridges
        </h2>

        <!-- Search Bar -->
        <input 
            type="text" 
            id="fridge-search" 
            placeholder="Search fridges..." 
            class="w-full p-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-green-500"
        />

        <ul id="fridge-list" class="space-y-4"></ul>
    </div>

    <!-- Map -->
    <div id="map" class="w-2/3 rounded-l-lg shadow-inner"></div>

</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
// Initialize map
var map = L.map('map').setView([40.7128, -74.0060], 12);

L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap &copy; CARTO',
    subdomains: 'abcd',
    maxZoom: 19
}).addTo(map);

const list = document.getElementById("fridge-list");
const searchInput = document.getElementById("fridge-search");

// Icons
const userIcon = L.icon({
    iconUrl: "/static/images/pin.png",
    iconSize: [35, 35],
    iconAnchor: [17, 35],
    popupAnchor: [0, -35]
});

const fridgeIcon = L.icon({
    iconUrl: "/static/images/fridge.png",
    iconSize: [45, 45],
    iconAnchor: [22, 45],
    popupAnchor: [0, -45]
});

// Distance function
function getDistance(lat1, lon1, lat2, lon2) {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return R * c;
}

let allFridges = [];

// Load fridges
function loadFridges(userLat, userLng) {
    fetch("/get-fridges")
    .then(res => res.json())
    .then(data => {
        list.innerHTML = "";
        allFridges = [];

        const fridgesWithDistance = data
            .map(fridge => {
                const lat = parseFloat(fridge.lat);
                const lng = parseFloat(fridge.lng);
                if (isNaN(lat) || isNaN(lng)) return null;
                return {...fridge, lat, lng, distance: getDistance(userLat, userLng, lat, lng)};
            })
            .filter(Boolean)
            .sort((a,b)=>a.distance-b.distance);

        fridgesWithDistance.forEach(fridge => {
            const {lat, lng, distance} = fridge;
            const cleanName = (fridge.name || "Unnamed Fridge").trim();
            const status = fridge.status || "Unknown";

            // Marker
            const marker = L.marker([lat, lng], {icon: fridgeIcon})
                .addTo(map)
                .bindPopup(`
                    <div class="text-lg font-semibold">${cleanName}</div>
                    <div class="text-sm text-gray-600">Status: ${status}</div>
                    <div class="text-sm text-gray-600">${distance.toFixed(2)} km away</div>
                `);

            marker.on("dblclick", () => {
                window.location.href = "/individfridge/" + fridge.id;
            });

            // Sidebar item
            const li = document.createElement("li");
            li.className = "p-4 bg-gray-50 rounded-lg shadow hover:bg-gray-100 cursor-pointer transition duration-150";
            li.innerHTML = `
                <div class="font-semibold text-gray-800">${cleanName}</div>
                <div class="text-sm text-gray-500">${distance.toFixed(2)} km away</div>
            `;

            // Single click → zoom + popup
            li.addEventListener("click", () => {
                map.setView([lat, lng], 15);
                marker.openPopup();
            });

            // Double click → fridge page
            li.addEventListener("dblclick", () => {
                window.location.href = "/individfridge/" + fridge.id;
            });

            list.appendChild(li);

            // Keep for search filtering
            allFridges.push({name: cleanName.toLowerCase(), li, marker});
        });
    })
    .catch(err => console.error("Fetch error:", err));
}

// Search input
searchInput.addEventListener("input", () => {
    const query = searchInput.value.toLowerCase();
    allFridges.forEach(fridge => {
        if (fridge.name.includes(query)) {
            fridge.li.style.display = "block";
            fridge.marker.addTo(map);
        } else {
            fridge.li.style.display = "none";
            map.removeLayer(fridge.marker);
        }
    });
});

// Default load
loadFridges(40.7128, -74.0060);

// User location
navigator.geolocation.getCurrentPosition(
    pos => {
        const userLat = pos.coords.latitude;
        const userLng = pos.coords.longitude;
        map.setView([userLat, userLng], 13);
        L.marker([userLat, userLng], {icon: userIcon})
            .addTo(map)
            .bindPopup("You are here");
        loadFridges(userLat, userLng);
    },
    err => {
        console.log("Location denied. Using default NYC.");
        loadFridges(40.7128, -74.0060);
    }
);
</script>

{% include "components/footer.html.jinja" %}
</body>
</html>