                <ul id="favorites-list" data-tutorial="favorites" class="space-y-2 mb-5">
                </ul>


                <!-- RECENTS -->
                <div class="flex justify-between items-center mb-2 hidden md:flex">
                    <h3 class="text-sm font-bold text-gray-500 dark:text-gray-400">
                        Recently Viewed
                    </h3>

                    <div class="flex gap-2">
                        <button id="undo-recents"
                            class="text-[10px] font-bold uppercase text-blue-500 hover:underline hidden">
                            Undo
                        </button>

                        <button id="clear-recents"
                            class="text-[10px] font-bold uppercase text-gray-400 hover:text-red-500">
                            Clear
                        </button>
                    </div>
                </div>

                <ul id="recent-list" class="space-y-2 mb-5 text-sm text-gray-700 dark:text-gray-300">
                </ul>


                <!-- FRIDGE LIST -->
                <div id="fridge-list-wrapper">
    <ul id="fridge-list" class="space-y-3 pb-24 overflow-y-auto max-h-[50vh] md:max-h-full pr-1">
    </ul>
