                time: timeMin
            };
        })

        .catch(err => {

            console.error(err);

            const errorHtml =
                `<p class="text-red-500 text-sm">Failed to load route</p>`;

            document.getElementById(
                "itinerary-container"
            ).innerHTML = errorHtml;

            document.getElementById(
                "mobile-itinerary-container"
            ).innerHTML = errorHtml;

        });

    if (isMobile && mobileItinerary) {
        mobileItinerary.innerHTML = errorHtml;
    } else {
        itineraryContainer.innerHTML = errorHtml;
    }

    window.lastRoute = {
        lat,
        lng,
        coords,
        stepsHtml,
        distance: distMi,
        time: timeMin
    };
};


/* =========================================================
   ROUTE HELPERS
========================================================= */
window.closeDirectionsModal = function() {
    document.getElementById('directions-modal')
        .classList.add('hidden');
};

window.clearRoute = function() {

    if (window.currentRouteLayer) {
        map.removeLayer(window.currentRouteLayer);
    }

    document.getElementById('routing-directions')
        .classList.add('hidden');

    const reopenBtn =
        document.getElementById('reopen-directions');

    reopenBtn.classList.remove("hidden");

    // reset animation state
    reopenBtn.classList.remove("fade-out-directions");

    // auto fade after 3s
    clearTimeout(window.reopenDirectionsTimeout);

    window.reopenDirectionsTimeout = setTimeout(() => {
        reopenBtn.classList.add("fade-out-directions");

        // fully hide after animation
        setTimeout(() => {
            reopenBtn.classList.add("hidden");
            reopenBtn.classList.remove("fade-out-directions");
        }, 400);

    }, 3000);

    document.getElementById('itinerary-container')
        .innerHTML = "";

    const modal =
        document.getElementById('directions-modal');

    const mobileItinerary =
        document.getElementById('mobile-itinerary-container');

    if (modal) {
        modal.classList.add('hidden');
    }

    if (mobileItinerary) {
        mobileItinerary.innerHTML = "";
    }

    currentTargetFridge = null;
};
function restoreLastRoute() {

    if (!window.lastRoute) return;

    const { lat, lng, coords, stepsHtml } = window.lastRoute;

    const isDark =
        document.documentElement.classList.contains('dark');

    if (window.currentRouteLayer) {
        map.removeLayer(window.currentRouteLayer);
    }

    window.currentRouteLayer = L.polyline(coords, {
        color: isDark ? '#a855f7' : '#16a34a',
        weight: 6,
        opacity: 1,
        dashArray: '12 16',
        className: 'animated-route'
    }).addTo(map);

    map.fitBounds(window.currentRouteLayer.getBounds(), {
        padding: [50, 50]
    });

    document.getElementById('routing-directions')
        .classList.remove('hidden');

    document.getElementById('itinerary-container')
        .innerHTML = stepsHtml;

    const mobile =
        document.getElementById('mobile-itinerary-container');

    if (mobile) {
        mobile.innerHTML = stepsHtml;
    }

    document.getElementById("directions-modal")
        ?.classList.remove("hidden");
}


/* =========================================================
   RENDER FRIDGES
========================================================= */
function renderFridges(fridges) {

    const list = document.getElementById("fridge-list");

    list.innerHTML = "";

    fridgeMarkers.forEach(m => map.removeLayer(m));

    fridgeMarkers = [];

    const fridgesWithData = fridges
        .map(f => ({
            ...f,
            distance: userLat
                ? getDistance(userLat, userLng, f.lat, f.lng)
                : null
        }))
        .sort((a, b) => (a.distance || 999) - (b.distance || 999));

    fridgesWithData.forEach(f => {

        /* -----------------------------
           MAP MARKER
        ----------------------------- */
        const marker = L.marker([f.lat, f.lng], {
            icon: fridgeIcon
        })

        .addTo(map)

        .bindPopup(`
<div class="p-3 text-center rounded-xl text-gray-900 dark:text-white">

    <b class="text-lg font-bold text-gray-900 dark:text-white">
        ${f.name}
    </b><br>

    <span class="text-[10px] text-gray-500 dark:text-gray-400 uppercase">
        ${f.status || 'Active'}
    </span><br>

    <div class="flex gap-2 mt-3">

        <button 
            onclick="window.location.href='/individfridge/${f.id}'"
            class="flex-1 text-[11px] bg-gray-200 hover:bg-gray-300 
                   dark:bg-[#A855F7] dark:hover:bg-[#693D9E]
                   text-gray-800 dark:text-white px-3 py-2 rounded-lg font-bold transition">
            Details
        </button>

        <button 
            onclick="window.routeToFridge(${f.lat},${f.lng})"
            class="flex-1 bg-green-600 dark:bg-purple-600
                   hover:bg-green-700 dark:hover:bg-purple-700
                   text-white px-3 py-2 rounded-lg font-bold text-[11px]
                   touch-manipulation">
            Directions
        </button>

    </div>
</div>
`);

        marker.on('dblclick', () => {
            window.location.href =
                `/individfridge/${f.id}`;
        });

        fridgeMarkers.push(marker);

        marker.on('click', () => {

            saveRecentlyViewed(f);

            map.flyTo([f.lat, f.lng], 16, {
                duration: 0.6,
                easeLinearity: 0.25
            });

            marker.openPopup();

            if (window.innerWidth < 768) {
                toggleBtn.classList.remove('hidden');
            }
        });


        /* -----------------------------
           SIDEBAR ITEM
        ----------------------------- */
        const li = document.createElement("li");

        li.className = `
p-4 rounded-2xl cursor-pointer
bg-white dark:bg-[#2a2545]
border border-gray-200 dark:border-[#40376E]
shadow-sm hover:shadow-lg
transition-all duration-200
active:scale-[0.97]
flex justify-between items-center gap-4
`;

        li.innerHTML = `
<div class="flex flex-col">

    <span class="font-bold text-base">
        ${f.name}
    </span>

    <span class="text-xs text-gray-400 uppercase tracking-wide">
        ${f.status || 'Active'}
    </span>

    <div class="flex gap-2 mt-2">
        <button class="details-btn text-[10px] bg-green-600 text-white px-2 py-1 rounded">
            Details
        </button>

        <button class="fav-btn text-[10px] bg-yellow-500 text-white px-2 py-1 rounded">
            ⭐
        </button>
    </div>

</div>

${f.distance
    ? `<span class="text-xs font-bold text-green-700 dark:text-green-300 bg-green-100 dark:bg-[#1f1a3a] px-2 py-1 rounded-lg">${f.distance.toFixed(1)} mi</span>`
    : ''}
`;

        // Details Button
        li.querySelector(".details-btn").onclick = (e) => {
            e.stopPropagation();

            saveRecentlyViewed(f);

            window.location.href =
                `/individfridge/${f.id}`;
        };

        // Favorite Button
        li.querySelector(".fav-btn").onclick = (e) => {
            e.stopPropagation();
            toggleFavorite(f);
        };

        // Double click
        li.ondblclick = () => {
            window.location.href =
                `/individfridge/${f.id}`;
        };

        // Normal click
        li.onclick = () => {

            saveRecentlyViewed(f);

            map.setView([f.lat, f.lng], 16);

            marker.openPopup();

            if (window.innerWidth >= 768) {
                window.routeToFridge(f.lat, f.lng);
            }

            if (window.innerWidth < 768) {
                toggleBtn.classList.remove('hidden');
            }
        };

        list.appendChild(li);
    });
}


/* =========================================================
   TRANSPORT MODE CHANGES
========================================================= */
document.querySelectorAll(
    'input[name="transport"]'
).forEach(radio => {

    radio.addEventListener("change", () => {
        window.updateRoute();
    });

});

window.updateRoute = function () {

    if (!currentTargetFridge || !userLat || !userLng) {
        return;
    }

    if (window.currentRouteLayer) {
        map.removeLayer(window.currentRouteLayer);
        window.currentRouteLayer = null;
    }

    window.routeToFridge(
        currentTargetFridge.lat,
        currentTargetFridge.lng
    );
};


/* =========================================================
   SEARCH
========================================================= */
document.getElementById("fridge-search").oninput = (e) => {

    renderFridges(
        allFridges.filter(f =>
            f.name.toLowerCase()
                .includes(e.target.value.toLowerCase())
        )
    );

};


/* =========================================================
   START LOCATION SEARCH
========================================================= */
document.getElementById("set-start").onclick = () => {

    const address =
        document.getElementById("start-location").value;

    fetch(
        `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`
    )

    .then(res => res.json())

    .then(data => {

        if (data[0]) {
            setUserLocation(
                parseFloat(data[0].lat),
                parseFloat(data[0].lon)
            );
        }

    });
};


