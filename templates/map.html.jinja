                    element: "#transport-controls",
                    popover: {
                        title: "Travel Modes",
                        description:
                            "Switch between walking, biking, and driving directions."
                    }
                },

                {
                    element: "#map",
                    popover: {
                        title: "Your Turn",
                        description:
                            "Next: click any fridge marker on the map to continue the tutorial.",
                        showButtons: []
                    },

                    onHighlightStarted: () => {

                        fridgeClicked = false;

                        const cleanup = [];

                        state.markerMap.forEach((marker) => {

                            const handler = () => {

                                if (fridgeClicked) return;

                                fridgeClicked = true;

                                cleanup.forEach(fn => fn());

                                setTimeout(() => {
                                    driver.moveNext();
                                }, 500);
                            };

                            marker.once("click", handler);

                            cleanup.push(() => {
                                marker.off("click", handler);
                            });
                        });
                    }
                },

                {
                    element: "#fridge-sheet",
                    popover: {
                        title: "Fridge Details",
                        description:
                            "This panel shows fridge information and quick actions."
                    }
                },

                {
                    element: "#favorites-list",
                    popover: {
                        title: "Favorites",
                        description:
                            "Save your favorite fridges for quick access later."
                    }
                },

                {
                    element: "#recent-list",
                    popover: {
                        title: "Recently Viewed",
                        description:
                            "Your recently opened fridges appear here."
                    }
                },

                {
                    element: "#routing-directions",
                    popover: {
                        title: "Directions",
                        description:
                            "Step-by-step route guidance appears here after choosing directions."
                    }
                },

                {
                    element: "#fridge-list",
                    popover: {
                        title: "You're Ready",
                        description:
                            "Explore the map and help support your local community."
                    }
                }
            ]
        });

        window.mapTour = driver;

        driver.drive();
    };


    window.restartMapTutorial = function () {

        // destroy previous instance safely
        if (window.mapTour) {
            try {
                window.mapTour.destroy();
            } catch (e) {
                console.warn(e);
            }
        }

        // restart tutorial
        window.startMapTutorial();
    };


    document.addEventListener("DOMContentLoaded", () => {
        loadFavoritesFromServer();
    });
</script>

</html>