    /* =========================================================
       GLOBAL MUTATION STAR ACTIONS
    ========================================================= */
    window.toggleFavorite = async function (fridge) {
        try {
            const endpoint = (typeof CONFIG !== 'undefined' && CONFIG.API?.TOGGLE_FAVORITE) ? CONFIG.API.TOGGLE_FAVORITE : "/toggle-favorite";
            const id = fridge.id || fridge.ID;

            const data = await safeApiPost(endpoint, { fridge_id: id });

            if (data.success || data.action) {
                // Update the baseline status element models held locally in map state arrays
                const localMatch = state.allFridges.find(f => (f.id || f.ID) === id);
                if (localMatch) {
                    localMatch.isFavorite = (data.action === "added");
                }

                // Sync visual button modifications on parent listings without rewriting layout nodes
                document.querySelectorAll(".fav-btn").forEach(btn => {
                    const parentLi = btn.closest("li");
                    // Fallback check to scan structural elements during event handling passes
                    if (parentLi && parentLi.innerHTML.includes(`window.location.href='/individfridge/${id}'`)) {
                        if (data.action === "added") {
                            btn.classList.add("favorited");
                        } else {
                            btn.classList.remove("favorited");
                        }
                    }
                });

                // Re-render the side list component container with fresh server sync data
                await loadFavoritesFromServer();

                // Broadcast structural data synchronization tokens to open background view windows
                if (window.BroadcastChannel) {
                    new BroadcastChannel('favorites_sync').postMessage({
                        action: data.action,
                        fridge_id: id,
                        fridge_name: fridge.name || fridge.Name,
                        fridge_address: fridge.address || fridge.Address
                    });
                }
            }
        } catch (err) {
            console.error("Critical favorite toggle transaction failed:", err);
        }
    };

