    renderRecent();
});


/* =========================================================
   FAVORITES
========================================================= */
async function loadFavoritesFromServer() {

    try {

        const res = await fetch('/get-favorites');

        const favorites = await res.json();

        renderFavoritesList(favorites);

    } catch (err) {

        console.error(
            "Error loading favorites from server:",
            err
        );

    }
}

function requireLogin() {
    showFlashMessage(
        "Please log in to favorite fridges",
        "error"
    );
}

window.toggleFavorite = async function(fridge) {

    try {

        const res = await fetch('/toggle-favorite', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                fridge_id: fridge.id || fridge.ID
            })
        });

        if (res.status === 401) {
            requireLogin();
            return;
        }

        const data = await res.json();

        loadFavoritesFromServer();

    } catch (err) {

        console.error(
            "Error toggling favorite:",
            err
        );

    }
};


/* =========================================================
   FAVORITES SIDEBAR
========================================================= */
function renderFavoritesList(favorites) {

    const list =
        document.getElementById("favorites-list");

    if (!list) return;

    list.innerHTML = "";

    if (!favorites || favorites.length === 0) {

        list.innerHTML =
            '<li class="p-2 text-xs text-gray-400 italic text-center">No favorites yet.</li>';

        return;
    }

    favorites.forEach(f => {

        const li = document.createElement("li");

        const fID = f.ID || f.id;
        const fName = f.Name || f.name;
        const fLat = f.Latitude || f.lat;
        const fLng = f.Longitude || f.lng;

        li.className =
            "p-2 bg-yellow-50 dark:bg-[#2a2545] border border-yellow-200 dark:border-[#40376E] rounded-xl flex justify-between items-center gap-2";

        li.innerHTML = `
<span class="font-semibold text-sm cursor-pointer hover:text-yellow-700 flex-grow py-1">
    ⭐ ${fName}
</span>

<button class="go-to-btn text-[10px] bg-yellow-500 text-white px-2 py-1 rounded-lg font-bold uppercase hover:bg-yellow-600 transition-colors">
    Go to →
</button>
`;

        // Name click
        li.querySelector('span').onclick = () => {

            if (fLat && fLng) {
                map.setView([fLat, fLng], 15);
            } else {
                window.location.href =
                    `/individfridge/${fID}`;
            }
        };

        // Route button
        li.querySelector('.go-to-btn').onclick = (e) => {

            e.stopPropagation();

            if (fLat && fLng) {

                map.setView([fLat, fLng], 16);

                window.routeToFridge(fLat, fLng);

                if (window.innerWidth < 768) {
                    toggleBtn.classList.remove('hidden');
                    hideSidebar();
                }

            } else {

                alert(
                    "Location data not available for this fridge."
                );

            }
        };

        list.appendChild(li);
    });
}


/* =========================================================
   RECENTLY VIEWED
========================================================= */
function saveRecentlyViewed(fridge) {

    let recent =
        JSON.parse(
            localStorage.getItem("recentFridges")
        ) || [];

    recent = recent.filter(
        f => f.id !== (fridge.id || fridge.ID)
    );

    recent.unshift({
        id: fridge.id || fridge.ID,
        name: fridge.name || fridge.Name
    });

    recent = recent.slice(0, 5);

    localStorage.setItem(
        "recentFridges",
        JSON.stringify(recent)
    );

    renderRecent();
}

function renderRecent() {

    const list =
        document.getElementById("recent-list");

    if (!list) return;

    const data =
        JSON.parse(
            localStorage.getItem("recentFridges")
        ) || [];

    list.innerHTML = "";

    if (data.length === 0) {

        list.innerHTML = `
<li class="p-3 text-xs text-gray-400 italic text-center bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] rounded-xl">
    No recent activity
</li>
`;

        return;
    }

    data.forEach(f => {

        const li = document.createElement("li");

        li.className = `
p-3 bg-gray-50 dark:bg-[#2a2545]
border border-gray-200 dark:border-[#40376E]
rounded-xl flex justify-between items-center
cursor-pointer hover:bg-green-50
dark:hover:bg-[#40376E]
transition-all
`;

        li.innerHTML = `
<div class="flex items-center gap-2 flex-grow">
    <span class="text-xs">🕒</span>

    <span class="text-sm font-semibold text-gray-800 dark:text-gray-200 truncate">
        ${f.name}
    </span>
</div>

<span class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase">
    View
</span>
`;

        li.onclick = () => {
            window.location.href =
                `/individfridge/${f.id}`;
        };

        list.appendChild(li);
    });
}


/* =========================================================
   CLEAR / UNDO RECENTS
========================================================= */
document.getElementById("clear-recents").onclick = () => {

    const current =
        localStorage.getItem("recentFridges");

    if (!current) return;

    recentsBackup = current;

    localStorage.removeItem("recentFridges");

    renderRecent();

    const undoBtn =
        document.getElementById("undo-recents");

    const clearBtn =
        document.getElementById("clear-recents");

    // show undo
    undoBtn.classList.remove("hidden");

    // hide clear button
    clearBtn.classList.add("hidden");

    let timeLeft = 3;

    undoBtn.textContent = `Undo (${timeLeft})`;

    clearTimeout(undoTimeout);
    clearInterval(undoInterval);

    undoInterval = setInterval(() => {

        timeLeft--;

        if (timeLeft > 0) {
            undoBtn.textContent = `Undo (${timeLeft})`;
        } else {
            undoBtn.textContent = "Undo";
            clearInterval(undoInterval);
        }

    }, 1000);

    undoTimeout = setTimeout(() => {

        recentsBackup = null;

        undoBtn.classList.add("hidden");
        undoBtn.textContent = "Undo";

        // show clear button again
        clearBtn.classList.remove("hidden");

        clearInterval(undoInterval);

    }, 3000);
};
document.getElementById("undo-recents").onclick = () => {

    if (!recentsBackup) return;

    localStorage.setItem(
        "recentFridges",
        recentsBackup
    );

    renderRecent();

    recentsBackup = null;

    const undoBtn =
        document.getElementById("undo-recents");

    const clearBtn =
        document.getElementById("clear-recents");

    undoBtn.classList.add("hidden");
    undoBtn.textContent = "Undo";

    // restore clear button
    clearBtn.classList.remove("hidden");

    clearTimeout(undoTimeout);
    clearInterval(undoInterval);
};

/* =========================================================
   WINDOW RESIZE
========================================================= */
window.addEventListener("resize", () => {

    setTimeout(() => {
        map.invalidateSize(false);
    }, 250);

});


/* =========================================================
   SIDEBAR DRAG HELPERS
========================================================= */
function setTranslate(y) {
    currentTranslate = Math.max(
        0,
        Math.min(y, MAX_TRANSLATE)
    );
}

document.getElementById("sidebar-toggle").onclick =
    toggleSidebar;

sidebar.addEventListener("touchstart", (e) => {

    if (!e.target.closest("#drag-handle")) return;

    isDragging = true;

    startY = e.touches[0].clientY;

    sidebar.style.transition = "none";
});

sidebar.addEventListener("touchmove", (e) => {

    if (!isDragging) return;

    currentY = e.touches[0].clientY;

    const diff = currentY - startY;

    currentTranslate += diff;

    currentTranslate = Math.max(
        0,
        Math.min(currentTranslate, MAX_TRANSLATE)
    );

    sidebar.style.transform =
        `translateY(${currentTranslate}px)`;

    startY = currentY;
});

sidebar.addEventListener("touchend", () => {

    if (!isDragging) return;

    isDragging = false;

    sidebar.style.transition =
        "transform 0.3s ease";

    if (currentTranslate > MAX_TRANSLATE * 0.5) {
        hideSidebar();
    } else {
        openSidebar();
    }
});


/* =========================================================
   FLASH MESSAGE
========================================================= */
function showFlashMessage(message, type = "error") {

    const existing =
        document.getElementById("flash-message");

    if (existing) {
        existing.remove();
    }

    const flash =
        document.createElement("div");

    flash.id = "flash-message";

    flash.className = `flash-message ${
        type === "error"
            ? "flash-error"
            : "flash-success"
    }`;

    flash.innerHTML = `<span>${message}</span>`;

    document.body.appendChild(flash);

    requestAnimationFrame(() => {

        flash.style.opacity = "1";

        flash.style.transform =
            "translateX(-50%) translateY(0)";
    });

    setTimeout(() => {

        flash.style.opacity = "0";

        flash.style.transform =
            "translateX(-50%) translateY(-6px)";

        setTimeout(() => flash.remove(), 300);

    }, 2000);
}


/* =========================================================
   REOPEN DIRECTIONS
========================================================= */
document.getElementById("reopen-directions").onclick = () => {

    const sidebar =
        document.getElementById("sidebar");

    if (window.lastRoute) {

        restoreLastRoute();

    } else if (
        currentTargetFridge &&
        userLat &&
        userLng
    ) {

        window.routeToFridge(
            currentTargetFridge.lat,
            currentTargetFridge.lng
        );
    }

    if (window.innerWidth < 768) {

        document.getElementById("directions-modal")
            .classList.remove("hidden");

    } else {

        sidebar.classList.add("open");
    }

    document.getElementById("reopen-directions")
        .classList.add("hidden");

    map.invalidateSize();
};

