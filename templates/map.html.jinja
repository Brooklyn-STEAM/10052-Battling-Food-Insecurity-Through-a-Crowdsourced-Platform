<script>
    
const sidebar = document.getElementById('sidebar');
const toggleBtn = document.getElementById('toggle-sidebar');
const closeBtn = document.getElementById('close-sidebar');
function openSidebar() {
    currentTranslate = 0;
    sidebar.style.transform = "";
    sidebar.classList.add("open");
    sidebar.classList.remove("hidden-state");
    toggleBtn.classList.add("hidden");

    setTimeout(() => map.invalidateSize(), 300);

}

function hideSidebar() {
    currentTranslate = MAX_TRANSLATE;
    sidebar.style.transform = "";
    sidebar.classList.remove("open");
    sidebar.classList.add("hidden-state");
    toggleBtn.classList.remove("hidden");

    setTimeout(() => map.invalidateSize(), 300);

}

function toggleSidebar() {
    if (sidebar.classList.contains("open")) {
        hideSidebar();
    } else {
        openSidebar();
    }
}

toggleBtn.onclick = openSidebar;
closeBtn.onclick = hideSidebar;

let isDragging = false;
let startY = 0;
let currentY = 0;

let currentTranslate = 0;
const MAX_TRANSLATE = window.innerHeight * 0.6;


// Sidebar Toggle Logic




// Map Initialization
const map = L.map('map', {
    zoomAnimation: true,
    fadeAnimation: true,
    zoomControl: false
}).setView([40.7128, -74.0060], 12);
setTimeout(() => {
    map.invalidateSize();
}, 300);

L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; OpenStreetMap &copy; CARTO',
    subdomains: 'abcd',
    maxZoom: 20
}).addTo(map);

L.control.zoom({ position: 'topright' }).addTo(map);



const userIcon = L.icon({ iconUrl: "/static/images/pin.png", iconSize: [35, 35] });
const fridgeIcon = L.icon({ iconUrl: "/static/images/fridge.png", iconSize: [45, 45] });

let recentsBackup = null;
let undoTimeout = null;
let userLat, userLng, userMarker;
let currentRouteLayer = null; // Stores the polyline
let currentTargetFridge = null;
let allFridges = [], fridgeMarkers = [];

// Profile Map for Geoapify
const profileMap = {
    "foot": "walk",
    "bicycle": "bicycle",
    "car": "drive"
};

function getDistance(lat1, lon1, lat2, lon2) {
    const R = 3958.8;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
    return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)));
}

function setUserLocation(lat, lng) {
    userLat = lat; userLng = lng;
    if (userMarker) map.removeLayer(userMarker);
    userMarker = L.marker([lat, lng], { icon: userIcon }).addTo(map).bindPopup("Your Location").openPopup();
    map.setView([lat, lng], 13);
    renderFridges(allFridges);
}
function resetRouteUI() {
    // Remove map route line
    if (currentRouteLayer) {
        map.removeLayer(currentRouteLayer);
        currentRouteLayer = null;
    }

    // Clear UI (desktop)
    const itineraryContainer = document.getElementById('itinerary-container');
    const directionsContainer = document.getElementById('routing-directions');

    if (itineraryContainer) itineraryContainer.innerHTML = "";
    if (directionsContainer) directionsContainer.classList.remove('hidden');

    // Clear UI (mobile)
    const mobileItinerary = document.getElementById('mobile-itinerary-container');
    if (mobileItinerary) mobileItinerary.innerHTML = "";

    const modal = document.getElementById('directions-modal');
    if (modal) modal.classList.add('hidden');
}
// THE FIXED ROUTING FUNCTION
window.routeToFridge = function(lat, lng) {
    if (!userLat || !userLng) return alert("Please set your starting location first.");

    currentTargetFridge = { lat, lng };

resetRouteUI();

    const isMobile = window.innerWidth < 768;
    const directionsContainer = document.getElementById('routing-directions');
    const transportControls = document.getElementById('transport-controls');
    directionsContainer.prepend(transportControls);
    const itineraryContainer = document.getElementById('itinerary-container');
    const mobileItinerary = document.getElementById('mobile-itinerary-container');
    const modal = document.getElementById('directions-modal');
    
    // Show loading state
    const loadingHtml = "<p class='text-xs text-green-600 animate-pulse'>Calculating route...</p>";
        if (isMobile && modal && mobileItinerary) {
            modal.classList.remove('hidden');
            mobileItinerary.innerHTML = loadingHtml;
        } else {
            directionsContainer.classList.remove('hidden');
            itineraryContainer.innerHTML = loadingHtml;
        }

    const selectedMode = document.querySelector('input[name="transport"]:checked').value;
    const geoMode = profileMap[selectedMode] || "walk";
    const apiKey = "364fdb68178f4a09b69ef7df5051e13b";

    const url = `https://api.geoapify.com/v1/routing?waypoints=${userLat},${userLng}|${lat},${lng}&mode=${geoMode}&apiKey=${apiKey}`;

    fetch(url)
        .then(res => res.json())
        .then(data => {
            if (!data.features || data.features.length === 0) throw new Error("No route found");

            const routeData = data.features[0];
            const coords = routeData.geometry.coordinates[0].map(c => [c[1], c[0]]);
            currentRouteLayer = L.polyline(coords, {color: '#16a34a', weight: 5, opacity: 0.8}).addTo(map);
            const bounds = currentRouteLayer.getBounds();

            if (window.innerWidth < 768) {
                map.fitBounds(bounds, {
    animate: true,
    padding: [40, 40],
    maxZoom: 16
});
            } else {
                map.fitBounds(bounds, {
                    padding: [50, 50]
                });
            }
const distMi = (routeData.properties.distance * 0.000621371).toFixed(1);
const timeMin = Math.round(routeData.properties.time / 60);

const summary = document.getElementById("mobile-summary");
if (summary) {
    summary.innerHTML = `
        <div class="flex justify-between">
            <span>${distMi} mi</span>
            <span>${timeMin} min</span>
        </div>
    `;
}
            
            // Build the HTML for the steps
            let stepsHtml = `
<div class="mb-4 p-4 bg-green-600 dark:bg-purple-600 rounded-xl text-white shadow-md">
        <div class="flex justify-between items-center gap-2">
            <div class="flex flex-col">
                <span class="text-[10px] uppercase opacity-80 font-bold">Distance</span>
                <span class="text-lg font-extrabold leading-none">${distMi} mi</span>
            </div>
            <div class="h-8 w-px bg-white/20"></div>
            <div class="flex flex-col text-right">
                <span class="text-[10px] uppercase opacity-80 font-bold">Est. Time</span>
                <span class="text-lg font-extrabold leading-none">${timeMin} mins</span>
            </div>
        </div>
    </div>
`;

            routeData.properties.legs[0].steps.forEach((step, i) => {
                const stepDist = (step.distance * 0.000621371).toFixed(2);
                stepsHtml += `
                    <div class="text-sm py-3 border-b border-gray-100 dark:border-[#40376E] last:border-0 flex gap-3">
                        <span class="font-bold text-green-600 dark:text-purple-400">${i + 1}.</span> 
                        <div class="flex-grow">
                            <p class="text-gray-800 dark:text-gray-200">${step.instruction.text}</p>
                            <span class="text-[10px] text-gray-400 dark:text-gray-200 font-bold uppercase">${stepDist}</span>
                        </div>
                    </div>
                `;
            });

            // Inject into the correct container
            if (isMobile) {
                mobileItinerary.innerHTML = stepsHtml;
            } else {
                itineraryContainer.innerHTML = stepsHtml;
            }
        })
.catch(err => {
    const errorHtml = `<p class='text-red-500 text-sm'>Failed to load route</p>`;

    if (window.innerWidth < 768 && mobileItinerary) {
        mobileItinerary.innerHTML = errorHtml;
    } else {
        itineraryContainer.innerHTML = errorHtml;
    }

    console.error(err);
});
};

// Add this helper function
window.closeDirectionsModal = function() {
    document.getElementById('directions-modal').classList.add('hidden');
};

window.clearRoute = function() {
    if (currentRouteLayer) map.removeLayer(currentRouteLayer);

    document.getElementById('routing-directions').classList.add('hidden');
    document.getElementById('itinerary-container').innerHTML = "";

    const modal = document.getElementById('directions-modal');
    const mobileItinerary = document.getElementById('mobile-itinerary-container');

    if (modal) modal.classList.add('hidden');
    if (mobileItinerary) mobileItinerary.innerHTML = "";

    currentTargetFridge = null;
    const transportControls = document.getElementById('transport-controls');
    const placeholder = document.getElementById('transport-placeholder');

    if (placeholder) {
        placeholder.appendChild(transportControls);
    }
};

function renderFridges(fridges) {
    const list = document.getElementById("fridge-list");
    list.innerHTML = "";
    fridgeMarkers.forEach(m => map.removeLayer(m));
