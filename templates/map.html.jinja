<style>
/* =========================================================
   LEAFLET + MAP
========================================================= */
.leaflet-routing-container {
    display: none;
}

.leaflet-container {
    touch-action: pan-x pan-y;
}

.leaflet-tile {
    transition: filter 0.3s ease;
}

.leaflet-marker-icon {
    filter: drop-shadow(0 6px 12px rgba(0,0,0,0.25));
    transition: transform 0.2s ease;
}

.leaflet-marker-icon:hover {
    transform: scale(1.05);
}

.dark .leaflet-marker-icon {
    filter:
        drop-shadow(0 0 10px rgba(168,85,247,0.35))
        drop-shadow(0 6px 14px rgba(0,0,0,0.5));
}

#map {
    height: 100%;
    width: 100%;
    background: #0b0b10;
}


/* =========================================================
   ROUTING / DIRECTIONS
========================================================= */
#itinerary-container .leaflet-routing-alt {
    max-height: 300px;
    overflow-y: auto;
    background: transparent !important;
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    font-size: 13px;
    color: #166534;
}

#itinerary-container tr {
    display: flex;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid #e2e8f0;
}

/* Animated route line */
/* =========================================================
   ROUTE ANIMATION
========================================================= */

/* Main animated route */
.animated-route {
    stroke-linecap: round;
    stroke-linejoin: round;

    animation:
        routeFlow 1.2s linear infinite,
        routePulse 2s ease-in-out infinite;
}

/* Moving dashed effect */
@keyframes routeFlow {
    from {
        stroke-dashoffset: 24;
    }

    to {
        stroke-dashoffset: 0;
    }
}

/* Gentle breathing glow */
@keyframes routePulse {
    0%, 100% {
        opacity: 0.85;
        filter: drop-shadow(0 0 2px rgba(34,197,94,0.4));
    }

    50% {
        opacity: 1;
        filter: drop-shadow(0 0 8px rgba(34,197,94,0.9));
    }
}

/* Dark mode glow */
.dark .animated-route {
    filter: drop-shadow(0 0 10px rgba(168,85,247,0.8));
}

.route-draw {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: drawRoute 1.4s ease forwards;
}

@keyframes drawRoute {
    to {
        stroke-dashoffset: 0;
    }
}
/* =========================================================
   POPUPS
========================================================= */
.leaflet-popup-content button {
    pointer-events: auto;
}


/* =========================================================
   INPUTS + FORMS
========================================================= */
.input {
    width: 100%;
    padding: 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid #d1d5db;
    background: #f8fafc;
    transition: 0.25s;
}

.input:focus {
    border-color: #a78bfa;
    box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.3);
}

.dark .input {
    background: #2a2545;
    border-color: #40376E;
    color: #fff;
}

.dark .dropdown {
    background: #2a2545;
    border-color: #40376E;
}


/* =========================================================
   FORM CARD
========================================================= */
.form-card {
    background: linear-gradient(135deg, #ffffff, #f3f0ff);
    border: 1px solid #cac2d2;
}

.dark .form-card {
    background: linear-gradient(135deg, #1e1b2e, #2a2545);
    border: 1px solid #40376E;
}


/* =========================================================
   PAGE LAYOUT
========================================================= */
html,
body {
    height: 100%;
    margin: 0;
}

html {
    scroll-behavior: smooth;
    transition: background-color 0.3s ease,
                color 0.3s ease;
}

body {
    overflow: hidden;
    padding-bottom: env(safe-area-inset-bottom);

}

body > div {
    height: 100vh;
    overflow: hidden;
}

nav {
    position: relative;
    z-index: 9000;
}


/* =========================================================
   FLASH MESSAGES
========================================================= */
.flash-message {
    position: fixed;
    top: 90px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 99999;

    display: flex;
    align-items: center;
    gap: 8px;

    padding: 8px 12px;
    max-width: 260px;
    border-radius: 0.6rem;

    font-size: 13px;
    height: auto;

    opacity: 0;

    box-shadow: 0 10px 25px rgba(0,0,0,0.15);

    transition:
        opacity 0.3s ease,
        transform 0.3s ease;
}

.flash-success {
    background: #16a34a;
    color: white;
}

.flash-error {
    background: #dc2626;
    color: white;
}

.dark .flash-success {
    background: #6d28d9;
}

.dark .flash-error {
    background: #ef4444;
}


/* =========================================================
   SCROLLBARS
========================================================= */
.scrollbar-hide {
    scrollbar-width: thin;
    scrollbar-color: #22c55e transparent;
}

.scrollbar-hide::-webkit-scrollbar {
    width: 8px;
}

.scrollbar-hide::-webkit-scrollbar-track {
    background: transparent;
}

.scrollbar-hide::-webkit-scrollbar-thumb {
    background-color: #22c55e;
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: content-box;
}

.dark .scrollbar-hide::-webkit-scrollbar-thumb {
    background-color: #a855f7;
}
/* Light mode popup */
.leaflet-popup-content-wrapper {
    background: white;
    color: #111;
    border-radius: 12px;
}

.leaflet-popup-tip {
    background: white;
}

/* 🌙 Dark mode popup */
.dark .leaflet-popup-content-wrapper {
    background: #1f1a3a !important;
    color: white !important;
}

.dark .leaflet-popup-tip {
    background: #1f1a3a !important;
}

/* optional polish */
.leaflet-popup-content {
    margin: 0;
}

/* =========================================================
   MOBILE STYLES
========================================================= */
@media (max-width: 768px) {

    /* ---------------- SIDEBAR ---------------- */
#sidebar {
    position: fixed;
    bottom: 0;
    left: 0;

    width: 100%;
    height: 80vh;

    transform: translateY(calc(100% - 110px)); /* only peek handle */
    transition: transform 0.3s ease;

    border-radius: 18px 18px 0 0;

    z-index: 1000;
}

#sidebar.open {
    transform: translateY(0);
}

/* when user is navigating, shrink sidebar */
#sidebar.routing {
    height: 55vh;
}
    .dark #sidebar {
    background: rgba(27,23,48,0.92);
}



    #sidebar.hidden-state {
        transform: translateY(70%);
    }


    /* ---------------- FRIDGE LIST ---------------- */
    #fridge-list {
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
    }

    /* ---------------- DRAG HANDLE ---------------- */
    #sidebar.hidden-state #drag-handle {
        animation: bounceHint 1.5s infinite;
    }

    @keyframes bounceHint {
        0%,
        100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-4px);
        }
    }
}
    .animated-route {
        animation: none !important;
    }

    .leaflet-marker-icon {
        filter: none !important;
    }

    .leaflet-marker-icon:hover {
        transform: none;
    }
    #fridge-list li {
    min-height: 84px;
}
#routing-directions .mb-4 {
    position: sticky;
    top: 0;
    z-index: 10;
}
/* Directions reopen fade animation */
.fade-out-directions {
    opacity: 0;
    transform: translateY(10px) scale(0.95);
    pointer-events: none;

    transition:
        opacity 0.4s ease,
        transform 0.4s ease;
}
</style>
        <script>
