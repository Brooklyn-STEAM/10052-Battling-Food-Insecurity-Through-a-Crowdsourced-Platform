        </div>
        ${f.distance ? `<span class="text-xs font-bold text-green-700 dark:text-green-300 bg-green-100 dark:bg-[#1f1a3a] px-2 py-1 rounded-lg">${f.distance.toFixed(1)} mi</span>` : ''}
    `;

    // Existing buttons (unchanged)
    li.querySelector(".details-btn").onclick = (e) => {
        e.stopPropagation();
        saveRecentlyViewed(f);
        window.location.href = `/individfridge/${f.id}`;
    };

    li.querySelector(".fav-btn").onclick = (e) => {
        e.stopPropagation();
        toggleFavorite(f);
    };

    // ✅ Double click on list item → go to page
    li.ondblclick = () => {
        window.location.href = `/individfridge/${f.id}`;
    };

    // Normal click (UNCHANGED behavior)
        li.onclick = () => {
            saveRecentlyViewed(f);
            map.setView([f.lat, f.lng], 16);
            marker.openPopup();

            if (window.innerWidth >= 768) {
                window.routeToFridge(f.lat, f.lng); // desktop only
            }

            if (window.innerWidth < 768) {
                toggleBtn.classList.remove('hidden');
            }
        };

    list.appendChild(li);
});
}

document.querySelectorAll('input[name="transport"]').forEach(radio => {
    radio.onchange = () => {
        if (!currentTargetFridge) return;

        // IMPORTANT: force full reset BEFORE new route
        resetRouteUI();

        window.routeToFridge(
            currentTargetFridge.lat,
            currentTargetFridge.lng
        );
    };
});

document.getElementById("fridge-search").oninput = (e) => {
    renderFridges(allFridges.filter(f => f.name.toLowerCase().includes(e.target.value.toLowerCase())));
};

document.getElementById("set-start").onclick = () => {
    const address = document.getElementById("start-location").value;
    fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
        .then(res => res.json())
        .then(data => { 
