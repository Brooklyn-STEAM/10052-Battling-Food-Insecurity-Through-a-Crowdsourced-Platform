    <span class="font-bold text-base">${f.name}</span>
    <span class="text-xs text-gray-400 uppercase tracking-wide">
        ${f.status || 'Active'}
    </span>
            <div class="flex gap-2 mt-2">
                <button class="details-btn text-[10px] bg-green-600 text-white px-2 py-1 rounded">Details</button>
                <button class="fav-btn text-[10px] bg-yellow-500 text-white px-2 py-1 rounded">⭐</button>
