<script>
/* =========================================================
   SIDEBAR CONTROLS
========================================================= */
const sidebar = document.getElementById('sidebar');
const closeBtn = document.getElementById('close-sidebar');

function openSidebar() {
    sidebar.classList.add("open");
    sidebar.classList.remove("hidden-state");

    setTimeout(() => {
        map.invalidateSize();
    }, 300);
}

function hideSidebar() {
    sidebar.classList.remove("open");
    sidebar.classList.add("hidden-state");

    setTimeout(() => {
        map.invalidateSize();
    }, 300);
}

function toggleSidebar() {
    if (sidebar.classList.contains("open")) {
        hideSidebar();
    } else {
        openSidebar();
    }
}

closeBtn.onclick = hideSidebar;


/* =========================================================
   DRAGGING STATE
========================================================= */
let isDragging = false;
let startY = 0;
let currentY = 0;

let currentTranslate = 0;
const MAX_TRANSLATE = window.innerHeight * 0.6;


/* =========================================================
   MAP INITIALIZATION
========================================================= */
const map = L.map('map', {
    zoomAnimation: true,
    fadeAnimation: true,
    zoomControl: false
}).setView([40.7128, -74.0060], 12);

setTimeout(() => {
    map.invalidateSize();
}, 300);


/* =========================================================
   TILE LAYERS (LIGHT / DARK)
========================================================= */
const lightTiles = L.tileLayer(
    'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
    {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 20
    }
);

const darkTiles = L.tileLayer(
    'https://tiles.stadiamaps.com/tiles/alidade_smooth_dark/{z}/{x}/{y}{r}.png',
    {
        attribution: '&copy; Stadia Maps &copy; OpenMapTiles &copy; OpenStreetMap',
        maxZoom: 20
    }
);

// Track current layer
let currentTileLayer;


/* =========================================================
   APPLY MAP THEME
========================================================= */
window.applyMapTheme = function () {
    const isDark = document.documentElement.classList.contains('dark');

    if (currentTileLayer) {
        map.removeLayer(currentTileLayer);
    }

    currentTileLayer = isDark ? darkTiles : lightTiles;
    currentTileLayer.addTo(map);

    requestAnimationFrame(() => {
        map.invalidateSize();
    });
};

// Run on load
applyMapTheme();

L.control.zoom({ position: 'topright' }).addTo(map);


/* =========================================================
   MAP ICONS
========================================================= */
const userIcon = L.icon({
    iconUrl: "/static/images/pin.png",
    iconSize: [35, 35],
    className: "drop-shadow-lg"
});

const fridgeIcon = L.icon({
    iconUrl: "/static/images/fridge.png",
    iconSize: [45, 45],
    className: "drop-shadow-lg"
});


/* =========================================================
   GLOBAL VARIABLES
========================================================= */
let recentsBackup = null;
let undoTimeout = null;
let undoInterval = null;

let userLat, userLng, userMarker;

window.currentRouteLayer = null;

let currentTargetFridge = null;

let allFridges = [];
let fridgeMarkers = [];


// Profile Map for Geoapify
const profileMap = {
    "foot": "walk",
    "bicycle": "bicycle",
    "car": "drive"
};


/* =========================================================
   DISTANCE HELPERS
========================================================= */
function getDistance(lat1, lon1, lat2, lon2) {
    const R = 3958.8;

    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;

    const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(lat1 * Math.PI / 180) *
        Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLon / 2) ** 2;

    return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
}


/* =========================================================
   USER LOCATION
========================================================= */
function setUserLocation(lat, lng) {
    userLat = lat;
    userLng = lng;

    if (userMarker) {
        map.removeLayer(userMarker);
    }

    userMarker = L.marker([lat, lng], { icon: userIcon })
        .addTo(map)
        .bindPopup("Your Location")
        .openPopup();

    map.flyTo([lat, lng], 13, {
        duration: 0.8,
        easeLinearity: 0.25
    });

    renderFridges(allFridges);
}


/* =========================================================
   ROUTE UI RESET
========================================================= */
function resetRouteUI() {

    // Remove map route line
    if (window.currentRouteLayer) {
        map.removeLayer(window.currentRouteLayer);
        window.currentRouteLayer = null;
    }

    // Desktop
    const itineraryContainer =
        document.getElementById('itinerary-container');

    const directionsContainer =
        document.getElementById('routing-directions');

    if (itineraryContainer) {
        itineraryContainer.innerHTML = "";
    }

    if (directionsContainer) {
        directionsContainer.classList.remove('hidden');
    }

    // Mobile
    const mobileItinerary =
        document.getElementById('mobile-itinerary-container');

    if (mobileItinerary) {
        mobileItinerary.innerHTML = "";
    }

    const modal = document.getElementById('directions-modal');

    if (modal) {
        modal.classList.add('hidden');
    }
}


/* =========================================================
   ROUTING FUNCTION
========================================================= */
window.routeToFridge = function(lat, lng) {

    if (!userLat || !userLng) {
        return alert("Please set your starting location first.");
    }

    currentTargetFridge = { lat, lng };

    const isSameDestination =
        currentTargetFridge &&
        currentTargetFridge.lat === lat &&
        currentTargetFridge.lng === lng;

    if (isSameDestination && window.currentRouteLayer) {
        map.removeLayer(window.currentRouteLayer);
        window.currentRouteLayer = null;
    }

    const isMobile = window.innerWidth < 768;

    const directionsContainer =
        document.getElementById('routing-directions');

    const transportControls =
        document.getElementById('transport-controls');

    directionsContainer.prepend(transportControls);

    const itineraryContainer =
        document.getElementById('itinerary-container');

    const mobileItinerary =
        document.getElementById('mobile-itinerary-container');

    const modal =
        document.getElementById('directions-modal');

    // Loading state
    const loadingHtml =
        "<p class='text-xs text-green-600 animate-pulse'>Calculating route...</p>";

    if (isMobile && modal && mobileItinerary) {
        modal.classList.remove('hidden');
        mobileItinerary.innerHTML = loadingHtml;
    } else {
        directionsContainer.classList.remove('hidden');
        itineraryContainer.innerHTML = loadingHtml;
    }

    const selectedMode =
        document.querySelector('input[name="transport"]:checked').value;

    const geoMode = profileMap[selectedMode] || "walk";

    const apiKey =
        "364fdb68178f4a09b69ef7df5051e13b";

    const url =
        `https://api.geoapify.com/v1/routing?waypoints=${userLat},${userLng}|${lat},${lng}&mode=${geoMode}&apiKey=${apiKey}`;

    fetch(url)
        .then(res => res.json())
        .then(data => {

            if (!data.features || data.features.length === 0) {
                throw new Error("No route found");
            }

            const routeData = data.features[0];

            const coords =
                routeData.geometry.coordinates[0].map(c => [c[1], c[0]]);

            const isDark =
                document.documentElement.classList.contains('dark');

            window.currentRouteLayer = L.polyline(coords, {
                color: isDark ? '#a855f7' : '#16a34a',
                weight: 6,
                opacity: 1,
                dashArray: '12 16',
                className: 'animated-route'
            }).addTo(map);

            const bounds = window.currentRouteLayer.getBounds();

            map.fitBounds(bounds, {
                padding: [50, 50]
            });

            const distMi =
                (routeData.properties.distance * 0.000621371).toFixed(1);

            const timeMin =
                Math.round(routeData.properties.time / 60);
let stepsHtml = `
<div class="
    mb-5 p-5 rounded-3xl
    border border-white/10 dark:border-[#4c3b73]

    bg-gradient-to-br
    from-[#15803d]
    via-[#16a34a]
