/* =========================================================
   WINDOW RESIZE
========================================================= */
window.addEventListener("resize", () => {

    setTimeout(() => {
        map.invalidateSize(false);
    }, 250);

});
/* =========================================================
   SIDEBAR DRAGGING
========================================================= */
DOM.sidebar.addEventListener(
    "touchstart",
    (e) => {

        if (!e.target.closest("#drag-handle")) {
            return;
        }

        state.isDragging = true;

        state.startY =
            e.touches[0].clientY;

        DOM.sidebar.style.transition = "none";
    }
);

DOM.sidebar.addEventListener(
    "touchmove",
    (e) => {

        if (!state.isDragging) return;

        state.currentY = e.touches[0].clientY;

        const diff = state.currentY - state.startY;

        const now = Date.now();

        state.velocity =
            diff / (now - (state.lastMoveTime || now));

        state.lastMoveTime = now;

        const nextTranslate =
            state.currentTranslate + diff;

        state.currentTranslate = Math.max(
            0,
            Math.min(nextTranslate, MAX_TRANSLATE)
        );

        DOM.sidebar.style.transform =
            `translateY(${state.currentTranslate}px)`;

        state.startY = state.currentY;

    },
    { passive: true }
);
DOM.sidebar.addEventListener(
    "touchend",
    () => {

        if (!state.isDragging) return;

        state.isDragging = false;

        DOM.sidebar.style.transition =
            "transform 0.3s ease";

        const shouldClose =
    state.currentTranslate > MAX_TRANSLATE * 0.45 ||
    state.velocity > 0.6;

if (shouldClose)
 {

            hideSidebar();

        } else {

            openSidebar();
        }
    }
);


/* =========================================================
   FLASH MESSAGES
========================================================= */
function showFlashMessage(
    message,
    type = "error"
) {

    const existing =
        document.getElementById(
            "flash-message"
        );

    if (existing) {
        existing.remove();
    }

    const flash =
        document.createElement("div");

    flash.id = "flash-message";

    flash.className = `flash-message ${
        type === "error"
            ? "flash-error"
            : "flash-success"
    }`;

    flash.innerHTML =
        `<span>${message}</span>`;

    document.body.appendChild(flash);

    requestAnimationFrame(() => {

        flash.style.opacity = "1";

        flash.style.transform =
            "translateX(-50%) translateY(0)";
    });

    setTimeout(() => {

        flash.style.opacity = "0";

        flash.style.transform =
            "translateX(-50%) translateY(-6px)";

        setTimeout(() => {
            flash.remove();
        }, 300);

    }, 2000);
}


/* =========================================================
   REOPEN DIRECTIONS
========================================================= */
DOM.reopenDirections.onclick = () => {

    if (state.lastRoute) {

        restoreLastRoute();

    } else if (
        state.currentTargetFridge &&
        state.userLat &&
        state.userLng
    ) {

        window.routeToFridge(
            state.currentTargetFridge.lat,
            state.currentTargetFridge.lng
        );
    }

    if (isMobile()) {

        show(DOM.directionsModal);

    } else {

        openSidebar();
    }

    hide(DOM.reopenDirections);

    safeMapResize();
};

window.closeDirectionsModal = function () {
    hide(DOM.directionsModal);
};

