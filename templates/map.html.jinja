                ETA
            </span>

            <span class="text-3xl font-black text-white">
                ${timeMin} min
            </span>
        </div>

    </div>
</div>
`;
            routeData.properties.legs[0].steps.forEach((step, i) => {
                stepsHtml += `
                    <div class="text-sm py-2 border-b">
                        <b>${i + 1}.</b> ${step.instruction.text}
                    </div>
                `;
            });

            document.getElementById(
