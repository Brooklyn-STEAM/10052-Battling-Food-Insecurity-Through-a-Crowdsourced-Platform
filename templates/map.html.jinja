            </div>
        </aside>
    </div>
    <div id="directions-controls-mobile" class="mb-2"></div>

    <div id="directions-modal"
        class="hidden w-full max-h-[45dvh] bg-white dark:bg-[#1b1730] rounded-t-2xl p-2 overflow-y-auto md:hidden">
        <h2 class="font-bold text-base">Directions</h2>

        <div class="flex gap-2">
            <button onclick="window.clearRoute(); closeDirectionsModal()"
                class="text-[10px] font-bold text-red-500 border border-red-300 px-2 py-1 rounded-md">
                Clear
            </button>

            <button onclick="closeDirectionsModal()" class="text-[10px] font-bold text-gray-500">
                Close
            </button>
        </div>
    </div>

    <div id="mobile-itinerary-container" class="max-h-[55dvh] overflow-y-auto rounded-lg px-2 py-3
        text-sm leading-relaxed
                bg-white text-gray-900
                dark:bg-[#1b1730] dark:text-gray-100
                transition-colors">
    </div>

</body>
<script>
    window.mapTour = null;
    window.isMapTourActive = false;
    /* =========================================================
       CONFIG
    ========================================================= */
    const CONFIG = {
        DEFAULT_LOCATION: [40.7128, -74.0060],
        DEFAULT_ZOOM: 12,
        USER_ZOOM: 13,
        FRIDGE_ZOOM: 16,

        MOBILE_BREAKPOINT: 768,

        ROUTE_PADDING: [50, 50],

        ROUTE_STYLE: {
            light: '#16a34a',
            dark: '#a855f7',
            weight: 6,
            opacity: 1,
            dashArray: '12 16'
        },

        API: {
            GEOAPIFY_KEY: "364fdb68178f4a09b69ef7df5051e13b",
            FRIDGES: "/get-fridges",
            FAVORITES: "/get-favorites",
            TOGGLE_FAVORITE: "/toggle-favorite"
        }
    };


    /* =========================================================
       DOM CACHE
    ========================================================= */
    const DOM = {
        sidebar: document.getElementById('sidebar'),
        closeBtn: document.getElementById('close-sidebar'),
        sidebarToggle: document.getElementById("sidebar-toggle"),

        fridgeList: document.getElementById("fridge-list"),
        fridgeSearch: document.getElementById("fridge-search"),

        itinerary: document.getElementById('itinerary-container'),
        mobileItinerary: document.getElementById('mobile-itinerary-container'),

        directions: document.getElementById('routing-directions'),
        directionsModal: document.getElementById('directions-modal'),

        reopenDirections: document.getElementById('reopen-directions'),

        startLocation: document.getElementById("start-location"),
        setStart: document.getElementById("set-start"),

        favoritesList: document.getElementById("favorites-list"),
        recentList: document.getElementById("recent-list"),

        clearRecents: document.getElementById("clear-recents"),
        undoRecents: document.getElementById("undo-recents"),

        transportControls: document.getElementById('transport-controls')
    };


    /* =========================================================
       GLOBAL STATE
    ========================================================= */
    const state = {
        userLat: null,
        userLng: null,
        userMarker: null,

        currentRouteLayer: null,
        currentTargetFridge: null,

        allFridges: [],
        preparedFridges: [],
        lastRoute: null,

        recentsBackup: null,
        undoTimeout: null,
        undoInterval: null,

        currentTileLayer: null,

        isDragging: false,
        startY: 0,
        currentY: 0,
        currentTranslate: 0,
        sidebarState: "collapsed"
    };
    state.markerMap = new Map();

    const MAX_TRANSLATE = window.innerHeight * 0.6;


    /* =========================================================
       HELPERS
    ========================================================= */
    function isMobile() {
        return window.innerWidth < CONFIG.MOBILE_BREAKPOINT;
    }

    function show(el) {
        el?.classList.remove("hidden");

        requestAnimationFrame(() => {
            el.style.opacity = "1";
            el.style.transform = "translateY(0)";
        });
    }
    function hide(el) {
        el?.classList.add("hidden");
    }

    function clearHTML(el) {
        if (el) el.innerHTML = "";
    }

    function debounce(fn, delay = 250) {

        let timeout;

        return (...args) => {

            clearTimeout(timeout);

            timeout = setTimeout(() => {
                fn(...args);
            }, delay);

        };
    }
    let resizeRAF = null;

    function safeMapResize() {
        if (resizeRAF) return;

        resizeRAF = requestAnimationFrame(() => {
            resizeRAF = null;
        });
    }

    /* =========================================================
       API HELPERS
    ========================================================= */

    async function apiGet(url) {

        const res = await fetch(url);

        if (!res.ok) {
            throw new Error(`API Error: ${res.status}`);
        }

        return res.json();
    }

    async function apiPost(url, body = {}) {

        const res = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(body)
        });

        if (!res.ok) {
            throw new Error(`API Error: ${res.status}`);
        }

        return res.json();
    }


    /* =========================================================
       MAP INITIALIZATION
    ========================================================= */
    const map = L.map('map', {
        zoomAnimation: true,
        fadeAnimation: true,
        zoomControl: false
    }).setView(
        CONFIG.DEFAULT_LOCATION,
        CONFIG.DEFAULT_ZOOM
    );

    setTimeout(() => {
        safeMapResize();
    }, 300);

    map.on("click", (e) => {
        if (!isMobile()) return;

        closeFridgeSheet();

        const el = e.originalEvent?.target;

        // ignore clicks on UI elements
        if (
            el?.closest("#sidebar") ||
            el?.closest(".leaflet-popup") ||
            el?.closest(".leaflet-control") ||
            el?.closest("#directions-modal")
        ) return;

        hideSidebar();
        hide(DOM.directionsModal);
        hide(DOM.directions);
    });
    
    /* =========================================================
       TILE LAYERS
    ========================================================= */
    const lightTiles = L.tileLayer(
        'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
        {
            attribution: '&copy; OpenStreetMap &copy; CARTO',
            subdomains: 'abcd',
            maxZoom: 20,
            updateWhenIdle: false,
            updateWhenZooming: true,
            keepBuffer: 4

        }
    );

    const darkTiles = L.tileLayer(
        'https://tiles.stadiamaps.com/tiles/alidade_smooth_dark/{z}/{x}/{y}{r}.png',
        {
            attribution: '&copy; Stadia Maps &copy; OpenMapTiles &copy; OpenStreetMap',
            maxZoom: 20,
            updateWhenIdle: false,
            updateWhenZooming: true,
            keepBuffer: 4
        }
    );


    /* =========================================================
       APPLY MAP THEME
    ========================================================= */
    window.applyMapTheme = function () {

        const isDark =
            document.documentElement.classList.contains('dark');

        if (state.currentTileLayer) {
            map.removeLayer(state.currentTileLayer);
        }

        state.currentTileLayer =
            isDark ? darkTiles : lightTiles;

        state.currentTileLayer.addTo(map);

        requestAnimationFrame(() => {
            setTimeout(() => {
                safeMapResize();
            }, 250);
        });
    };

    applyMapTheme();


    /* =========================================================
       ICONS
    ========================================================= */
    const userIcon = L.icon({
        iconUrl: "/static/images/pin.png",
        iconSize: [35, 35],
        className: "fridge-marker"
    });

    const fridgeIcon = L.icon({
        iconUrl: "/static/images/fridge.png",
        iconSize: [45, 45],
        className: "fridge-marker"
    });


    /* =========================================================
       MOBILE BOTTOM SHEET
    ========================================================= */

    const SHEET = {
        FULL: 0,
        HALF: window.innerHeight * 0.45,
        PEEK: window.innerHeight * 0.6,
        CLOSED: window.innerHeight
    };

    state.sheetPosition = SHEET.FULL;
    state.dragStartY = 0;
    state.dragStartTranslate = 0;
    state.lastDragY = 0;
    state.lastDragTime = 0;
    state.velocity = 0;
    state.isDragging = false;

    /* =========================
       APPLY POSITION
    ========================= */
    function setSheetPosition(y, animate = true) {

        state.sheetPosition = y;

        DOM.sidebar.style.transition =
            animate
                ? "transform 0.28s cubic-bezier(.22,.9,.35,1)"
                : "none";

        DOM.sidebar.style.transform =
            `translateY(${y}px)`;
    }

    /* =========================
       SNAP LOGIC
    ========================= */
    function snapSheet() {

        const y = state.sheetPosition;

        const snapPoints = [SHEET.FULL, SHEET.HALF, SHEET.PEEK];

        // fast flick down → close
        if (state.velocity > 1.2) {
            return setSheetPosition(SHEET.CLOSED);
        }

        // fast flick up → open fully
        if (state.velocity < -1.2) {
            return setSheetPosition(SHEET.FULL);
        }

        let nearest = snapPoints[0];

        for (const point of snapPoints) {
            if (Math.abs(point - y) < Math.abs(nearest - y)) {
                nearest = point;
            }
        }

        setSheetPosition(nearest);
    }
    /* =========================
       OPEN/CLOSE HELPERS
    ========================= */
    function openSidebar() {
        setSheetPosition(SHEET.FULL);
    }

    function halfSidebar() {
        setSheetPosition(SHEET.HALF);
    }

    function hideSidebar() {
        setSheetPosition(SHEET.PEEK);
    }

    /* initial mobile state */
    if (isMobile()) {
        requestAnimationFrame(() => {
            setSheetPosition(SHEET.PEEK, false);
        });
    }

    /* =========================================================
       DRAGGING
    ========================================================= */

    const dragHandle =
        document.getElementById("drag-handle");

    dragHandle.addEventListener(
        "touchstart",
        (e) => {

            state.isDragging = true;

            state.dragStartY =
                e.touches[0].clientY;

            state.dragStartTranslate =
                state.sheetPosition;

            state.lastDragY =
                state.dragStartY;

            state.lastDragTime =
                performance.now();

            DOM.sidebar.style.transition = "none";
        },
        { passive: true }
    );
    window.addEventListener(
        "touchmove",
        (e) => {
            if (!state.isDragging) return;

            const currentY = e.touches[0].clientY;
            const delta = currentY - state.dragStartY;

            let next = state.dragStartTranslate + delta;

            // clamp bounds
            next = Math.max(SHEET.FULL, Math.min(next, SHEET.PEEK));

            const now = performance.now();

            state.velocity =
                (currentY - state.lastDragY) /
                Math.max(1, (now - state.lastDragTime));

            state.lastDragY = currentY;
            state.lastDragTime = now;

            setSheetPosition(next, false);
        },
        { passive: true }
    );
    window.addEventListener(
        "touchend",
        () => {

            if (!state.isDragging) return;

            state.isDragging = false;

            snapSheet();
        }
    );

    /* =========================================================
       BUTTONS
    ========================================================= */

    DOM.closeBtn.onclick = () => {
        hideSidebar();
    };
    DOM.sidebarToggle.onclick = () => {

        if (!isMobile()) return;

        if (state.sheetPosition <= SHEET.HALF) {
            hideSidebar();
        } else {
            openSidebar();
        }
    };
    /* =========================================================
       INITIAL MOBILE STATE
    ========================================================= */

    if (isMobile()) {
        hideSidebar();
    }
    /* =========================================================
       DISTANCE HELPERS
    ========================================================= */
    function getDistance(lat1, lon1, lat2, lon2) {

        const R = 3958.8;

        const dLat =
            (lat2 - lat1) * Math.PI / 180;

        const dLon =
            (lon2 - lon1) * Math.PI / 180;

        const a =
            Math.sin(dLat / 2) ** 2 +
            Math.cos(lat1 * Math.PI / 180) *
            Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon / 2) ** 2;

        return R * (
            2 * Math.atan2(
                Math.sqrt(a),
                Math.sqrt(1 - a)
            )
        );
    }


    /* =========================================================
       USER LOCATION
    ========================================================= */
    function setUserLocation(lat, lng) {

        state.userLat = lat;
        state.userLng = lng;

        if (state.userMarker) {
            map.removeLayer(state.userMarker);
        }

        state.userMarker = L.marker(
            [lat, lng],
            { icon: userIcon }
        )

            .addTo(map)

            .bindPopup(`
<div class="
    px-2 py-1.5
    text-center
    rounded-lg
    text-gray-900 dark:text-white
    w-[140px]
    md:w-auto
">

    <div class="text-sm md:text-lg font-black leading-tight">
        📍 Your Location
    </div>

    <div class="
        text-[9px] md:text-[11px]
        uppercase tracking-wide
        text-gray-500 dark:text-gray-400
        mt-0.5
    ">
        Starting Point
    </div>

</div>
`)

            .openPopup();

        map.setView(
            [lat, lng],
            CONFIG.USER_ZOOM,
            {
                duration: 0.8,
                easeLinearity: 0.25
            }
        );

        renderFridges(state.allFridges);
    }


    /* =========================================================
       ROUTE HELPERS
    ========================================================= */
    function clearRouteLayer() {

        if (!state.currentRouteLayer) return;

        map.removeLayer(state.currentRouteLayer);

        state.currentRouteLayer = null;
    }

    function drawRoute(coords) {

        clearRouteLayer();

        const isDark =
            document.documentElement.classList.contains('dark');

        state.currentRouteLayer = L.polyline(coords, {
            color: isDark
                ? CONFIG.ROUTE_STYLE.dark
                : CONFIG.ROUTE_STYLE.light,

            weight: CONFIG.ROUTE_STYLE.weight,
            opacity: CONFIG.ROUTE_STYLE.opacity,
            dashArray: CONFIG.ROUTE_STYLE.dashArray,
            className: 'animated-route'
        }).addTo(map);

        map.fitBounds(
            state.currentRouteLayer.getBounds(),
            {
                padding: CONFIG.ROUTE_PADDING
            }
        );
    }

    function createRouteSummary(distMi, timeMin) {

        return `
<div class="
    mb-5 p-5 rounded-3xl
    border border-white/10 dark:border-[#4c3b73]

    bg-gradient-to-br
    from-[#15803d]
    via-[#16a34a]
    to-[#34d399]

    dark:from-[#24183a]
    dark:via-[#3b2f63]
    dark:to-[#6d28d9]

    shadow-[0_12px_30px_rgba(0,0,0,0.18)]
    dark:shadow-[0_12px_35px_rgba(0,0,0,0.45)]
">

    <div class="flex items-center justify-between">

        <div class="flex flex-col">
            <span class="text-[10px] uppercase tracking-[0.25em] text-white/70 font-semibold">
                Distance
            </span>

            <span class="text-3xl font-black text-white">
                ${distMi} mi
            </span>
        </div>

        <div class="w-px h-10 bg-white/20 dark:bg-purple-300/20"></div>

        <div class="flex flex-col items-end">
            <span class="text-[10px] uppercase tracking-[0.25em] text-white/70 font-semibold">
                ETA
            </span>

            <span class="text-3xl font-black text-white">
                ${timeMin} min
            </span>
        </div>

    </div>
</div>
`;
    }


    /* =========================================================
       ROUTING
    ========================================================= */
    const profileMap = {
        foot: "walk",
        bicycle: "bicycle",
        car: "drive"
    };
    function getStepIcon(text = "") {
        const t = text.toLowerCase();

        if (t.includes("left")) return "⬅️";
        if (t.includes("right")) return "➡️";
        if (t.includes("slight left")) return "↖️";
        if (t.includes("slight right")) return "↗️";
        if (t.includes("sharp left")) return "⤴️";
        if (t.includes("sharp right")) return "⤵️";
        if (t.includes("continue") || t.includes("straight")) return "⬆️";
        if (t.includes("arrive")) return "📍";

        return "•";
    }

    function renderMobileDirections(distMi, timeMin, steps) {
        let html = `
        <div class="p-2 mb-2 rounded-lg bg-green-600 text-white font-bold text-xs flex justify-between">
            <span>${distMi} mi</span>
            <span>${timeMin} min</span>
        </div>
    `;

        steps.forEach((step, i) => {
            const icon = getStepIcon(step.instruction.text);

            html += `
<div class="flex items-start gap-2 text-sm py-2 border-b border-gray-200 dark:border-[#40376E] leading-relaxed">

                <span class="text-sm w-5 text-center">
                    ${icon}
                </span>

                <div class="flex-1">
                    <span class="font-bold mr-1">${i + 1}.</span>
                    ${step.instruction.text}
                </div>

            </div>
        `;
        });

        return html;
    }
    window.updateRouteTheme = function () {
        if (!state.currentRouteLayer) return;

        const isDark =
            document.documentElement.classList.contains('dark');

        state.currentRouteLayer.setStyle({
            color: isDark
                ? CONFIG.ROUTE_STYLE.dark
                : CONFIG.ROUTE_STYLE.light
        });
    };

    window.routeToFridge = async function (lat, lng) {

        if (!state.userLat || !state.userLng) {
            return alert("Please set your starting location first.");
        }

        state.currentTargetFridge = { lat, lng };

        const loadingHtml =
            `<p class='text-xs text-green-600 animate-pulse'>
            Calculating route...
        </p>`;

        show(DOM.directions);

        if (isMobile()) {
            show(DOM.directionsModal);

            requestAnimationFrame(() => {
                setTimeout(() => {
                    safeMapResize();
                }, 250);
            });

            DOM.mobileItinerary.innerHTML = loadingHtml;

        } else {
            DOM.itinerary.innerHTML = loadingHtml;
        }


        try {

            const selectedMode =
                document.querySelector(
                    'input[name="transport"]:checked'
                ).value;

            const geoMode =
                profileMap[selectedMode] || "walk";

            const url =
                `https://api.geoapify.com/v1/routing?waypoints=${state.userLat},${state.userLng}|${lat},${lng}&mode=${geoMode}&apiKey=${CONFIG.API.GEOAPIFY_KEY}`;

            const data = await apiGet(url);

            if (!data.features?.length) {
                throw new Error("No route found");
            }

            const routeData = data.features[0];

            const coords =
                routeData.geometry.coordinates[0]
                    .map(c => [c[1], c[0]]);

            drawRoute(coords);

            const distMi =
                (
                    routeData.properties.distance *
                    0.000621371
                ).toFixed(1);

            const timeMin =
                Math.round(
                    routeData.properties.time / 60
                );

            let stepsHtml = createRouteSummary(distMi, timeMin);

            routeData.properties.legs[0].steps.forEach((step, i) => {

                const icon = getStepIcon(step.instruction.text);

                stepsHtml += `
        <div class="flex items-start gap-2 text-xs py-2 border-b border-gray-200 dark:border-[#40376E] leading-snug">

            <span class="text-base w-6 text-center">
                ${icon}
            </span>

            <div class="flex-1">
                <span class="font-bold mr-1">${i + 1}.</span>
                ${step.instruction.text}
            </div>

        </div>
    `;
                show(DOM.directions);
                DOM.sidebar.classList.add("directions-open");
            });

            DOM.itinerary.innerHTML = stepsHtml;

            if (isMobile()) {
                DOM.mobileItinerary.innerHTML =
                    renderMobileDirections(distMi, timeMin, routeData.properties.legs[0].steps);
                hideSidebar();
            }

            state.lastRoute = {
                lat,
                lng,
                coords,
                distance: distMi,
                time: timeMin,
                rawSteps: routeData.properties.legs[0].steps
            };
        } catch (err) {
            console.error(err);
        }
    };


    /* =========================================================
       ROUTE RESTORE / CLEAR
    ========================================================= */
    window.clearRoute = function () {

        clearRouteLayer();

        // animate directions panel out
        DOM.directions.classList.add("fade-out-directions");

        setTimeout(() => {
            hide(DOM.directions);
            DOM.directions.classList.remove("fade-out-directions");
        }, 400);

        DOM.sidebar.classList.remove("directions-open");

        clearHTML(DOM.itinerary);
        hide(DOM.directionsModal);
        clearHTML(DOM.mobileItinerary);

        state.currentTargetFridge = null;

        // fade in reopen button
        DOM.reopenDirections.classList.remove("hidden");

        requestAnimationFrame(() => {
            DOM.reopenDirections.style.opacity = "1";
            DOM.reopenDirections.style.transform = "translateY(0)";
        });
    };
    function restoreLastRoute() {
        if (!state.lastRoute) return;

        const {
            coords,
            distance,
            time,
            steps
        } = state.lastRoute;

        drawRoute(coords);

        show(DOM.directions);

        const selectedMode =
            document.querySelector('input[name="transport"]:checked').value;

        const geoMode =
            profileMap[selectedMode] || "walk";

        const stepsData =
            state.lastRoute.rawSteps || [];

        const html = createRouteSummary(distance, time) +
            stepsData.map((step, i) => {
                const icon = getStepIcon(step.instruction.text);

                return `
                <div class="flex items-start gap-2 text-xs py-2 border-b border-gray-200 dark:border-[#40376E]">
                    <span class="w-5 text-center">${icon}</span>
                    <div><b>${i + 1}.</b> ${step.instruction.text}</div>
                </div>
            `;
            }).join("");

        DOM.itinerary.innerHTML = html;

        if (isMobile()) {
            DOM.mobileItinerary.innerHTML =
                renderMobileDirections(distance, time, stepsData);

            show(DOM.directionsModal);
            hideSidebar();
        }
    }

    /* =========================================================
       CREATE POPUP HTML
    ========================================================= */
    function createFridgePopup(f) {

        return `
<div class="p-4 rounded-2xl text-center text-gray-900 dark:text-white">

    <div class="mb-2">
        <div class="text-base font-black leading-tight">
            ${f.name}
        </div>

        <div class="text-[10px] uppercase tracking-wide text-gray-500 dark:text-gray-400 mt-1">
            ${f.status || 'Active'}
        </div>
    </div>

    <div class="flex gap-2 mt-4">

