        function createMarkers(fridges) {

            fridges.forEach(f => {

                if (state.markerMap.has(f.id)) return;

                const marker = L.marker(
                    [f.lat, f.lng],
                    { icon: fridgeIcon }
                ).addTo(map);

                // ONLY use Leaflet popups on desktop
                if (!isMobile()) {
                    marker.bindPopup(createFridgePopup(f));
                }

                marker.on('dblclick', () => {
                    window.location.href =
                        `/individfridge/${f.id}`;
                });

                marker.on('click', () => {

                    saveRecentlyViewed(f);

                    map.setView(
                        [f.lat, f.lng],
                        CONFIG.FRIDGE_ZOOM
                    );

                    if (isMobile()) {
                        openFridgeSheet(f);   // 👈 bottom sheet instead of popup
                    } else {
                        marker.openPopup();   // desktop stays same
                    }
                });
                state.markerMap.set(f.id, marker);
            });
