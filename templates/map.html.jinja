            ).innerHTML = stepsHtml;

            if (window.innerWidth < 768) {
                document.getElementById(
                    "mobile-itinerary-container"
                ).innerHTML = stepsHtml;
            }

            window.lastRoute = {
                lat,
                lng,
                coords,
                stepsHtml,
