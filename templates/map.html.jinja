    function moveTooltip(rect) {

        const NAVBAR_HEIGHT = 90;
        const PADDING = 16;
        const GAP = 18;

        const tooltipRect = tooltip.getBoundingClientRect();

        const tooltipWidth = tooltipRect.width || 320;
        const tooltipHeight = tooltipRect.height || 180;

        /* =========================
           DEFAULT POSITION
           BELOW + CENTERED
        ========================= */

        let left =
            rect.left +
            (rect.width / 2) -
            (tooltipWidth / 2);

        let top =
            rect.bottom + GAP;

        let position = "bottom";

        /* =========================
           IF TOO LOW -> PLACE ABOVE
        ========================= */

        if (
            top + tooltipHeight >
            window.innerHeight - PADDING
        ) {

            top =
                rect.top -
                tooltipHeight -
                GAP;

            position = "top";
        }

        /* =========================
           NAVBAR COLLISION
        ========================= */

        if (top < NAVBAR_HEIGHT) {

            top = NAVBAR_HEIGHT + 12;

            position = "bottom";
        }


        /* =========================
           LEFT EDGE
        ========================= */

        if (left < PADDING) {
            left = PADDING;
        }

        /* =========================
           RIGHT EDGE
        ========================= */

        if (
            left + tooltipWidth >
            window.innerWidth - PADDING
        ) {

            left =
                window.innerWidth -
                tooltipWidth -
                PADDING;
        }

        /* =========================
           MOBILE MODE
        ========================= */

        if (window.innerWidth < 768) {

            left = 16;
            top = window.innerHeight - tooltipHeight - 28;

            tooltip.style.width =
                "calc(100vw - 32px)";
        } else {

            tooltip.style.width = "";
        }

        /* =========================
           APPLY
        ========================= */

        top = Math.max(
            12,
            Math.min(
                top,
                window.innerHeight - tooltipRect.height - 12
            )
        );

        tooltip.style.top = `${top}px`;
        tooltip.style.left = `${left}px`;

        tooltip.dataset.position = position;
    };

