        text-white px-3 py-2 rounded-lg font-bold text-[11px]
        touch-manipulation">
        Directions
    </button>

</div>
`);

    // ✅ Double click on marker → go to page
    marker.on('dblclick', () => {
        window.location.href = `/individfridge/${f.id}`;
    });

    fridgeMarkers.push(marker);
marker.on('click', () => {
    saveRecentlyViewed(f);
