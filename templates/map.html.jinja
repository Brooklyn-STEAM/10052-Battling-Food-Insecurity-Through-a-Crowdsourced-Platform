function getElementRect(selector) {

    const selectors = selector.split(",");

    for (const s of selectors) {

        const el = document.querySelector(s.trim());

        if (!el) continue;

        const style = window.getComputedStyle(el);

        const hidden =
            style.display === "none" ||
            style.visibility === "hidden";

        if (hidden) continue;

        return el.getBoundingClientRect();
    }

    return null;
}
function getVisibleElement(selector) {

    const selectors = selector.split(",");

    for (const s of selectors) {

        const el = document.querySelector(s.trim());

        if (!el) continue;

        const style = window.getComputedStyle(el);

        const hidden =
            style.display === "none" ||
            style.visibility === "hidden";

        if (!hidden) return el;
    }

    return null;
}

function moveSpotlight(rect) {
    spotlight.style.width = rect.width + "px";
    spotlight.style.height = rect.height + "px";
    spotlight.style.transform =
    `translate(${rect.left + window.scrollX}px, ${rect.top + window.scrollY}px)`;
}

function moveTooltip(rect) {

    const NAVBAR_HEIGHT = 90;
    const PADDING = 16;
    const GAP = 18;

    const tooltipRect = tooltip.getBoundingClientRect();

    const tooltipWidth = tooltipRect.width || 320;
    const tooltipHeight = tooltipRect.height || 180;

    /* =========================
       DEFAULT POSITION
       BELOW + CENTERED
    ========================= */

    let left =
        rect.left +
        (rect.width / 2) -
        (tooltipWidth / 2);

    let top =
        rect.bottom + GAP;

    let position = "bottom";

    /* =========================
       IF TOO LOW -> PLACE ABOVE
    ========================= */

    if (
        top + tooltipHeight >
        window.innerHeight - PADDING
    ) {

        top =
            rect.top -
            tooltipHeight -
            GAP;

        position = "top";
    }

    /* =========================
       NAVBAR COLLISION
    ========================= */

    if (top < NAVBAR_HEIGHT) {

        top = NAVBAR_HEIGHT + 12;

        position = "bottom";
    }

    /* =========================
       LEFT EDGE
    ========================= */

    if (left < PADDING) {
        left = PADDING;
    }

    /* =========================
       RIGHT EDGE
    ========================= */

    if (
        left + tooltipWidth >
        window.innerWidth - PADDING
    ) {

        left =
            window.innerWidth -
            tooltipWidth -
            PADDING;
    }

    /* =========================
       MOBILE MODE
    ========================= */

    if (window.innerWidth < 768) {

        left = 16;
        top = window.innerHeight - tooltipHeight - 28;

        tooltip.style.width =
            "calc(100vw - 32px)";
    } else {

        tooltip.style.width = "";
    }

    /* =========================
       APPLY
    ========================= */

    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;

    tooltip.dataset.position = position;
}
function showStep(index) {
    const step = tutorialSteps[index];
    const el = getVisibleElement(step.el);

    if (!el) {
        nextStep();
        return;
    }

    const rect = el.getBoundingClientRect();

    titleEl.textContent = step.title;
    textEl.textContent = step.text;

    moveSpotlight(rect);
    moveTooltip(rect);
}

window.addEventListener("keydown", (e) => {

    if (e.key === "Escape") {
        endTutorial();
    }
});


function nextStep() {
    tutorialIndex++;

    if (tutorialIndex >= tutorialSteps.length) {
        endTutorial();
        return;
    }

    setTimeout(() => {
    showStep(tutorialIndex);
}, 150);
}

function endTutorial() {

    overlay.classList.add("hidden");

    document.body.classList.remove("tutorial-active");

    map.dragging.enable();
    map.touchZoom.enable();

    tutorialIndex = 0;
}
/* controls */
document.addEventListener("click", (e) => {

    if (e.target.id === "tutorial-next") {
        nextStep();
    }

    if (e.target.id === "tutorial-skip") {
        endTutorial();
    }

});

window.startMapTutorial = function () {
    if (window.driver) return; // prevent conflict

    tutorialIndex = 0;
    document.body.classList.add("tutorial-active");
    map.dragging.disable();
    map.touchZoom.disable();
    showStep(0);
};

window.addEventListener("load", () => {
    setTimeout(() => {
        // only show once per user
        if (!localStorage.getItem("map_tutorial_seen")) {
            window.startMapTutorial();
            localStorage.setItem("map_tutorial_seen", "true");
        }
    }, 800);
});
/* =========================================================
   MAP PAGE TUTORIAL LISTENER
========================================================= */

window.addEventListener("start-tutorial", () => {

    // mobile UX
    if (isMobile()) {
        openSidebar();
    }

    window.restartTutorial();
});
window.restartTutorial = function () {

    tutorialIndex = 0;

    document.body.classList.add("tutorial-active");

    overlay.classList.remove("hidden");

    // mobile prep
    if (isMobile()) {

        openSidebar();
    

        setTimeout(() => {
            safeMapResize();
            showStep(0);
        }, 350);

    } else {

        setTimeout(() => {
            showStep(0);
        }, 150);
    }
};
document.addEventListener("DOMContentLoaded", () => {

  const driver = window.driver.js.driver;

  const mapTour = driver({
    animate: true,
    smoothScroll: false,

    popoverClass: "fridgenet-tour",

    showProgress: true,
    showButtons: ["next", "previous", "close"],

    steps: [
      {
        element: "#map",
        popover: {
          title: "Your Map",
          description: "This is where community fridges appear.",
          side: "bottom"
        }
      },
      {
        element: "#search-bar",
        popover: {
          title: "Search",
          description: "Find fridges near you.",
          side: "bottom"
        }
      },
      {
        element: "#directions-btn",
        popover: {
          title: "Directions",
          description: "Get routes to a fridge.",
          side: "left"
        }
      }
    ],

    onStart: () => {
      document.body.style.overflow = "hidden";
    },

    onDestroy: () => {
      document.body.style.overflow = "";
    }
  });
window.addEventListener("load", () => {

    if (localStorage.getItem("map_tutorial_seen")) return;

    setTimeout(() => {

        if (window.driver) {
            mapTour.drive();
        } else {
            window.startMapTutorial();
        }

        localStorage.setItem("map_tutorial_seen", "true");

    }, 800);
});

});
</script>
