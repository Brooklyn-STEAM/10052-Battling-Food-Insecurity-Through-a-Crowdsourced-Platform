    function createMarkers(fridges) {

        let index = 0;
        const chunkSize = 125;

        function processChunk() {

            const slice = fridges.slice(index, index + chunkSize);

            slice.forEach(f => {

                if (state.markerMap.has(f.id)) return;

                const marker = L.marker(
                    [f.lat, f.lng],
                    { icon: fridgeIcon }
                ).addTo(map);

                if (!isMobile()) {
                    marker.bindPopup(createFridgePopup(f));
                }

                marker.on('click', () => {
                    saveRecentlyViewed(f);

                    map.setView(
                        [f.lat, f.lng],
                        CONFIG.FRIDGE_ZOOM
                    );

                    if (isMobile()) {
                        openFridgeSheet(f);
                    } else {
                        marker.openPopup();
                    }
                });

                state.markerMap.set(f.id, marker);
            });

            index += chunkSize;

            if (index < fridges.length) {
                requestAnimationFrame(processChunk);
            }
        }

        processChunk();
    }

    let sheetStartY = 0;
