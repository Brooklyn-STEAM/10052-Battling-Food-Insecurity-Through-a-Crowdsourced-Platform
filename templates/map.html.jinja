    <style>
/* =========================
   LIGHT SPOTLIGHT MODE (CLEAR VISIBILITY)
========================= */

#tutorial-tooltip {
  position: absolute;
  width: min(320px, calc(100vw - 24px));
  padding: 14px 16px;
  border-radius: 16px;

  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);

  backdrop-filter: blur(10px);

  transition: transform 0.25s ease, opacity 0.25s ease;
  z-index: 10000;
}

.dark #tutorial-tooltip {
  background: rgba(31, 26, 58, 0.92);
  border: 1px solid rgba(168, 85, 247, 0.25);
  box-shadow: 0 20px 70px rgba(0, 0, 0, 0.5);
}
#tutorial-title {
  font-size: 14px;
  letter-spacing: -0.01em;
}

#tutorial-text {
  margin-top: 6px;
  line-height: 1.4;
  opacity: 0.85;
}

#tutorial-tooltip button {
  transition: transform 0.15s ease, opacity 0.15s ease;
}

#tutorial-tooltip button:hover {
  transform: translateY(-1px);
}
        /* =========================================================
   LEAFLET + MAP
========================================================= */
        :root {
            --vh: 1vh;
            --navbar-height: 5rem
        }

        .leaflet-routing-container {
            display: none;
        }

        .leaflet-container {
            touch-action: pan-x pan-y;
        }

        .leaflet-tile {
            transition: filter 0.3s ease;
        }

        .leaflet-marker-icon {
            filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.25));
            transition: transform 0.2s ease;
        }

        .leaflet-marker-icon:hover {
            transform: scale(1.05);
        }

        .dark .leaflet-marker-icon {
            filter:
                drop-shadow(0 0 10px rgba(168, 85, 247, 0.35)) drop-shadow(0 6px 14px rgba(0, 0, 0, 0.5));
        }

        #map {
            height: 100%;
            width: 100%;
            background: #0b0b10;
        }


        /* =========================================================
   ROUTING / DIRECTIONS
========================================================= */
        #itinerary-container .leaflet-routing-alt {
            max-height: 300px;
            overflow-y: auto;
            background: transparent !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            font-size: 13px;
            color: #166534;
        }

        #itinerary-container tr {
            display: flex;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        /* Animated route line */
        /* =========================================================
   ROUTE ANIMATION
========================================================= */

        /* Main animated route */
        .animated-route {
            stroke-linecap: round;
            stroke-linejoin: round;
            animation:
                routeFlow 1s linear infinite,
                routePulseColor 2.5s linear infinite,
                routeGlow 2s ease-in-out infinite;
        }

        /* Desktop only */
        @media (min-width: 769px) {
            .animated-route {
                animation:
                    routeFlow 1.2s linear infinite,
                    routePulse 2s ease-in-out infinite;
            }
        }

        /* Moving dashed effect */
        @keyframes routeFlow {
            from {
                stroke-dashoffset: 24;
            }

            to {
                stroke-dashoffset: 0;
            }
        }

        /* Gentle breathing glow */
        @keyframes routePulse {

            0%,
            100% {
                opacity: 0.85;
                filter: drop-shadow(0 0 2px rgba(34, 197, 94, 0.4));
            }

            50% {
                opacity: 1;
                filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.9));
            }
        }

        /* Dark mode glow */
        .dark .animated-route {
            filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.8));
        }

        .route-draw {
            stroke-dasharray: 2000;
            stroke-dashoffset: 2000;
            animation: drawRoute 1.4s ease forwards;
        }

        @keyframes drawRoute {
            to {
                stroke-dashoffset: 0;
            }
        }



        /* =========================================================
   INPUTS + FORMS
========================================================= */
        .input {
            width: 100%;
            padding: 0.75rem;
            border-radius: 0.75rem;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            transition: 0.25s;
        }

        .input:focus {
            border-color: #a78bfa;
            box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.3);
        }

        .dark .input {
            background: #2a2545;
            border-color: #40376E;
            color: #fff;
        }

        .dark .dropdown {
            background: #2a2545;
            border-color: #40376E;
        }


        /* =========================================================
   FORM CARD
========================================================= */
        .form-card {
            background: linear-gradient(135deg, #ffffff, #f3f0ff);
            border: 1px solid #cac2d2;
        }

        .dark .form-card {
            background: linear-gradient(135deg, #1e1b2e, #2a2545);
            border: 1px solid #40376E;
        }


        /* =========================================================
   PAGE LAYOUT
========================================================= */
        html,
        body {
            height: 100%;
            margin: 0;
        }

        html {
            scroll-behavior: smooth;
            transition: background-color 0.3s ease,
                color 0.3s ease;
        }

        body {
            overflow-x: hidden;
            overflow-y: auto;
        }

        body>div {
            min-height: 100vh;
        }

        nav {
            position: relative;
            z-index: 9000;
        }


        /* =========================================================
   FLASH MESSAGES
========================================================= */
        .flash-message {
            position: fixed;
            top: 90px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 99999;

            display: flex;
            align-items: center;
            gap: 8px;

            padding: 8px 12px;
            max-width: 260px;
            border-radius: 0.6rem;

            font-size: 13px;
            height: auto;

            opacity: 0;

            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);

            transition:
                opacity 0.3s ease,
                transform 0.3s ease;
        }

        .flash-success {
            background: #16a34a;
            color: white;
        }

        .flash-error {
            background: #dc2626;
            color: white;
        }

        .dark .flash-success {
            background: #6d28d9;
        }

        .dark .flash-error {
            background: #ef4444;
        }


        /* =========================================================
   SCROLLBARS
========================================================= */
        .scrollbar-hide {
            scrollbar-width: thin;
            scrollbar-color: #22c55e transparent;
        }

        .scrollbar-hide::-webkit-scrollbar {
            width: 8px;
        }

        .scrollbar-hide::-webkit-scrollbar-track {
            background: transparent;
        }

        .scrollbar-hide::-webkit-scrollbar-thumb {
            background-color: #22c55e;
            border-radius: 999px;
            border: 2px solid transparent;
            background-clip: content-box;
        }

        .dark .scrollbar-hide::-webkit-scrollbar-thumb {
            background-color: #a855f7;
        }


        /* =========================================================
   MOBILE STYLES
========================================================= */
        /* =========================================================
   MOBILE DECLUTTER
========================================================= */
        @media (max-width: 768px) {

            /* Hide secondary sections on mobile */
            #recent-list,
            #clear-recents,
            #undo-recents {
                display: none !important;
            }

            /* Hide helper labels/text */
            #sidebar p,
            label[for="start-location"] {
                display: none !important;
            }

            /* Make sidebar cleaner */
            #sidebar .px-4.pt-2.pb-24 {
                padding-top: 0.5rem;
            }

            /* Reduce fridge card density */
            #fridge-list li {
                padding: 0.85rem;
                gap: 0.5rem;
            }

            /* Hide distance pill on mobile */
            #fridge-list li span.text-xs.font-bold {
                display: none;
            }

            /* Smaller buttons */
            .details-btn,
            .fav-btn {
                font-size: 9px;
                padding: 4px 8px;
            }

            /* Compact fridge titles */
            #fridge-list .font-bold.text-base {
                font-size: 0.95rem;
            }

            /* Hide desktop search */
            #fridge-search {
                display: none;
            }

            /* Cleaner drag handle spacing */
            #drag-handle {
                padding-top: 10px;
                padding-bottom: 10px;
            }

            /* =========================================================
   MOBILE BOTTOM SHEET POLISH
========================================================= */

            #sidebar {
                will-change: transform;
                touch-action: none;
                overscroll-behavior: contain;

                box-shadow:
                    0 -10px 40px rgba(0, 0, 0, 0.18);

            }

            #drag-handle {
                user-select: none;
                -webkit-user-select: none;
            }

            #drag-handle div {
                transition:
                    width 0.2s ease,
                    opacity 0.2s ease;
            }

            #drag-handle:active div {
                width: 5rem;
                opacity: 0.8;
            }

            /* smoother scroll */
            #sidebar .overflow-y-auto {
                -webkit-overflow-scrolling: touch;
            }

            /* prevents ugly bounce */
            body.dragging-sheet {
                overflow: hidden;
            }

            /* Route summary box */
            #mobile-itinerary-container .p-3.mb-3 {
                font-size: 12px;
                padding: 10px;
                border-radius: 12px;
            }

            /* Distance/ETA header */
            #mobile-itinerary-container .text-3xl {
                font-size: 1.1rem !important;
            }

            #mobile-itinerary-container .text-[10px] {
                font-size: 9px !important;
            }

            /* Step instructions */
            #mobile-itinerary-container .text-sm {
                font-size: 12px !important;
                line-height: 1.35rem;
            }

            /* Make spacing tighter */
            #mobile-itinerary-container div {
                padding-top: 6px;
                padding-bottom: 6px;
            }

            /* Reduce modal padding slightly */
            #directions-modal>div {
                padding: 10px !important;
            }


            /* =========================================================
   MOBILE FRIDGE BOTTOM SHEET
========================================================= */

            #fridge-sheet {
                will-change: transform;
            }

            #fridge-sheet.open {
                transform: translateY(0%);
            }

            #fridge-sheet::before {
                content: "";
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.35);
                z-index: -1;
            }

            /* smooth scroll */
            #fridge-sheet-content {
                -webkit-overflow-scrolling: touch;
            }

            #fridge-sheet>div {
                touch-action: none;
                will-change: transform;
            }

            #fridge-sheet.open {
                transform: translateY(0%);
                transition: transform 0.28s cubic-bezier(.22, .9, .35, 1);
            }
        }


        #routing-directions .mb-4 {
            position: sticky;
            top: 0;
            z-index: 10;
        }

        /* Directions reopen fade animation */
        .fade-out-directions {
            opacity: 0;
            transform: translateY(10px) scale(0.95);
            pointer-events: none;

            transition:
                opacity 0.4s ease,
                transform 0.4s ease;
        }

        /* =========================
   CLEAN LEAFLET POPUP FIX
========================= */

        .leaflet-popup {
            z-index: 9999;
        }

        /* main popup container */
        .leaflet-popup-content-wrapper {
            width: 260px;
            max-width: 85vw;
            border-radius: 16px;
            padding: 0;
            overflow: hidden;
            background: white;
            color: #111;
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.25);
        }

        /* dark mode */
        .dark .leaflet-popup-content-wrapper {
            background: #1f1a3a;
            color: white;
            box-shadow: 0 18px 55px rgba(0, 0, 0, 0.6);
        }

        /* content reset */
        .leaflet-popup-content {
            margin: 0;
            padding: 12px;
            width: 100% !important;
        }

        /* remove default tip cleanly */
        .leaflet-popup-tip {
            background: inherit;
            box-shadow: none;
        }

        /* title styling */
        .leaflet-popup-content b {
            font-size: 14px;
            display: block;
            margin-bottom: 6px;
        }

        /* buttons */
        .leaflet-popup-content button {
            border-radius: 10px;
            font-size: 12px;
            padding: 8px 10px;
            font-weight: 700;
            transition: 0.2s ease;
        }

        .leaflet-popup-content button:hover {
            transform: translateY(-1px);
        }

        .fav-btn {
            font-size: 10px;
            padding: 4px 8px;
            border-radius: 0.5rem;
            color: white;
            background: #eab308;
            /* yellow */
            transition: all 0.2s ease;
        }

        /* unfavorite state = RED */
        .fav-btn.favorited {
            background: #dc2626;
            color: #fff;
        }

        .fav-btn:hover {
            transform: scale(1.05);
        }
/* =========================
   CRISP SPOTLIGHT MODE (NO DIM, NO BLUR)
========================= */

#tutorial-spotlight {
