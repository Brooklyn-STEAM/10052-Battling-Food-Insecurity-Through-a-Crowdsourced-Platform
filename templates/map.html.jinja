     /* =========================
   FORCE MAP-STYLE TOUR MODE
   (kills homepage dark overlay)
========================= */


/* REMOVE global dimming layer */


/* REMOVE stage darkening */
.driver-stage {
  background: transparent !important;
}

/* KEEP ONLY spotlight cutout behavior */
#tutorial-spotlight {
