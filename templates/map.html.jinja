<!DOCTYPE html>
<html lang="en">

<head>

    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <meta charset="UTF-8">

    <title>Community Fridge Map</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

    <style>
        #map {
            height: 100%;
            min-height: 500px;
        }

        .leaflet-marker-icon:hover {
            transform: scale(1.2);
        }
    </style>

</head>

<body class="bg-gray-100 font-sans">

    {% include "components/navbar.html.jinja" %}

    <div class="flex h-screen">

        <!-- SIDEBAR -->

        <div class="w-1/3 bg-white p-6 overflow-y-auto">

            <h2 class="text-2xl font-bold mb-4">
                Nearby Community Fridges
            </h2>

            <input type="text" id="fridge-search" placeholder="Search fridges..."
                class="w-full p-2 border rounded mb-4" />

            <label class="font-semibold text-sm mb-2 block">
                Transportation
            </label>

            <div class="space-y-2 mb-4">

                <label class="flex items-center gap-2">
                    <input type="radio" name="transport" value="train" checked>
                    🚆 Train
                </label>

                <label class="flex items-center gap-2">
                    <input type="radio" name="transport" value="bus">
                    🚌 Bus
                </label>

                <label class="flex items-center gap-2">
                    <input type="radio" name="transport" value="bike">
                    🚲 Bike
                </label>

            </div>

            <div id="travel-info" class="mb-4 text-sm text-gray-700"></div>

            <ul id="fridge-list" class="space-y-3"></ul>

        </div>

        <!-- MAP -->

        <div id="map" class="w-2/3"></div>

    </div>

    <script>

        const targetFridge = {{ target_fridge| tojson if target_fridge else 'null' }};

        var map = L.map('map').setView([40.7128, -74.0060], 12);

        L.tileLayer(
            'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png'
        ).addTo(map);

        /* TRANSIT OVERLAY LAYERS */

        const trainRoutes = L.tileLayer(
            'https://{s}.tiles.openrailwaymap.org/standard/{z}/{x}/{y}.png'
        );

        const busRoutes = L.tileLayer(
            'https://tile.memomaps.de/tilegen/{z}/{x}/{y}.png'
        );

        const bikeLanes = L.tileLayer(
            'https://tile.waymarkedtrails.org/cycling/{z}/{x}/{y}.png'
        );

        const layers = {
            train: trainRoutes,
            bus: busRoutes,
            bike: bikeLanes
        }

        function switchLayer(layer) {

            Object.values(layers).forEach(l => {
                map.removeLayer(l)
            })

            layers[layer].addTo(map)

        }

        trainRoutes.addTo(map)

        /* ICONS */

        const userIcon = L.icon({
            iconUrl: "/static/images/pin.png",
            iconSize: [35, 35]
        })

        const fridgeIcon = L.icon({
            iconUrl: "/static/images/fridge.png",
            iconSize: [45, 45]
        })

        /* ROUTING */

        let routingControl = null
        let routingProfile = "walking"
        let userLat = null
        let userLng = null

        /* STORAGE FOR SEARCH */

        let allFridges = []
        let fridgeMarkers = []

        /* TRANSPORT RADIO BUTTONS */

        document.querySelectorAll('input[name="transport"]').forEach(radio => {

            radio.addEventListener("change", e => {

                let mode = e.target.value

                if (mode === "train") {
                    routingProfile = "walking"
                    switchLayer("train")
                }

                if (mode === "bus") {
                    routingProfile = "driving"
                    switchLayer("bus")
                }

                if (mode === "bike") {
                    routingProfile = "cycling"
                    switchLayer("bike")
                }

            })

        })

        /* ROUTE FUNCTION */

        function routeToFridge(lat, lng) {

            if (!userLat) {
                alert("Location unavailable")
                return
            }

            if (routingControl) {
                map.removeControl(routingControl)
            }

            routingControl = L.Routing.control({

                waypoints: [
                    L.latLng(userLat, userLng),
                    L.latLng(lat, lng)
                ],

                router: L.Routing.osrmv1({
                    serviceUrl: "https://router.project-osrm.org/route/v1",
                    profile: routingProfile
                }),

                showAlternatives: true,

                lineOptions: {
                    styles: [{ color: "#22c55e", weight: 6 }]
                }

            }).addTo(map)

            routingControl.on('routesfound', function (e) {

                let route = e.routes[0]

                let time = (route.summary.totalTime / 60).toFixed(0)
                let distance = (route.summary.totalDistance / 1000).toFixed(2)

                document.getElementById("travel-info").innerHTML =
                    `Travel time: <b>${time} minutes</b><br>
Distance: <b>${distance} km</b>`

            })

        }

        /* RENDER FRIDGES */

        function renderFridges(fridges) {

            const list = document.getElementById("fridge-list")
            list.innerHTML = ""

            /* REMOVE OLD MARKERS */

            fridgeMarkers.forEach(m => map.removeLayer(m))
            fridgeMarkers = []

            fridges.forEach(f => {

                const marker = L.marker([f.lat, f.lng], { icon: fridgeIcon })
                    .addTo(map)
                    .bindPopup(`
<b>${f.name}</b><br>
Status: ${f.status}<br>
<button onclick="routeToFridge(${f.lat},${f.lng})"
class="bg-green-500 text-white px-3 py-1 rounded mt-2">
Route Here
</button>
`)

                fridgeMarkers.push(marker)

                const li = document.createElement("li")

                li.className = "p-3 bg-gray-50 rounded cursor-pointer"

                li.innerHTML = `${f.name}`

                li.onclick = () => {
                    map.setView([f.lat, f.lng], 15)
                    marker.openPopup()
                }

                list.appendChild(li)

            })

        }

        /* SEARCH FUNCTION */

        document.getElementById("fridge-search").addEventListener("input", e => {

            let query = e.target.value.toLowerCase()

            let filtered = allFridges.filter(f =>
                f.name.toLowerCase().includes(query)
            )

            renderFridges(filtered)

        })

        /* LOAD FRIDGES */

        function loadFridges() {

            fetch("/get-fridges")
                .then(res => res.json())
                .then(data => {

                    allFridges = data
                    renderFridges(allFridges)

                })

        }

        /* USER LOCATION */

        navigator.geolocation.getCurrentPosition(

            pos => {

                userLat = pos.coords.latitude
                userLng = pos.coords.longitude

                L.marker([userLat, userLng], { icon: userIcon })
                    .addTo(map)
                    .bindPopup("You are here")

                map.setView([userLat, userLng], 13)

                loadFridges()

            },

            err => {

                userLat = 40.7128
                userLng = -74.0060

                loadFridges()

            }

        )

        /* AUTO ROUTE */

        if (targetFridge) {

            setTimeout(() => {

                routeToFridge(targetFridge.lat, targetFridge.lng)

                map.setView([targetFridge.lat, targetFridge.lng], 15)

            }, 1000)

        }

    </script>

    {% include "components/footer.html.jinja" %}

</body>

</html>