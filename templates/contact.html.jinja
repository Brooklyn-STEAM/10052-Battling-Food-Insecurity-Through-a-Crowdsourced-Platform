<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet Sign Up</title>
</head>

<body class="bg-gradient-to-r from-green-100 to-yellow-100 min-h-screen flex flex-col">

  {% include "components/navbar.html.jinja" %}

  <h1 class="text-4xl font-extrabold text-center text-green-800 mt-12">
    Contact Us
  </h1>

  <p class="text-center text-gray-600 mt-3 mb-12 max-w-2xl mx-auto px-4 text-lg">
    Have questions, feedback, or want to get involved? Reach out to us!
  </p>

  <div class="max-w-3xl mx-100 bg-white rounded-2xl shadow-xl p-10">
    <form method="post" class="space-y-5">

      <div>
        <label class="block font-semibold text-gray-700 mb-1">Name *</label>
        <input type="text" name="name" required
          class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400" />
      </div>

      <div>
        <label class="block font-semibold text-gray-700 mb-1">Email *</label>
        <input type="email" name="email" required
          class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400" />
      </div>

      <div>
        <label class="block font-semibold text-gray-700 mb-1">Message *</label>
        <textarea name="message" rows="5" required
          class="w-full border border-gray-300 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400"></textarea>
      </div>

      <button type="submit"
        class="w-full bg-green-500 text-white font-semibold py-3 rounded-xl hover:bg-green-600 transition">
        Send Message
      </button>

    </form>
  </div>


  {% include "components/footer.html.jinja" %}

</body>

</html>
