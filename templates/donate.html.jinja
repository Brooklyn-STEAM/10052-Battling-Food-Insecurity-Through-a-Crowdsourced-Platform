<!doctype html>
<html>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <title>Donate Food - FridgeNet</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = { darkMode: 'class' }
    </script>

    <script>
        (function () {
            const saved = localStorage.getItem("theme");
            if (saved === "dark") {
                document.documentElement.classList.add("dark");
            } else if (saved === "light") {
                document.documentElement.classList.remove("dark");
            }
        })();
    </script>

    <style>
        html { transition: background-color 0.3s ease, color 0.3s ease; }
        body, div { transition: background-color 0.3s ease, color 0.3s ease; }
    </style>
</head>
<body class="bg-gradient-to-b from-[#e8f9ee] to-white 
             dark:from-[#141225] dark:to-[#1b1730]
             min-h-screen flex flex-col text-gray-900 dark:text-gray-100 transition-colors duration-300">
    {% include "components/navbar.html.jinja" %}

    <main class="flex-grow pt-10">
        <section class="max-w-6xl mx-auto py-16 px-6 text-center">
            <h1 class="font-extrabold text-5xl md:text-6xl mb-6 text-[#166534] dark:text-[#b9a6ff] tracking-tight">
                DONATE FOOD <span class="text-[#f97316]">NEAR YOU</span>
            </h1>
            
            <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-12 text-xl leading-relaxed">
                FridgeNet connects neighbors, restaurants, and community fridges to make free food easy to find and share.
            </p>

            <div class="relative inline-block mb-16">
                <img class="relative w-full max-w-md sm:max-w-lg lg:max-w-2xl mx-auto rounded-3xl shadow-2xl"
                     src="/static/products/Donate.png" alt="Donate Illustration">
            </div>

            <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto text-left">
                
                <div class="group bg-white/80 backdrop-blur-sm dark:bg-[#2a2545] p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-[#40376E] hover:shadow-xl hover:-translate-y-1 transition-all">
                    <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center mb-6">
                        <svg class="text-green-600" width="28" height="28" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    </div>
                    <h2 class="font-bold text-2xl mb-4 text-[#166534] dark:text-white">WE ACCEPT</h2>
                    <ul class="space-y-3 text-gray-700 dark:text-gray-300">
                        <li>✅ Packaged Foods</li>
                        <li>✅ Fresh Produce</li>
                        <li>✅ Sealed Drinks</li>
                        <li>✅ Bakery Items (same day)</li>
                    </ul>
                </div>

                <div class="group bg-white/80 backdrop-blur-sm dark:bg-[#2a2545] p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-[#40376E] hover:shadow-xl hover:-translate-y-1 transition-all">
                    <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-xl flex items-center justify-center mb-6">
                        <svg class="text-red-600" width="28" height="28" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </div>
                    <h2 class="font-bold text-2xl mb-4 text-[#991b1b] dark:text-white">NOT ACCEPTING</h2>
                    <ul class="space-y-3 text-gray-700 dark:text-gray-300">
                        <li>❌ Open Containers</li>
                        <li>❌ Expired Food</li>
                        <li>❌ Alcohol</li>
                        <li>❌ Homemade Meals</li>
                    </ul>
                </div>
            </div>
        </section>

        <div class="flex justify-center pb-24">
            <a href="/donate"
               class="px-10 py-4 bg-[#f97316] text-white font-bold text-lg rounded-xl shadow-lg hover:bg-[#ea580c] transform hover:scale-105 transition-all duration-300 dark:bg-[#5a189a] dark:hover:bg-[#8C65DB]">
                Donate Food
            </a>
        </div>
    </main>

    {% include "components/footer.html.jinja" %}
</body>
</html>