<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/static/images/logo.png">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title> FridgeNet - Donate</title>
  </head>
  <body class="bg-gradient-to-r from-green-100 to-orange-300 min-h-screen flex flex-col"> 
  {% include "components/navbar.html.jinja" %}
  <div>
  <h1 class="font-bold text-4xl text-center p-6">DONATE FOOD NEAR YOU</h1>

<img class="w-full max-w-md sm:max-w-lg lg:max-w-2xl mx-auto mb-12" src="/static/products/Donate.png" >

<div class="flex flex-col md:flex-row justify-center gap-12 mb-12 bg-green-50 p-8 rounded-xl shadow-md">
  <div class="flex flex-col items-center">
    <svg xmlns="http://www.w3.org/2000/svg"
         width="48"
         height="48"
         viewBox="0 0 48 48">
      <g fill="none" stroke-linejoin="round" stroke-width="4">
        <path fill="#16a839" stroke="#000"
          d="M24 44C29.5228 44 34.5228 41.7614 38.1421 38.1421C41.7614 34.5228 44 29.5228 44 24C44 18.4772 41.7614 13.4772 38.1421 9.85786C34.5228 6.23858 29.5228 4 24 4C18.4772 4 13.4772 6.23858 9.85786 9.85786C6.23858 13.4772 4 18.4772 4 24C4 29.5228 6.23858 34.5228 9.85786 38.1421C13.4772 41.7614 18.4772 44 24 44Z"/>
        <path stroke="#fff" stroke-linecap="round" d="M16 24L22 30L34 18"/>
      </g>
    </svg>

    <p class="font-semibold mt-2">WE ACCEPT</p>
    <ul class="list-disc pl-5 text-left space-y-1 text-xl">
      <li>Packaged Foods</li>
      <li>Fresh Produce</li>
      <li>Sealed Drinks</li>
      <li>Bakery Items (same day)</li>
    </ul>
  </div>

  <div class="flex flex-col items-center">
    <svg xmlns="http://www.w3.org/2000/svg"
         width="48"
         height="48"
         viewBox="0 0 24 24">
      <g fill="#16a839">
        <path d="M8.478 8.478a1 1 0 0 1 1.414 0l2.154 2.153l2.153-2.153a1 1 0 1 1 1.414 1.414l-2.153 2.154l2.153 2.153a1 1 0 0 1-1.414 1.414l-2.153-2.153l-2.154 2.153A1 1 0 0 1 8.478 14.2l2.153-2.153l-2.153-2.154a1 1 0 0 1 0-1.414"/>
        
      </g>
    </svg>

    <p class="font-semibold mt-2">NOT ACCEPTING</p>
    <ul class="list-disc pl-5 text-left space-y-1 text-xl">
      <li>Open Containers</li>
      <li>Expired Food</li>
      <li>Alcohol</li>
      <li>Homemade Meals</li>
    </ul>
  </div>
  <div></div>
</div>
<div class="flex justify-center mb-12">
    <a href="/donate"
       class="px-6 py-3 hover:scale-80 bg-orange-600 text-white rounded-lg shadow-md hover:bg-green-600 transition duration-300">
      Donate
    </a>
  </div>

<div class="bg-green-200 py-8 text-center">
  <p class="text-xl sm:text-2xl lg:text-3xl font-bold px-4">
    HELP REDUCE FOOD WASTE BY DONATING SURPLUS FOOD TO COMMUNITY FRIDGES.
  </p>
</div>
