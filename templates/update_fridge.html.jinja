<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ fridge['Name'] }} -  Update Inventory</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50">

{% include "components/navbar.html.jinja" %}

<div class="max-w-4xl mx-auto py-10 px-6">

<!-- Title -->
<h1 class="text-3xl font-bold text-green-800 mb-6">
Update - {{ fridge['Name'] }}
</h1>

<!-- Last Updated -->
<div class="bg-green-100 border border-green-300 text-green-900 rounded-xl p-4 mb-8">
<strong>Last Updated:</strong>
{% if status %}
{{ status["Last_updated"].strftime('%b %d, %Y at %I:%M %p') }}
{% else %}  
No updates yet
{% endif %}
</div>

<form method="POST">

<!-- ================= INVENTORY ================= -->
<h2 class="text-2xl font-semibold text-green-700 mb-4">
Inventory
</h2>

<div class="space-y-4 mb-10">

{% for item in items %}
<div class="flex items-center justify-between bg-white p-4 rounded-xl shadow">

<div class="flex items-center gap-4">
<img src="{{ item['Image'] }}" class="w-8 h-8">
<span class="font-semibold text-green-800">
{{ item['Name'] }}
</span>
</div>

<div class="flex items-center gap-3">

<button type="button"
onclick="changeQty({{ item['ItemsID'] }}, -1)"
class="bg-red-500 hover:bg-red-600 text-white w-8 h-8 rounded-full">
-
</button>

<input 
    type="number" 
    id="qty_{{ item['ItemsID'] }}"
    value="{{ item['Quantity'] }}"
    readonly
    class="w-14 text-center border rounded-md bg-white"
>

<input 
    type="hidden"
    name="quantity_{{ item['ItemsID'] }}"
    id="hidden_qty_{{ item['ItemsID'] }}"
    value="{{ item['Quantity'] }}"
>


<button type="button"
onclick="changeQty({{ item['ItemsID'] }}, 1)"
class="bg-green-600 hover:bg-green-700 text-white w-8 h-8 rounded-full">
+
</button>

</div>

</div>
{% endfor %} 

</div>

<!-- ================= FULLNESS ================= -->
<h2 class="text-2xl font-semibold text-green-700 mb-4">
Fridge Fullness
</h2>

<div class="bg-white p-6 rounded-xl shadow mb-10">

<input
type="range"
name="fullness"
id="fullnessSlider"
min="0"
max="4"
step="1"
value="2"
class="w-full accent-green-600"
oninput="updateLabel(this.value)"
>

<div class="flex justify-between text-sm text-gray-500 mt-2">
<span>Empty</span>
<span>Few</span>
<span>Half</span>
<span>Many</span>
<span>Full</span>
</div>

<p id="fullnessLabel" class="text-center text-lg font-semibold text-green-700 mt-4">
Half Full
</p>

</div>
<!-- ================= Undo and Reset Button ================= -->
<div class="flex justify-between mt-6 mb-4">
    <button type="button"
        onclick="undoChanges()"
        class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold py-2 px-4 rounded-xl shadow">
        Undo Changes
    </button>

    <button type="button"
        onclick="resetAll()"
        class="bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-4 rounded-xl shadow">
        Reset All
    </button>
</div>

<!-- ================= SUBMIT ================= -->
<div class="mt-6">
<button type="submit"
class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-4 rounded-xl shadow-md transition">
Submit Update
</button>
</div>
</form>
</div>

<!-- RESET CONFIRMATION POPUP -->
<div id="reset-popup"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-[9999]">

  <div class="bg-white p-8 rounded-xl shadow-lg border w-[380px] scale-95 transition-transform duration-300">

    <h2 class="text-2xl font-bold text-orange-600 mb-4">Reset All Items?</h2>
    <p class="text-gray-700 mb-6">
      This will set every item’s quantity to <strong>0</strong>.  
      You can’t undo this after submitting.
    </p>

    <div class="flex justify-between">
      <button id="cancel-reset"
              class="px-5 py-3 rounded-xl font-medium text-gray-700 bg-gray-200 hover:bg-gray-300 transition">
        No, keep this item
      </button>

      <button id="confirm-reset"
              class="px-5 py-3 rounded-xl font-medium text-white bg-orange-600 hover:bg-orange-700 transition">
        Reset All
      </button>
    </div>

  </div>
</div>


<!-- JAVASCRIPT -->
<script>
/* 1. Global Data: Store original quantities for the Undo feature */
let originalQuantities = {
    {% for item in items %}
        "{{ item['ItemsID'] }}": {{ item['Quantity'] }},
    {% endfor %}
};

/* 2. Plus/minus buttons */
function changeQty(id, amount) {
    const input = document.getElementById("qty_" + id);
    const hidden = document.getElementById("hidden_qty_" + id);

    if (!input || !hidden) return;

    let value = parseInt(input.value) || 0;
    value = Math.max(0, value + amount);

    input.value = value;
    hidden.value = value;
}

/* 3. Fullness Slider Label Update */
function updateLabel(val) {
    const labels = ["Empty", "Few Items", "Half Full", "Many Items", "Full"];
    const labelEl = document.getElementById("fullnessLabel");
    if (labelEl) labelEl.innerText = labels[val];
}

/* 4. Undo Changes Logic */
function undoChanges() {
    for (const id in originalQuantities) {
        const input = document.getElementById("qty_" + id);
        const hidden = document.getElementById("hidden_qty_" + id);
        
        if (input) {
            input.value = originalQuantities[id];
            hidden.value = originalQuantities[id];
        }
    }
    // Also reset slider to default (Half Full)
    const slider = document.getElementById("fullnessSlider");
    if (slider) {
        slider.value = 2;
        updateLabel(2);
    }
}

/* 5. Open Reset Popup */
function resetAll() {
    const popup = document.getElementById("reset-popup");
    if (popup) popup.classList.remove("opacity-0", "pointer-events-none");
}

/* 6. Event Listeners for Popup Buttons */
document.addEventListener("DOMContentLoaded", () => {
    const popup = document.getElementById("reset-popup");
    const cancelBtn = document.getElementById("cancel-reset");
    const confirmBtn = document.getElementById("confirm-reset");

    // Close popup on Cancel
    if (cancelBtn) {
        cancelBtn.addEventListener("click", () => {
            popup.classList.add("opacity-0", "pointer-events-none");
        });
    }

    // Set everything to 0 on Confirm
    if (confirmBtn) {
        confirmBtn.addEventListener("click", () => {
            document.querySelectorAll("input[id^='qty_']").forEach(input => input.value = 0);
            document.querySelectorAll("input[id^='hidden_qty_']").forEach(input => input.value = 0);

            const slider = document.getElementById("fullnessSlider");
            if (slider) {
                slider.value = 0;
                updateLabel(0);
            }

            popup.classList.add("opacity-0", "pointer-events-none");
        });
    }
});
</script>

</div>
</div>

{% include "components/footer.html.jinja" %}


</div>
  </div>
</div>

</body>
</html>