<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ fridge['Name'] }} -  Update Inventory</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-50">

{% include "components/navbar.html.jinja" %}

<div class="max-w-4xl mx-auto py-10 px-6">

<!-- Title -->
<h1 class="text-3xl font-bold text-green-800 mb-6">
Update - {{ fridge['Name'] }}
</h1>

<!-- Last Updated -->
<div class="bg-green-100 border border-green-300 text-green-900 rounded-xl p-4 mb-8">
<strong>Last Updated:</strong>
{% if status %}
{{ status["Last_updated"].strftime('%b %d, %Y at %I:%M %p') }}
{% else %}  
No updates yet
{% endif %}
</div>

<form method="POST">

<!-- ================= INVENTORY ================= -->
<h2 class="text-2xl font-semibold text-green-700 mb-4">
Inventory
</h2>

<div class="space-y-4 mb-10">

{% for item in items %}
<div class="flex items-center justify-between bg-white p-4 rounded-xl shadow">

<div class="flex items-center gap-4">
<img src="{{ item['Image'] }}" class="w-8 h-8">
<span class="font-semibold text-green-800">
{{ item['Name'] }}
</span>
</div>

<div class="flex items-center gap-3">

<button type="button"
onclick="changeQty({{ item['ItemsID'] }}, -1)"
class="bg-red-500 hover:bg-red-600 text-white w-8 h-8 rounded-full">
-
</button>

<input 
type="number" 
name="quantity_{{ item['ItemsID'] }}"
id="qty_{{ item['ItemsID'] }}"
value="{{ item['Quantity'] }}"
class="w-16 text-center border rounded"
min="0"
readonly
>

<button type="button"
onclick="changeQty({{ item['ItemsID'] }}, 1)"
class="bg-green-600 hover:bg-green-700 text-white w-8 h-8 rounded-full">
+
</button>

</div>

</div>
{% endfor %} 

</div>

<!-- ================= FULLNESS ================= -->
<h2 class="text-2xl font-semibold text-green-700 mb-4">
Fridge Fullness
</h2>

<div class="bg-white p-6 rounded-xl shadow mb-10">

<input
type="range"
name="fullness"
id="fullnessSlider"
min="0"
max="4"
step="1"
value="2"
class="w-full accent-green-600"
oninput="updateLabel(this.value)"
>

<div class="flex justify-between text-sm text-gray-500 mt-2">
<span>Empty</span>
<span>Few</span>
<span>Half</span>
<span>Many</span>
<span>Full</span>
</div>

<p id="fullnessLabel" class="text-center text-lg font-semibold text-green-700 mt-4">
Half Full
</p>

</div>

<!-- ================= SUBMIT ================= -->
<div class="mt-6">
<button type="submit"
class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-4 rounded-xl shadow-md transition">
Submit Update
</button>
</div>

</form>

</div>

<script>
function changeQty(id, amount) {
    const input = document.getElementById("qty_" + id);
    let value = parseInt(input.value) || 0;

    value += amount;
    if (value < 0) value = 0;

    input.value = value;
}

function updateLabel(value) {
let text = "";
if (value == 0) text = "Empty";
if (value == 1) text = "Few Items";
if (value == 2) text = "Half Full";
if (value == 3) text = "Many Items";
if (value == 4) text = "Full";
document.getElementById("fullnessLabel").innerText = text;
}

const fridgeKey = `items_${fridgeId}`;
let localItems = JSON.parse(localStorage.getItem(fridgeKey)) || [];

function updateItems(newItems) {
  localItems = newItems;
  localStorage.setItem(fridgeKey, JSON.stringify(localItems));
}
function animateItems() {
  document.querySelectorAll("#list li").forEach((el, i) => {
    el.style.animationDelay = `${i * 0.05}s`;
    el.classList.add("fade-in");
  });
}

animateItems();


</script>

{% include "components/footer.html.jinja" %}

</body>
</html>