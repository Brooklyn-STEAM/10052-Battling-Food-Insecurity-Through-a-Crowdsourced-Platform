<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ fridge['Name'] }} - Update Inventory</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <script>
        (function () {
            const saved = localStorage.getItem("theme");
            if (saved === "dark") document.documentElement.classList.add("dark");
            else if (saved === "light") document.documentElement.classList.remove("dark");
            else document.documentElement.classList.toggle("dark", window.matchMedia("(prefers-color-scheme: dark)").matches);
        })();
    </script>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300">

{% include "components/navbar.html.jinja" %}

<div class="max-w-4xl mx-auto py-10 px-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-green-800 dark:text-green-400">
            Update - {{ fridge['Name'] }}
        </h1>
        <a href="/individfridge/{{ fridge['ID'] }}" class="text-green-600 hover:underline font-medium">← Back</a>
    </div>

    <div class="bg-green-600 dark:bg-green-900/30...">
    <span>
        <strong>Current Status:</strong> 
        {# Check for Fridge_status (capital) or fridge_status (lower) based on your preference #}
        {{ Fridge_status['Status'] | capitalize if Fridge_status else 'Unknown' }}
    </span>
    <span class="text-md text-end">
        <strong>Last Update:</strong> 
        {% if Fridge_status and Fridge_status['Last_updated'] %}
            {{ Fridge_status['Last_updated'].strftime('%b %d, %I:%M %p') }}
        {% else %}
            Never
        {% endif %}
    </span>
</div>

    <form method="POST">
        <h2 class="text-2xl font-semibold text-green-700 dark:text-green-400 mb-4 text-center md:text-left">Items in Fridge</h2>
        
        <div class="grid gap-4 mb-10">
            {% for item in items %}
            <div class="flex items-center justify-between bg-white dark:bg-gray-800 p-4 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex items-center gap-4">
                    <img src="{{ item['Image'] }}" class="w-12 h-12 rounded-lg object-cover bg-gray-100">
                    <div>
                        <span class="block font-bold text-gray-800 dark:text-gray-200">{{ item['Name'] }}</span>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <button type="button" onclick="changeQty({{ item['ItemsID'] }}, -1)"
                        class="bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 w-10 h-10 rounded-xl font-bold hover:bg-red-200 transition">-</button>

                    <input type="number" id="qty_display_{{ item['ItemsID'] }}" value="{{ item['Quantity'] }}" readonly
                        class="w-12 text-center font-bold bg-transparent border-none focus:ring-0">

                    <input type="hidden" name="quantity_{{ item['ItemsID'] }}" id="qty_input_{{ item['ItemsID'] }}" value="{{ item['Quantity'] }}">

                    <button type="button" onclick="changeQty({{ item['ItemsID'] }}, 1)"
                        class="bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 w-10 h-10 rounded-xl font-bold hover:bg-green-200 transition">+</button>
                </div>
            </div>
            {% endfor %}
        </div>

        <h2 class="text-2xl font-semibold text-green-700 dark:text-green-400 mb-4">Overall Fullness</h2>
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 mb-10">
            <input type="range" name="fullness" id="fullnessSlider" min="0" max="4" step="1" value="2"
                   class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-green-600"
                   oninput="updateLabel(this.value)">
            
            <div class="flex justify-between text-xs font-bold text-gray-400 mt-4 px-1 uppercase tracking-wider">
                <span>Empty</span>
                <span>Few</span>
                <span>Half</span>
                <span>Many</span>
                <span>Full</span>
            </div>

            <p id="fullnessLabel" class="text-center text-xl font-black text-green-600 mt-6 italic">Half Full</p>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
            <button type="button" onclick="undoChanges()"
                class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 font-bold py-3 px-4 rounded-xl transition">
                Undo Changes
            </button>
            <button type="button" onclick="showResetPopup()"
                class="bg-orange-100 dark:bg-orange-900/20 text-orange-600 font-bold py-3 px-4 rounded-xl hover:bg-orange-200 transition">
                Reset to Zero
            </button>
        </div>

        <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-black py-5 rounded-2xl shadow-lg transition transform active:scale-95 text-lg uppercase tracking-widest">
            Submit Update
        </button>
    </form>
</div>

<div id="reset-popup" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 z-[9999]">
    <div class="bg-white dark:bg-gray-900 p-8 rounded-3xl shadow-2xl w-[90%] max-w-md text-center">
        <div class="w-20 h-20 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-2">Are you sure?</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8">This will set <strong>all items</strong> in this fridge to zero. This action cannot be undone after submitting.</p>
        <div class="flex gap-4">
            <button onclick="closeResetPopup()" class="flex-1 px-6 py-3 rounded-xl bg-gray-100 dark:bg-gray-800 font-bold text-gray-500">Cancel</button>
            <button onclick="confirmReset()" class="flex-1 px-6 py-3 rounded-xl bg-orange-600 text-white font-bold hover:bg-orange-700">Yes, Reset All</button>
        </div>
    </div>
</div>

{% include "components/footer.html.jinja" %}

<script>
/* 1. Original State for Undo */
const originalQuantities = {
    {% for item in items %}
        "{{ item['ItemsID'] }}": {{ item['Quantity'] }},
    {% endfor %}
};

/* 2. Logic */
function changeQty(id, amount) {
    const display = document.getElementById("qty_display_" + id);
    const hiddenInput = document.getElementById("qty_input_" + id);
    
    let currentVal = parseInt(hiddenInput.value);
    let newVal = Math.max(0, currentVal + amount);
    
    display.value = newVal;
    hiddenInput.value = newVal;
}

function updateLabel(val) {
    const labels = ["Completely Empty", "A Few Items", "Half Full", "Mostly Full", "Completely Full"];
    document.getElementById("fullnessLabel").innerText = labels[val];
}

function undoChanges() {
    for (const id in originalQuantities) {
        document.getElementById("qty_display_" + id).value = originalQuantities[id];
        document.getElementById("qty_input_" + id).value = originalQuantities[id];
    }
}

function showResetPopup() {
    document.getElementById("reset-popup").classList.remove("opacity-0", "pointer-events-none");
}

function closeResetPopup() {
    document.getElementById("reset-popup").classList.add("opacity-0", "pointer-events-none");
}

function confirmReset() {
    document.querySelectorAll("input[id^='qty_display_']").forEach(el => el.value = 0);
    document.querySelectorAll("input[id^='qty_input_']").forEach(el => el.value = 0);
    const slider = document.getElementById("fullnessSlider");
    slider.value = 0;
    updateLabel(0);
    closeResetPopup();
}

// Init Label
updateLabel(document.getElementById("fullnessSlider").value);
</script>

</body>
</html>