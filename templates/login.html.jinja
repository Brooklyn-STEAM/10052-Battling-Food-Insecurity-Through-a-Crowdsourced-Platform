<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>

  <!-- Theme Loader -->
  <script>
    (function () {
      const saved = localStorage.getItem("theme");

      if (saved === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    })();
  </script>
  <style>
  html {
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body, div, section, nav, button, input, a, h1, h2, h3, p {
    transition: 
      background-color 0.3s ease, 
      color 0.3s ease, 
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
</style>
</head>

<body class="bg-gradient-to-r from-green-100 to-orange-100 
             dark:from-[#141225] dark:to-[#1b1730]
             min-h-screen flex flex-col 
             text-gray-900 dark:text-gray-100
             transition-colors duration-300">

  {% include "components/navbar.html.jinja" %}
  
  <!-- Login Section -->
  <section class="flex-grow flex items-center justify-center px-4 py-16
                  bg-gradient-to-r from-green-50 to-orange-100
                  dark:from-[#1b1730] dark:to-[#7C5EDB]
                  transition-colors duration-300">

    <div class="w-full max-w-md 
                bg-white dark:bg-[#1e1b2e]
                rounded-2xl shadow-xl p-10
                border border-green-100 dark:border-[#40376E]">

      <!-- Title -->
      <h1 class="text-4xl font-extrabold text-center 
                 text-green-800 dark:text-[#b9a6ff]">
        Welcome Back to 
        <span class="text-orange-500 dark:text-[#d8b4fe]">FridgeNet</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-center text-gray-600 dark:text-gray-300 mt-3">
        Sign in to find nearby community fridges and support your community.
      </p>

      <form method="post" class="mt-8 space-y-5">

        <!-- Email -->
        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Email *
          </label>
          <input type="email" name="email" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-500 dark:focus:ring-purple-400" />
        </div>

        <!-- Password -->
        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Password *
          </label>
          <input type="password" name="password" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-500 dark:focus:ring-purple-400" />
        </div>

        <!-- Button -->
        <button type="submit"
          class="w-full bg-green-600 hover:bg-green-700 
                 dark:bg-purple-600 dark:hover:bg-purple-700
                 text-white font-semibold py-2 rounded-xl shadow-md 
                 transition">
          Sign In
        </button>

        <!-- Signup -->
        <p class="text-center text-sm text-gray-600 dark:text-gray-300 pt-2">
          Don’t have an account?
          <a href="/signup" 
             class="text-green-700 dark:text-purple-300 font-semibold hover:underline">
            Create one
          </a>
        </p>

      </form>
    </div>
  </section>

  {% include "components/footer.html.jinja" %}

</body>

</html>