<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet Sign Up</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>

  <script>
    (function () {
      const saved = localStorage.getItem("theme");
      if (saved === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    })();
  </script>

  <style>
    html {
      scroll-behavior: smooth;
    }
    /* Smooth transitions for theme switching */
    body, div, section, nav, button, input, select, a, h1, p {
      transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    /* Flash message animation */
    .flash-message {
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
  </style>
</head>

<body class="bg-gray-50 dark:bg-[#0f0c1f] text-gray-900 dark:text-gray-100 min-h-screen flex flex-col">

  {% include "components/navbar.html.jinja" %}

  <main class="flex-grow flex items-center justify-center px-4 py-12 md:py-20 bg-gradient-to-br from-green-50 to-emerald-100 dark:from-[#141225] dark:to-[#1b1730]">

    <div class="w-full max-w-xl bg-white dark:bg-[#1b1730] rounded-3xl shadow-2xl p-6 md:p-10 border border-white/20 dark:border-[#40376E] backdrop-blur-sm">

      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-black text-green-800 dark:text-purple-300">
          Join <span class="text-yellow-500">FridgeNet</span>
        </h1>
        <p class="text-gray-500 dark:text-purple-200/60 mt-2 text-sm md:text-base">
          Reduce waste. Support neighbors. Share food.
        </p>
      </div>

      {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
          <div id="alert-container">
            {% for category, message in messages %}
              <div class="flash-message mb-4 px-4 py-3 rounded-xl text-white text-sm font-bold shadow-lg
                {% if category == 'signup_error' %} bg-red-500 {% else %} bg-green-600 dark:bg-purple-600 {% endif %}">
                {{ message }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {% endwith %}

      <form method="post" class="space-y-4 md:space-y-5">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Full Name</label>
            <input type="text" name="name" required placeholder="John Doe"
              class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Email</label>
            <input type="email" name="email" required placeholder="john@example.com"
              class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Password</label>
            <input type="password" name="password" required
              class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Confirm Password</label>
            <input type="password" name="repeat_password" required
              class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all" />
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Address</label>
          <input type="text" name="address" required placeholder="123 Street Name, City"
            class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Birthdate</label>
            <input type="date" name="birthdate" required max="{{ max_birthdate }}"
              class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-purple-300/50 mb-1 ml-1">Account Type</label>
            <select name="role" required
              class="w-full bg-gray-50 dark:bg-[#2a2545] border border-gray-200 dark:border-[#40376E] text-gray-900 dark:text-white rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-green-400 dark:focus:ring-purple-500 outline-none transition-all appearance-none cursor-pointer">
              <option value="" disabled selected>Select Role</option>
              <option value="user">Community User</option>
              <option value="restaurant">Restaurant/Partner</option>
            </select>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-6">
          <button type="submit"
            class="order-1 sm:order-2 w-full bg-green-600 hover:bg-green-700 dark:bg-purple-600 dark:hover:bg-purple-700 text-white font-bold py-3 rounded-xl shadow-lg active:scale-95 transition-all">
            Create Account
          </button>
          <button type="reset"
            class="order-2 sm:order-1 w-full bg-gray-100 dark:bg-[#2a2545] hover:bg-gray-200 dark:hover:bg-[#40376E] text-gray-600 dark:text-purple-100 font-bold py-3 rounded-xl transition-all">
            Reset
          </button>
        </div>

        <p class="text-center text-sm text-gray-500 dark:text-purple-200/50 pt-4">
          Already have an account? 
          <a href="/login" class="text-green-700 dark:text-purple-400 font-bold hover:underline">Sign in</a>
        </p>
      </form>
    </div>
  </main>

  {% include "components/footer.html.jinja" %}

  <script>
    // Auto-hide flash messages
    document.addEventListener("DOMContentLoaded", () => {
      const alerts = document.querySelectorAll(".flash-message");
      alerts.forEach(alert => {
        setTimeout(() => {
          alert.style.opacity = "0";
          alert.style.transform = "translateY(-10px)";
          setTimeout(() => alert.remove(), 700);
        }, 3000);
      });
    });
  </script>

</body>
</html>