<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/static/images/logo.png">
  <title>FridgeNet Sign Up</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>

  <!-- Theme Loader -->
  <script>
    (function () {
      const saved = localStorage.getItem("theme");

      if (saved === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    })();
  </script>
  <style>
  html {
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body, div, section, nav, button, input, a, h1, h2, h3, p {
    transition: 
      background-color 0.3s ease, 
      color 0.3s ease, 
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
</style>

</head>

<body class="bg-gradient-to-r from-green-100 to-yellow-100 
             dark:from-[#141225] dark:to-[#1b1730]
             text-gray-900 dark:text-gray-100 
             min-h-screen flex flex-col transition-colors duration-300">

  {% include "components/navbar.html.jinja" %}

  <!-- Section -->
  <section class="flex-grow flex items-center justify-center px-4 py-16 
                  bg-gradient-to-r from-green-50 to-emerald-100 
                  dark:from-[#1b1730] dark:to-[#7C5EDB] transition-colors duration-300">

    <!-- Card -->
    <div class="w-full max-w-2xl 
                bg-white dark:bg-[#1e1b2e]
                rounded-2xl shadow-xl p-10
                border border-green-100 dark:border-[#40376E]">

      <!-- Title -->
      <h1 class="text-4xl font-extrabold text-center 
                 text-green-800 dark:text-[#b9a6ff]">
        Create Your 
        <span class="text-yellow-500 dark:text-[#d8b4fe]">
          FridgeNet
        </span> 
        Account
      </h1>

      <!-- Subtitle -->
      <p class="text-center text-gray-600 dark:text-gray-300 mt-3">
        Join the community helping reduce food waste and support neighbors in need.
      </p>
{% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    {% for category, message in messages %}
      <div class="flash-message mb-4 px-4 py-3 rounded-xl 
                  bg-green-600 dark:bg-[#6f52c9] text-white text-sm shadow-md">
        {{ message }}
      </div>
    {% endfor %}
  {% endif %}
{% endwith %}
      <form method="post" class="mt-8 space-y-5">

        <!-- Input Template -->
        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Full Name *
          </label>
          <input type="text" name="name" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-400 dark:focus:ring-purple-400" />
        </div>

        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Email *
          </label>
          <input type="email" name="email" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-400 dark:focus:ring-purple-400" />
        </div>

        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Password *
          </label>
          <input type="password" name="password" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-400 dark:focus:ring-purple-400" />
        </div>

        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Repeat Password *
          </label>
          <input type="password" name="repeat_password" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-400 dark:focus:ring-purple-400" />
        </div>


        <!-- Address -->
        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Address *
          </label>
          <input type="text" name="address" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-400 dark:focus:ring-purple-400" />
        </div>

        <div>
          <label class="block font-semibold text-gray-700 dark:text-gray-300 mb-1">
            Birthdate *
          </label>
          <input type="date" name="birthdate" required
            class="w-full border border-gray-300 dark:border-[#40376E]
                   bg-white dark:bg-[#2a2545]
                   text-gray-900 dark:text-white
                   rounded-xl px-4 py-2
                   focus:outline-none focus:ring-2 
                   focus:ring-green-400 dark:focus:ring-purple-400" />
        </div>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">

          <button type="reset"
            class="w-full bg-gray-200 hover:bg-gray-300 
                   text-gray-800 dark:text-gray-300
                   dark:bg-[#2a2545] dark:hover:bg-[#40376E]
                   font-semibold py-2 rounded-xl transition">
            Reset
          </button>

          <button type="submit"
            class="w-full bg-green-600 hover:bg-green-700 
                   dark:bg-purple-600 dark:hover:bg-purple-700
                   text-white font-semibold py-2 rounded-xl shadow-md transition">
            Create Account
          </button>

        </div>

        <!-- Login -->
        <p class="text-center text-sm text-gray-600 dark:text-gray-300 pt-4">
          Already have an account?
          <a href="/login" 
             class="text-green-700 dark:text-purple-300 font-semibold hover:underline">
            Sign in
          </a>
        </p>

      </form>
    </div>
  </section>
  <script>
  document.addEventListener("DOMContentLoaded", () => {
    const alerts = document.querySelectorAll(".flash-message");

    alerts.forEach(alert => {
      setTimeout(() => {
        alert.classList.add("opacity-0", "translate-y-2");
        setTimeout(() => alert.remove(), 700);
      }, 3000);
    });
  });
</script>

  {% include "components/footer.html.jinja" %}

</body>
</html>