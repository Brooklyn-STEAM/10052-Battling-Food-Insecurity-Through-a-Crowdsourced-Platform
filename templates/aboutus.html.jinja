<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" type="image/png" href="/static/images/logo.png">

  <script>
    tailwind.config = { darkMode: 'class' }
  </script>

  <title>About Us | FridgeNet</title>

  <style>
    html { scroll-behavior: smooth; }

    .float {
      animation: float 6s ease-in-out infinite;
      will-change: transform;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }
  </style>
  <script>
  (function () {
    const saved = localStorage.getItem("theme");
    if (saved === "dark") {
      document.documentElement.classList.add("dark");
    } else if (saved === "light") {
      document.documentElement.classList.remove("dark");
    } else {
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.classList.toggle("dark", prefersDark);
    }
  })();
</script>
</head>

<body class="bg-gradient-to-br from-green-100 via-white to-yellow-100
             dark:from-[#0b0a18] dark:via-[#121028] dark:to-[#1a1635]
             min-h-screen flex flex-col text-gray-900 dark:text-gray-100
             transition-colors duration-500">

  {% include "components/navbar.html.jinja" %}

  <div class="relative overflow-x-hidden">

    <div class="fixed inset-0 -z-10 bg-gradient-to-br from-green-100 via-white to-yellow-100 transition-opacity duration-700 opacity-100 dark:opacity-0"></div>
    <div class="fixed inset-0 -z-10 bg-gradient-to-br from-[#0b0a18] via-[#121028] to-[#1a1635] transition-opacity duration-700 opacity-0 dark:opacity-100"></div>

    <section class="text-center px-6 pt-20 pb-12 relative z-10">
      <h1 class="text-5xl md:text-6xl font-extrabold mb-6 leading-[1.2] py-2
                 bg-gradient-to-r from-green-600 to-emerald-500
                 dark:from-purple-300 dark:to-indigo-400
                 bg-clip-text text-transparent">
        About FridgeNet
      </h1>
      <p class="max-w-2xl mx-auto text-lg text-gray-600 dark:text-gray-300">
        Fighting food waste and food insecurity through community-powered sharing.
      </p>
    </section>

    <section class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-5 gap-6 px-6 mb-16 text-center">
      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg transition-all duration-300">
        <p id="meals" class="text-2xl font-bold text-green-600 dark:text-purple-300">
          {{ "{:,}".format(stats.meals or 0) }}+
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400">Donations Made</p>
      </div>

      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg transition-all duration-300">
        <p id="users" class="text-2xl font-bold text-green-600 dark:text-purple-300">
          {{ "{:,}".format(stats.users or 0) }}+
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400">Active Users</p>
      </div>

      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg transition-all duration-300">
        <p id="fridges" class="text-2xl font-bold text-green-600 dark:text-purple-300">
          {{ stats.fridges or 0 }}+
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400">Community Fridges</p>
      </div>

      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg transition-all duration-300">
        <p id="food_saved" class="text-2xl font-bold text-green-600 dark:text-purple-300">
          {{ "{:,}".format((stats.food_saved or 0)|int) }}
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400">Food Items Shared</p>
      </div>

      {% if stats.money is defined %}
      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg transition-all duration-300">      
        <p id="money" data-raw="{{ stats.money or 0 }}" class="text-2xl font-bold text-green-600 dark:text-purple-300">
          ${{ "{:,}".format(stats.money|int) }}
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400">Money Donated</p>
      </div>
      {% endif %}
    </section>

    {% if current_user.is_authenticated %}
    <div class="float max-w-xl mx-auto p-10 rounded-3xl backdrop-blur-md
                  bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10
                  shadow-xl hover:shadow-2xl transition-all duration-300 text-center mb-16">
      <h3 class="text-2xl font-bold mb-2 text-green-700 dark:text-purple-300">
        Welcome back, {{ current_user.name }}!
      </h3>
      <p class="text-gray-600 dark:text-gray-400 mb-6">
        Ready to see your impact? Check your recent contributions.
      </p>
      <a href="/restaurant-dashboard" class="inline-block bg-orange-600 dark:bg-purple-600 text-white font-semibold px-8 py-3 rounded-xl shadow-md hover:bg-orange-700 dark:hover:bg-purple-700 transition">
        Go to Dashboard
      </a>
    </div>
    {% endif %}

    <section class="max-w-5xl mx-auto px-6 pb-20 grid gap-8 md:grid-cols-2 relative z-10">
      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg">
        <h2 class="text-xl font-bold mb-2 text-green-700 dark:text-purple-300">🌍 Our Mission</h2>
        <p class="text-gray-600 dark:text-gray-400">Bridge food surplus and food insecurity through simple, community-driven sharing.</p>
      </div>

      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg">
        <h2 class="text-xl font-bold mb-2 text-green-700 dark:text-purple-300">🧊 What We Do</h2>
        <p class="text-gray-600 dark:text-gray-400">Find fridges, donate food, and request supplies — all in one simple platform.</p>
      </div>

      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg">
        <h2 class="text-xl font-bold mb-2 text-green-700 dark:text-purple-300">📊 Our Impact</h2>
        <p class="text-gray-600 dark:text-gray-400">Real-time impact powered directly from community contributions.</p>
      </div>

      <div class="float p-6 rounded-2xl backdrop-blur-md bg-white/70 dark:bg-white/5 border border-gray-200 dark:border-white/10 shadow-lg">
        <h2 class="text-xl font-bold mb-2 text-green-700 dark:text-purple-300">💡 Why It Matters</h2>
        <p class="text-gray-600 dark:text-gray-400">Millions of tons of food are wasted while people go hungry — we’re fixing that.</p>
      </div>
    </section>

    <section class="text-center pb-24 px-6">
      {% if not current_user.is_authenticated %}
        <div class="max-w-xl mx-auto p-10 rounded-3xl bg-gradient-to-r from-green-500 to-emerald-500 dark:from-purple-700 dark:to-indigo-700 text-white shadow-2xl">
          <h3 class="text-3xl font-bold mb-3">Join the Movement</h3>
          <p class="opacity-90 mb-6">Make an impact in minutes — help your community today.</p>
          <a href="/signup" class="inline-block bg-white text-green-600 dark:text-purple-700 font-semibold px-8 py-3 rounded-xl shadow-md hover:scale-110 transition">
            Get Started
          </a>
        </div>
      {% endif %}
    </section>
  </div>

  {% include "components/footer.html.jinja" %}

<script>
function animateValue(el, start, end, isMoney = false, duration = 1500) {
  let startTime = null;
  const hasPlus = el.innerText.includes('+');

  function step(timestamp) {
    if (!startTime) startTime = timestamp;
    const progress = Math.min((timestamp - startTime) / duration, 1);
    // Easing function for smoother finish
    const easeOutQuad = t => t * (2 - t);
    const value = Math.floor(easeOutQuad(progress) * (end - start) + start);

    let formatted = value.toLocaleString();
    if (isMoney) formatted = `$${formatted}`;
    if (hasPlus) formatted = `${formatted}+`;
    
    el.innerText = formatted;

    if (progress < 1) {
      requestAnimationFrame(step);
    }
  }
  requestAnimationFrame(step);
}

function update(id, newValue, isMoney = false) {
  const el = document.getElementById(id);
  if (!el || newValue === undefined) return;

  // Extract digits only to get the raw current value
  const current = parseInt(el.dataset.raw || el.innerText.replace(/[^0-9]/g, "")) || 0;

  if (current !== newValue) {
    el.dataset.raw = newValue;
    animateValue(el, current, newValue, isMoney);
  }
}

async function loadStats() {
  try {
    const res = await fetch("/api/stats");
    if (!res.ok) throw new Error('Network response was not ok');
    const data = await res.json();

    update("users", data.users);
    update("fridges", data.fridges);
    update("meals", data.meals);
    update("food_saved", data.food_saved);

    if (document.getElementById("money")) {
      update("money", data.money, true);
    }
  } catch (err) {
    console.error("Failed to load stats:", err);
  }
}

// initial load
loadStats();
// refresh every 10 seconds (5s might be too aggressive for some servers)
setInterval(loadStats, 10000);
</script>
</body>
</html>